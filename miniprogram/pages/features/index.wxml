<view class="page {{themeClass}}">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <view><text class="title">FEATURES</text><text class="sub">专题</text></view>
  </view>
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="masthead"><text class="kicker">SOUNDIVE EDITORIAL</text><text class="headline">专题栏目，等待你的投稿</text><text class="deck">年度榜单、深度乐评与 Rapper 访谈，欢迎一起把内容做出来。</text></view>
    <scroll-view class="filters" scroll-x show-scrollbar="{{false}}"><view class="filter-row"><view wx:for="{{filters}}" wx:key="*this" class="filter {{activeFilter===item?'active':''}}" data-value="{{item}}" bindtap="onFilterTap"><text>{{item}}</text></view></view></scroll-view>
    <view class="feature-list">
      <view wx:for="{{features}}" wx:key="id" class="feature-card {{item.hero?'hero':''}}" data-id="{{item.id}}" bindtap="onFeatureTap">
        <view class="feature-top"><text class="feature-no">{{item.accent}}</text><text class="feature-cat">{{item.category}}</text></view>
        <text class="feature-title">{{item.title}}</text>
        <text class="feature-subtitle">{{item.subtitle}}</text>
        <view class="feature-meta"><text>{{item.status}}</text></view>
        <view class="feature-stats">
          <text class="feature-stat">{{item.viewDisplay}} 浏览</text>
          <text class="feature-dot">·</text>
          <text class="feature-stat">{{item.participantDisplay}} {{item.participantLabel}}</text>
          <text class="feature-dot">·</text>
          <text class="feature-stat">{{item.shareDisplay}} 分享</text>
          <text class="feature-dot">·</text>
          <text class="feature-heat">🔥 {{item.heatDisplay}} 热度</text>
        </view>
        <view class="feature-actions">
          <button class="feature-share" open-type="share" data-id="{{item.id}}" data-title="{{item.title}}" catchtap="noop"><text class="feature-share-icon">↗</text><text>分享</text></button>
          <text class="feature-arrow">{{item.cta}} →</text>
        </view>
      </view>
    </view>
  </scroll-view>
  <bottom-nav selected="{{3}}" />
</view>