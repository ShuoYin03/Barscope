<view class="page">

  <!-- TOPBAR -->
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <view class="topbar-back" bindtap="onBack">
      <text class="back-arrow">←</text>
    </view>
    <view class="topbar-titles">
      <text class="topbar-title">艺人审核</text>
      <text class="topbar-sub">ARTIST REVIEW</text>
    </view>
  </view>

  <!-- TAB BAR -->
  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      bindtap="onTabTap"
      data-key="{{item.key}}"
    >
      <text class="tab-label">{{item.label}}</text>
      <view wx:if="{{item.count > 0}}" class="tab-badge {{activeTab === item.key ? 'active' : ''}}">
        <text class="badge-num">{{item.count}}</text>
      </view>
    </view>
  </view>

  <!-- ══ CRITICS TAB ══════════════════════════════════════════════════════════ -->
  <block wx:if="{{activeTab === 'critics'}}">
    <!-- SEARCH -->
    <view class="critic-search-bar">
      <input
        class="critic-search-input"
        placeholder="搜索用户昵称…"
        value="{{criticKeyword}}"
        bindinput="onCriticKeyword"
        placeholder-style="color:#888"
      />
    </view>

    <scroll-view
      class="content"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      bindscrolltolower="onReachBottom"
    >
      <!-- SKELETON -->
      <block wx:if="{{criticLoading && criticList.length === 0}}">
        <view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="card-skeleton">
          <view class="sk skel-pic"></view>
          <view class="skel-body">
            <view class="sk skel-name"></view>
            <view class="sk skel-meta"></view>
          </view>
        </view>
      </block>

      <!-- EMPTY -->
      <view wx:elif="{{criticList.length === 0}}" class="empty-state">
        <text class="empty-icon">○</text>
        <text class="empty-text">{{ criticKeyword ? '没有匹配的用户' : '输入昵称搜索用户' }}</text>
      </view>

      <!-- USER CARDS -->
      <block wx:else>
        <view wx:for="{{criticList}}" wx:key="openId" class="card">

          <!-- AVATAR -->
          <view class="card-photo">
            <image wx:if="{{item.avatarUrl}}" class="photo-img" src="{{item.avatarUrl}}" mode="aspectFill" />
            <view wx:else class="photo-fallback">
              <text class="photo-initial">{{item.nickName[0]}}</text>
            </view>
          </view>

          <!-- INFO -->
          <view class="card-body">
            <view class="card-name-row">
              <text class="card-name">{{item.nickName}}</text>
              <view wx:if="{{item.type === 'critic'}}" class="status-chip critic-chip">乐评人</view>
              <view wx:elif="{{item.type === 'admin'}}" class="status-chip admin-chip">管理员</view>
            </view>
            <view class="card-meta-row">
              <text class="card-meta">{{item.reviewCount}} 条评论</text>
              <block wx:if="{{item.joinedAt}}">
                <view class="meta-dot"></view>
                <text class="card-meta">加入于 {{item.joinedAt}}</text>
              </block>
            </view>

            <!-- ACTION BUTTONS (skip admin) -->
            <view wx:if="{{item.type !== 'admin'}}" class="card-actions">
              <view
                wx:if="{{item.type !== 'critic'}}"
                class="btn-approve {{operating[item.openId] ? 'btn-disabled' : ''}}"
                bindtap="onGrantCritic"
                data-openid="{{item.openId}}"
              >
                <text class="btn-icon">★</text><text class="btn-label">认证乐评人</text>
              </view>
              <view
                wx:else
                class="btn-revoke {{operating[item.openId] ? 'btn-disabled' : ''}}"
                bindtap="onRevokeCritic"
                data-openid="{{item.openId}}"
              >
                <text class="btn-icon">✗</text><text class="btn-label">撤销认证</text>
              </view>
            </view>
          </view>

        </view>

        <!-- LOAD MORE -->
        <view wx:if="{{criticLoading}}" class="load-more">
          <text class="load-more-text">加载中…</text>
        </view>
        <view wx:elif="{{!criticHasMore && criticList.length > 0}}" class="list-end">
          <text class="list-end-text">── 已全部加载 ──</text>
        </view>
      </block>
    </scroll-view>
  </block>

  <!-- ══ CRAWLER TAB ════════════════════════════════════════════════════════ -->
  <block wx:elif="{{activeTab === 'crawler'}}">
    <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">

      <!-- STATUS CARD -->
      <view class="crawler-card">
        <view class="crawler-section-title">运行状态</view>
        <view class="crawler-status-row">
          <view class="status-dot {{crawlerStatus.status}}"></view>
          <text class="crawler-status-text">
            {{crawlerStatus.status === 'idle' ? '空闲' :
              crawlerStatus.status === 'pending' ? '等待中' :
              crawlerStatus.status === 'running' ? '运行中' :
              crawlerStatus.status === 'done' ? '已完成' :
              crawlerStatus.status === 'error' ? '出错' : '未知'}}
          </text>
          <text wx:if="{{crawlerStatus.completedAt}}" class="crawler-time-text">上次完成: {{crawlerStatus.completedAt}}</text>
        </view>

        <!-- PROGRESS (when running) -->
        <block wx:if="{{crawlerStatus.status === 'running' || crawlerStatus.status === 'pending'}}">
          <view class="crawler-progress-bar-track">
            <view
              class="crawler-progress-bar-fill"
              style="width: {{crawlerStatus.progress.totalArtists > 0 ? Math.round(crawlerStatus.progress.processedArtists / crawlerStatus.progress.totalArtists * 100) : 0}}%"
            />
          </view>
          <view class="crawler-meta-row">
            <text class="crawler-meta">艺人 {{crawlerStatus.progress.processedArtists}}/{{crawlerStatus.progress.totalArtists}}</text>
            <view class="meta-dot"></view>
            <text class="crawler-meta">发现专辑 {{crawlerStatus.progress.albumsFound}} 张</text>
            <view class="meta-dot"></view>
            <text class="crawler-meta">候选 {{crawlerStatus.progress.candidatesFound}} 位</text>
          </view>
        </block>

        <!-- LAST RUN SUMMARY -->
        <block wx:if="{{crawlerStatus.status === 'done' && crawlerStatus.lastRunSummary}}">
          <view class="crawler-summary-row">
            <view class="summary-chip">
              <text class="summary-num">+{{crawlerStatus.lastRunSummary.newAlbums}}</text>
              <text class="summary-label">新专辑</text>
            </view>
            <view class="summary-chip">
              <text class="summary-num">+{{crawlerStatus.lastRunSummary.newCandidates}}</text>
              <text class="summary-label">新候选</text>
            </view>
          </view>
        </block>
      </view>

      <!-- CONTROLS -->
      <view class="crawler-card">
        <view class="crawler-section-title">操作</view>
        <view class="crawler-actions-row">
          <view
            class="crawler-btn-run {{(crawlerStatus.status === 'running' || crawlerStatus.status === 'pending' || crawlerTriggering) ? 'btn-disabled' : ''}}"
            bindtap="onCrawlerTrigger"
          >
            <text class="crawler-btn-text">立即运行</text>
          </view>
          <view class="crawler-btn-clear" bindtap="onCrawlerClearLog">
            <text class="crawler-btn-text">清除日志</text>
          </view>
        </view>
      </view>

      <!-- SCHEDULE -->
      <view class="crawler-card">
        <view class="crawler-section-title">定时设置</view>
        <view class="crawler-schedule-row">
          <text class="crawler-schedule-label">启用定时</text>
          <switch checked="{{crawlerScheduleEnabled}}" bindchange="onScheduleToggle" color="#FFD600" />
        </view>
        <view wx:if="{{crawlerScheduleEnabled}}" class="crawler-interval-row">
          <view
            class="interval-chip {{crawlerScheduleInterval === 'daily' ? 'active' : ''}}"
            bindtap="onScheduleInterval" data-v="daily"
          ><text>每天</text></view>
          <view
            class="interval-chip {{crawlerScheduleInterval === 'weekly' ? 'active' : ''}}"
            bindtap="onScheduleInterval" data-v="weekly"
          ><text>每周</text></view>
        </view>
      </view>

      <!-- LOG -->
      <view class="crawler-card crawler-log-card">
        <view class="crawler-section-title">运行日志</view>
        <view wx:if="{{!crawlerStatus.log || crawlerStatus.log.length === 0}}" class="crawler-log-empty">
          <text class="crawler-meta">暂无日志</text>
        </view>
        <view wx:else class="crawler-log-list">
          <text wx:for="{{crawlerStatus.log}}" wx:key="*this" class="crawler-log-line">{{item}}</text>
        </view>
      </view>

    </scroll-view>
  </block>

  <!-- ══ CANDIDATE TABS ═══════════════════════════════════════════════════════ -->
  <block wx:else>
    <scroll-view
      class="content"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      bindscrolltolower="onReachBottom"
    >

      <!-- SKELETON -->
      <block wx:if="{{loading && list.length === 0}}">
        <view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="card-skeleton">
          <view class="sk skel-pic"></view>
          <view class="skel-body">
            <view class="sk skel-name"></view>
            <view class="sk skel-meta"></view>
            <view class="sk skel-meta skel-meta-short"></view>
          </view>
        </view>
      </block>

      <!-- EMPTY STATE -->
      <view wx:elif="{{list.length === 0}}" class="empty-state">
        <text class="empty-icon">✓</text>
        <text class="empty-text">
          {{activeTab === 'pending' ? '暂无待审核艺人' : activeTab === 'approved' ? '暂无已批准记录' : '暂无已拒绝记录'}}
        </text>
      </view>

      <!-- CANDIDATE CARDS -->
      <block wx:else>
        <view
          wx:for="{{list}}"
          wx:key="_id"
          class="card"
        >
          <!-- PHOTO -->
          <view class="card-photo">
            <image wx:if="{{item.picUrl}}" class="photo-img" src="{{item.picUrl}}" mode="aspectFill" />
            <view wx:else class="photo-fallback">
              <text class="photo-initial">{{item.artistName[0]}}</text>
            </view>
          </view>

          <!-- INFO -->
          <view class="card-body">
            <view class="card-name-row">
              <text class="card-name">{{item.artistName}}</text>
              <view wx:if="{{item.status === 'approved'}}" class="status-chip approved">批准</view>
              <view wx:if="{{item.status === 'declined'}}" class="status-chip declined">拒绝</view>
            </view>

            <text class="card-from">来自 {{item.foundFrom}} 的合作</text>
            <text wx:if="{{item.fromAlbum}}" class="card-album">《{{item.fromAlbum}}》</text>

            <view class="card-meta-row">
              <text class="card-meta">第 {{item.round}} 轮</text>
              <view class="meta-dot"></view>
              <text class="card-meta">{{item.albumSize}} 张专辑</text>
              <block wx:if="{{item.fansText}}">
                <view class="meta-dot"></view>
                <text class="card-meta">{{item.fansText}}</text>
              </block>
            </view>

            <!-- ACTION BUTTONS -->
            <view class="card-actions">
              <view wx:if="{{activeTab === 'pending'}}"
                class="btn-approve {{deciding[item._id] ? 'btn-disabled' : ''}}"
                bindtap="onApprove" data-id="{{item._id}}">
                <text class="btn-icon">✓</text><text class="btn-label">批准</text>
              </view>
              <view wx:if="{{activeTab === 'pending'}}"
                class="btn-decline {{deciding[item._id] ? 'btn-disabled' : ''}}"
                bindtap="onDecline" data-id="{{item._id}}">
                <text class="btn-icon">✗</text><text class="btn-label">拒绝</text>
              </view>
              <view wx:if="{{activeTab === 'approved'}}"
                class="btn-revoke {{deciding[item._id] ? 'btn-disabled' : ''}}"
                bindtap="onRevoke" data-id="{{item._id}}">
                <text class="btn-icon">↩</text><text class="btn-label">撤销</text>
              </view>
              <view wx:if="{{activeTab === 'declined'}}"
                class="btn-restore {{deciding[item._id] ? 'btn-disabled' : ''}}"
                bindtap="onRestore" data-id="{{item._id}}">
                <text class="btn-icon">↩</text><text class="btn-label">恢复</text>
              </view>
              <view
                class="btn-refresh {{refreshing[item._id] ? 'btn-disabled' : ''}}"
                bindtap="onRefresh" data-id="{{item._id}}">
                <text class="btn-refresh-icon">↻</text>
              </view>
            </view>
          </view>
        </view>

        <!-- LOAD MORE -->
        <view wx:if="{{loading}}" class="load-more">
          <text class="load-more-text">加载中…</text>
        </view>
        <view wx:elif="{{!hasMore && list.length > 0}}" class="list-end">
          <text class="list-end-text">── 已全部加载 ──</text>
        </view>
      </block>

    </scroll-view>
  </block>
</view>
