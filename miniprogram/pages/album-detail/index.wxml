<view class="page {{themeClass}}">
  <view class="back-bar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px; padding-bottom: 14rpx; box-sizing: border-box; align-items: flex-end; border-bottom: 2rpx solid var(--accent);" bindtap="onBack"><text class="back-icon">←</text><text class="back-label">ALBUM</text></view>
  <view wx:if="{{loading}}" class="loading-state"><text class="loading-text">加载中…</text></view>
  <scroll-view wx:elif="{{album}}" class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="hero"><view class="hero-main-row"><view class="hero-sleeve-wrap"><view class="hero-vinyl"><view class="hero-vinyl-label" /><view class="hero-vinyl-hole" /></view><view class="hero-sleeve"><image wx:if="{{album.coverUrl}}" class="hero-sleeve-img" src="{{album.coverUrl}}" mode="aspectFill" /><view wx:else class="hero-sleeve-fallback"><text>{{album.avgScore}}</text></view></view></view><view class="hero-info"><text class="hero-title">{{album.title}}</text><view class="hero-artist-row"><text class="hero-field-label">歌手</text><view wx:if="{{album.heroArtists.length === 1}}" class="hero-artist-link" bindtap="onGuestTap" data-id="{{album.heroArtists[0].id}}" data-name="{{album.heroArtists[0].name}}"><text class="hero-artist">{{album.heroArtists[0].name}}</text><text class="hero-arrow">›</text></view><view wx:elif="{{album.heroArtists.length > 1}}" class="hero-artist-multi"><view class="hero-artist-link" bindtap="onGuestTap" data-id="{{album.heroArtists[0].id}}" data-name="{{album.heroArtists[0].name}}"><text class="hero-artist">{{album.heroArtists[0].name}}</text></view><view class="artist-selector" bindtap="onOpenArtistSheet" data-source="album"><text>＋{{album.heroArtists.length - 1}}</text><text class="artist-selector-arrow">›</text></view></view><view wx:else class="hero-artist-link" bindtap="onArtistTap"><text class="hero-artist">{{album.primaryArtist || album.artist}}</text><text class="hero-arrow">›</text></view></view><view class="hero-date-row"><text class="hero-field-label">发行日期</text><text class="hero-meta-year">{{album.releaseDisplay}}</text></view><view wx:if="{{album.company}}" class="hero-company-row"><text class="hero-field-label">发行公司</text><text class="hero-company">{{album.company}}</text></view><view wx:if="{{album.releaseType}}" class="hero-company-row"><text class="hero-field-label">类型</text><text class="hero-company">{{album.releaseType}}</text></view></view></view><view class="rating-summary"><view class="rating-summary-cell"><text class="rating-summary-eyebrow">共 {{album.reviewCount}} 人打分</text><text class="rating-summary-value">{{album.avgScore}}</text></view><view class="rating-summary-divider"></view><view class="rating-summary-cell"><text class="rating-summary-eyebrow">精选评论</text><text class="rating-summary-value">{{reviews.length}}</text></view></view></view>
    <view class="album-section"><view class="section-head"><text class="section-label">SIDE A — 专辑简介</text></view><block wx:if="{{album.description}}"><text class="desc-text">{{descriptionExpanded ? album.description : descriptionPreview}}</text><view wx:if="{{hasLongDescription}}" class="desc-toggle" bindtap="onDescriptionToggle"><text>{{descriptionExpanded ? '收起' : '展开更多'}}</text><text class="desc-toggle-arrow">{{descriptionExpanded ? '↑' : '↓'}}</text></view></block><view wx:elif="{{trackSyncing}}" class="placeholder-row"><text class="placeholder-text">正在同步专辑简介…</text></view><view wx:else class="placeholder-row"><text class="placeholder-text">暂无专辑简介</text></view></view>
    <view class="album-section"><view class="section-head"><text class="section-label">SIDE B — Tracks</text><text class="section-count">{{album.tracks.length}}首</text></view><view wx:if="{{trackSyncing && album.tracks.length === 0}}" class="placeholder-row"><text class="placeholder-text">正在同步曲目…</text></view><view wx:elif="{{album.tracks.length === 0}}" class="placeholder-row"><text class="placeholder-text">暂无曲目信息</text></view><view wx:for="{{album.tracks}}" wx:key="songId" class="track-row"><text class="track-no">{{item.no < 10 ? '0' + item.no : item.no}}</text><view class="track-main"><text class="track-name">{{item.name}}</text><text class="track-artists">{{item.artistText}}</text></view><text wx:if="{{item.guestText}}" class="track-guest">ft. {{item.guestText}}</text></view></view>
    <view class="reviews-section"><view class="reviews-head"><text class="reviews-label">SIDE C — 乐评 REVIEWS</text><text class="reviews-count">{{reviews.length}}条</text></view><view wx:if="{{reviews.length === 0}}" class="no-reviews"><text class="no-reviews-text">还没有评论，来写第一条吧</text></view><view wx:for="{{reviews}}" wx:key="_id"><review-item review="{{item}}" bind:like="onLike" bind:reply="onReply" bind:usertap="onReviewUserTap" /></view></view>
    <view class="album-section"><view class="section-head"><text class="section-label">SIDE D — Featuring Guests</text><text class="section-count">{{album.featuringGuests.length}}人</text></view><view wx:if="{{album.featuringGuests.length === 0}}" class="placeholder-row"><text class="placeholder-text">暂无帮唱嘉宾</text></view><view wx:else class="guest-picker" bindtap="onOpenArtistSheet" data-source="guests"><view class="guest-picker-copy"><text class="guest-picker-title">查看 {{album.featuringGuests.length}} 位 Featuring Guests</text><text class="guest-picker-desc">点击查看嘉宾；未收录艺人可直接提交收录申请</text></view><text class="guest-picker-arrow">›</text></view></view>
    <view class="album-section"><view class="section-head"><text class="section-label">SIDE X — 纠错</text></view><view class="guest-picker" bindtap="onOpenCorrectionSheet"><view class="guest-picker-copy"><text class="guest-picker-title">修改封面 / 信息</text><text class="guest-picker-desc">统一修改封面、归属、日期、发行公司、类型、简介与曲目信息</text></view><text class="guest-picker-arrow">›</text></view></view>
  </scroll-view>
  <view wx:if="{{artistSheetVisible}}" class="artist-sheet-mask" bindtap="onCloseArtistSheet"><view class="artist-sheet" catchtap="noop"><view class="artist-sheet-handle" /><text class="artist-sheet-title">{{artistSheetTitle}}</text><navigator wx:for="{{artistSheetList}}" wx:key="name" class="artist-sheet-row" url="/pages/artist/index?artistId={{item.id}}&artistName={{item.name}}"><view class="artist-sheet-avatar"><image wx:if="{{item.avatarUrl}}" class="artist-sheet-avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" /><text wx:else>{{item.initial}}</text></view><view class="artist-sheet-copy"><text class="artist-sheet-name">{{item.name}}</text><text class="artist-sheet-note">{{item.note}}</text></view><text class="artist-sheet-go">›</text></navigator><view class="artist-sheet-cancel" bindtap="onCloseArtistSheet"><text>取消</text></view></view></view>
  <view wx:if="{{replySheetVisible}}" class="reply-sheet-mask" bindtap="onCloseReplySheet"><view class="reply-sheet" catchtap="noop"><view class="reply-sheet-handle" /><text class="reply-sheet-title">回复 <text>{{replyTargetName}}</text></text><textarea class="reply-sheet-textarea" placeholder="写下你的回复" placeholder-style="color:#6f6762" value="{{replyContent}}" bindinput="onReplyContentInput" maxlength="300" auto-focus /><text class="reply-sheet-count">{{replyContent.length}}/300</text><view class="reply-sheet-actions"><view class="reply-sheet-cancel" bindtap="onCloseReplySheet"><text>取消</text></view><view class="reply-sheet-submit {{replySubmitting ? 'btn-disabled' : ''}}" bindtap="onSubmitReply"><text>{{replySubmitting ? '发送中…' : '发送'}}</text></view></view></view></view>
  <view wx:if="{{!loading && !album}}" class="loading-state"><text class="loading-text">专辑不存在</text></view>
  <view wx:if="{{album}}" class="bottom-bar"><view class="btn-fav {{isFavorited ? 'is-fav' : ''}}" bindtap="onFavoriteToggle"><text class="btn-fav-icon">{{isFavorited ? '★' : '☆'}}</text></view><view class="btn-write" bindtap="onWriteReview"><text>＋ 写评论</text></view></view>
</view>