<view class="page {{themeClass}}">
  <view class="topbar" style="padding-top: {{statusBarHeight}}px">
    <text class="back" bindtap="onBack">←</text>
    <view class="topbar-copy">
      <text class="title">TRACK CORRECTION</text>
      <text class="subtitle">曲目纠错</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="state"><text>LOADING...</text></view>

  <scroll-view wx:else class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="album-block">
      <view class="album-main">
        <view class="album-copy">
          <text class="album-eyebrow">ALBUM</text>
          <text class="album-title">{{albumTitle}}</text>
        </view>
        <text class="album-count">{{tracks.length}} TRACKS</text>
      </view>
      <text class="album-note">提交后进入管理员审核，审核通过后才会更新正式曲目。</text>
    </view>

    <view class="track-list">
      <view wx:for="{{tracks}}" wx:key="clientKey" class="track-row {{draggingKey===item.clientKey ? 'dragging' : ''}}" bindtap="onOpenTrack" data-idx="{{index}}">
        <text class="track-no">{{index < 9 ? '0' + (index + 1) : index + 1}}</text>
        <view class="track-copy">
          <text class="track-name">{{item.name}}</text>
          <text class="track-feat" wx:if="{{item.guests.length}}">FEAT. {{item.guests[0].name}}{{item.guests.length > 1 ? ' 等' : ''}}</text>
          <text class="track-feat empty" wx:else>FEAT. —</text>
        </view>
        <view class="track-actions">
          <view class="drag-handle" data-key="{{item.clientKey}}" catchtouchstart="onDragStart" catchtouchmove="onDragMove" catchtouchend="onDragEnd" catchtouchcancel="onDragEnd">
            <text>≡</text>
          </view>
          <text class="track-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="add-track" bindtap="onAddTrack">
      <text class="add-track-plus">＋</text>
      <view class="add-track-copy">
        <text class="add-track-title">添加曲目</text>
        <text class="add-track-subtitle">ADD TRACK</text>
      </view>
      <text class="add-track-arrow">›</text>
    </view>

    <view class="list-end"><text>— END OF TRACKLIST —</text></view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="submit {{saving ? 'btn-disabled' : ''}}" bindtap="onSave"><text>{{saving ? '提交中…' : '提交修改'}}</text></view>
    <text class="submit-note">提交后进入管理员审核</text>
  </view>

  <view wx:if="{{editVisible}}" class="edit-sheet-mask" bindtap="onEditCancel">
    <view class="edit-sheet" catchtap="noop">
      <view class="sheet-handle" />
      <text class="sheet-title">{{editIsNew ? '添加曲目' : '编辑曲目'}}</text>
      <text class="sheet-index">TRACK {{editTrackIndex < 9 ? '0' + (editTrackIndex + 1) : editTrackIndex + 1}}</text>

      <text class="sheet-label">曲目名称</text>
      <input class="sheet-name-input" value="{{editName}}" bindinput="onEditNameInput" placeholder="输入曲目名称" placeholder-style="color:#766f68" maxlength="-1" />

      <text class="sheet-label feat-label">Featuring</text>
      <view class="sheet-feat-row" bindtap="onEditGuests">
        <view class="sheet-feat-copy">
          <view wx:if="{{tracks[editTrackIndex].guests.length}}" class="sheet-feat-chips">
            <text wx:for="{{tracks[editTrackIndex].guests}}" wx:for-item="g" wx:key="id" class="sheet-feat-chip">{{g.name}}</text>
          </view>
          <text wx:else class="sheet-feat-empty">暂无合作歌手</text>
        </view>
        <text class="sheet-feat-arrow">›</text>
      </view>

      <view class="sheet-actions">
        <view class="sheet-cancel" bindtap="onEditCancel"><text>取消</text></view>
        <view class="sheet-confirm" bindtap="onEditConfirm"><text>{{editIsNew ? '添加到曲目列表' : '保存本首修改'}}</text></view>
      </view>
    </view>
  </view>

  <view wx:if="{{pickerVisible}}" class="owner-sheet-mask" bindtap="onPickerCancel">
    <view class="owner-sheet" catchtap="noop">
      <view class="owner-sheet-handle" />
      <text class="owner-sheet-title">编辑 Featuring 歌手</text>
      <view wx:if="{{pickerSelected.length}}" class="owner-sheet-chips">
        <view wx:for="{{pickerSelected}}" wx:key="artistId" class="owner-chip" bindtap="onPickerRemove" data-id="{{item.artistId}}"><text>{{item.artistName}}</text><text class="owner-chip-x">×</text></view>
      </view>
      <view wx:else class="owner-sheet-hint"><text>暂无 Featuring 歌手</text></view>
      <input class="owner-sheet-input" placeholder="搜索歌手…" value="{{pickerKeyword}}" bindinput="onPickerSearch" placeholder-style="color:#766f68" />
      <scroll-view class="owner-sheet-results" scroll-y>
        <view wx:for="{{pickerResults}}" wx:key="artistId" class="owner-sheet-row {{item.selected ? 'selected' : ''}}" bindtap="onPickerPick" data-id="{{item.artistId}}">
          <view class="owner-sheet-avatar"><image wx:if="{{item.picUrl}}" class="owner-sheet-avatar-img" src="{{item.picUrl}}" mode="aspectFill" /><text wx:else>{{item.artistName[0]}}</text></view>
          <text class="owner-sheet-name">{{item.artistName}}</text>
          <text class="owner-sheet-check">{{item.selected ? '已选' : '选择'}}</text>
        </view>
      </scroll-view>
      <view class="owner-sheet-actions"><view class="owner-sheet-cancel" bindtap="onPickerCancel"><text>取消</text></view><view class="owner-sheet-confirm" bindtap="onPickerConfirm"><text>确定</text></view></view>
    </view>
  </view>
</view>