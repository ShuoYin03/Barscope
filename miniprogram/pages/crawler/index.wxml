<view class="page">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px"><view class="topbar-back" bindtap="onBack"><text class="back-arrow">←</text></view><view class="topbar-titles"><text class="topbar-title">CRAWLER</text><text class="topbar-sub">MGMT</text></view></view>
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="card"><view class="section-title">运行状态</view><view class="status-row"><view class="status-dot {{crawlerTriggering ? 'running' : crawlerStatus.status}}"></view><text class="status-text">{{crawlerTriggering ? '启动中' : crawlerStatus.status === 'idle' ? '空闲' : crawlerStatus.status === 'pending' ? '等待中' : crawlerStatus.status === 'running' ? '运行中' : crawlerStatus.status === 'done' ? '已完成' : crawlerStatus.status === 'aborted' ? '已中止' : crawlerStatus.status === 'error' ? '出错' : '—'}}</text><view wx:if="{{crawlerStatus.mode && crawlerStatus.status !== 'idle'}}" class="mode-tag"><text>{{ crawlerStatus.mode === 'allApproved' ? '全部已批准' : crawlerStatus.mode === 'artist' ? '艺人 ' + crawlerStatus.param : crawlerStatus.mode === 'album' ? '专辑 ' + crawlerStatus.param : '裂变' }}</text></view><text wx:if="{{!crawlerTriggering && crawlerStatus.completedAt}}" class="time-text">上次完成: {{crawlerStatus.completedAt}}</text></view><block wx:if="{{crawlerTriggering || crawlerStatus.status === 'running' || crawlerStatus.status === 'pending'}}"><view class="progress-track"><view wx:if="{{!crawlerTriggering && crawlerStatus.status === 'running'}}" class="progress-fill" style="width: {{crawlerProgressPct}}%" /></view><view class="meta-row"><text class="meta">{{crawlerTriggering ? '正在启动，请稍候…' : '云端处理中…'}}</text></view></block><block wx:if="{{!crawlerTriggering && (crawlerStatus.status === 'done' || crawlerStatus.status === 'aborted') && crawlerStatus.lastRunSummary}}"><view class="summary-row"><view class="summary-chip"><text class="summary-num">+{{crawlerStatus.lastRunSummary.newAlbums}}</text><text class="summary-label">新专辑</text></view><view class="summary-chip"><text class="summary-num">+{{crawlerStatus.lastRunSummary.newCandidates}}</text><text class="summary-label">新候选</text></view></view></block></view>
    <view class="card"><view class="section-title">爬取模式</view><view class="mode-grid"><view wx:for="{{crawlerModes}}" wx:key="key" class="mode-chip {{crawlerMode === item.key ? 'active' : ''}}" bindtap="onCrawlerModeTap" data-key="{{item.key}}"><text class="mode-label">{{item.label}}</text></view></view><text class="mode-desc">{{crawlerDesc}}</text><input wx:if="{{crawlerNeedsId}}" class="id-input" type="number" value="{{crawlerParam}}" placeholder="{{crawlerPlaceholder}}" placeholder-style="color:#888" bindinput="onCrawlerParamInput" /></view>
    <view class="card"><view class="section-title">操作</view><view class="actions-row"><view wx:if="{{crawlerStatus.status === 'running' || crawlerStatus.status === 'pending'}}" class="btn-abort" bindtap="onCrawlerAbort"><text class="btn-text">中止</text></view><view wx:else class="btn-run {{crawlerTriggering ? 'btn-disabled' : ''}}" bindtap="onCrawlerTrigger"><text class="btn-text">立即运行</text></view><view class="btn-clear" bindtap="onCrawlerClearLog"><text class="btn-text">清除日志</text></view></view><view class="actions-row" style="margin-top:16rpx"><navigator url="/pages/album-candidates/index" class="btn-clear" style="flex:1"><text class="btn-text">专辑候选区</text></navigator><view class="btn-clear {{metadataSyncing ? 'btn-disabled' : ''}}" style="flex:1" bindtap="onSyncArtistMetadata"><text class="btn-text">{{metadataSyncing ? '同步中' : '同步艺人资料'}}</text></view></view><view class="actions-row" style="margin-top:16rpx"><navigator url="/pages/album-quality-screen/index" class="btn-clear" style="flex:1"><text class="btn-text">重新筛选专辑</text></navigator><view class="btn-clear" style="flex:1" bindtap="onCleanupSingles"><text class="btn-text">清除单曲</text></view></view><view class="actions-row" style="margin-top:16rpx"><view class="btn-run {{ownershipRepairing ? 'btn-disabled' : ''}}" style="flex:1" bindtap="onRepairAlbumOwnership"><text class="btn-text">{{ownershipRepairing ? '归属修复中' : '修复专辑归属'}}</text></view></view><view wx:if="{{ownershipRepairing || ownershipChecked}}" class="meta-row" style="margin-top:16rpx"><text class="meta">已检查 {{ownershipChecked}} / {{ownershipTotal || '…'}} · 已校正 {{ownershipCorrected}} · 跳过 {{ownershipFailed}}</text></view><text wx:if="{{ownershipCurrent}}" class="mode-desc">当前：{{ownershipCurrent}}</text><text class="mode-desc">按网易云专辑页艺人栏校正历史归属；会移除被误收录到 rapper 页的专辑</text></view>
    <view class="card"><view class="section-title">定时设置</view><view class="schedule-row"><text class="schedule-label">启用定时</text><switch checked="{{crawlerScheduleEnabled}}" bindchange="onScheduleToggle" color="#C94E25" /></view><view wx:if="{{crawlerScheduleEnabled}}" class="interval-row"><view class="interval-chip {{crawlerScheduleInterval === 'daily' ? 'active' : ''}}" bindtap="onScheduleInterval" data-v="daily"><text>每天</text></view><view class="interval-chip {{crawlerScheduleInterval === 'weekly' ? 'active' : ''}}" bindtap="onScheduleInterval" data-v="weekly"><text>每周</text></view></view></view>
    <view class="card card-log"><view class="section-title">运行日志</view><view wx:if="{{crawlerLog.length === 0}}" class="log-empty"><text class="meta">暂无日志</text></view><view wx:else class="log-list"><text wx:for="{{crawlerLog}}" wx:key="*this" class="log-line">{{item}}</text></view></view>
  </scroll-view>
</view>