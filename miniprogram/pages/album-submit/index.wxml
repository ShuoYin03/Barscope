<view class="page {{themeClass}}"><view class="topbar" style="padding-top:{{statusBarHeight}}px"><text class="back" bindtap="onBack">←</text><text class="title">SUBMIT ALBUM</text></view><scroll-view class="content" scroll-y><block wx:if="{{mode==='search'}}"><view class="section"><text class="label">先搜索网易云</text><input class="input" value="{{searchName}}" data-field="searchName" bindinput="onInput" placeholder="输入专辑名称" placeholder-class="ph"/><view class="primary" bindtap="onSearch">{{searching?'正在查询…':'查询并提交'}}</view><view class="manual-link" bindtap="onManual"><text>网易云没有这张专辑？手动提交 →</text></view></view></block><block wx:else><view class="section"><text class="section-title">手动提交</text><text class="hint">适用于已下架、网易云无法检索或资料不完整的专辑</text><text class="label">专辑名 *</text><input class="input" value="{{title}}" data-field="title" bindinput="onInput"/><text class="label">歌手 *</text><input class="input" value="{{artist}}" data-field="artist" bindinput="onInput" placeholder="多人请用 / 分隔" placeholder-class="ph"/><text class="label">关联已收录艺人（可选）</text><input class="input" placeholder="搜索已收录 rapper" placeholder-class="ph" value="{{artistKeyword}}" bindinput="onArtistSearchInput"/><text wx:if="{{selectedArtists.length}}" class="picked-note">已选择 {{selectedArtists.length}} 位 rapper</text><text wx:elif="{{artistSearching}}" class="picked-note">搜索中…</text><view wx:if="{{selectedArtists.length}}" class="artist-results"><view wx:for="{{selectedArtists}}" wx:key="artistId" class="artist-row selected" bindtap="onRemoveArtist" data-id="{{item.artistId}}"><view class="artist-avatar"><image wx:if="{{item.picUrl}}" class="artist-img" src="{{item.picUrl}}" mode="aspectFill"/><text wx:else>{{item.letter || item.artistName[0]}}</text></view><view class="artist-copy"><text class="artist-name">{{item.artistName}}</text><text class="artist-meta">{{item.albumSize || 0}} 张专辑</text></view><text class="artist-check">移除</text></view></view><view wx:if="{{artistResults.length}}" class="artist-results"><view wx:for="{{artistResults}}" wx:key="artistId" class="artist-row {{item.selected ? 'selected' : ''}}" bindtap="onPickArtist" data-id="{{item.artistId}}"><view class="artist-avatar"><image wx:if="{{item.picUrl}}" class="artist-img" src="{{item.picUrl}}" mode="aspectFill"/><text wx:else>{{item.letter || item.artistName[0]}}</text></view><view class="artist-copy"><text class="artist-name">{{item.artistName}}</text><text class="artist-meta">{{item.albumSize || 0}} 张专辑</text></view><text class="artist-check">{{item.selected ? '已选' : '选择'}}</text></view></view><text class="label">发行日期</text><input class="input" value="{{releaseDate}}" data-field="releaseDate" bindinput="onInput" placeholder="YYYY-MM-DD" placeholder-class="ph"/><text class="label">发行公司</text><input class="input" value="{{company}}" data-field="company" bindinput="onInput"/><text class="label">曲目 *</text><textarea class="textarea" value="{{tracksText}}" data-field="tracksText" bindinput="onInput" placeholder="每行一首曲目" placeholder-class="ph"/><text class="label">专辑简介</text><textarea class="textarea desc" value="{{description}}" data-field="description" bindinput="onInput" placeholder="可选" placeholder-class="ph"/><text class="label">封面 *</text><view class="cover-box" bindtap="onChooseCover"><image wx:if="{{localCover||coverUrl}}" src="{{localCover||coverUrl}}" mode="aspectFill"/><text wx:else>＋ 上传封面</text></view><view class="primary" bindtap="onSubmitManual">{{submitting?'正在提交…':'提交管理员审核'}}</view></view></block></scroll-view></view>