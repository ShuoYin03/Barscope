<view class="page {{themeClass}}">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px"><text class="topbar-title">DISCOVER</text><text class="topbar-filter">⊞</text></view>
  <view class="search-wrap" style="position:relative;z-index:40">
    <view class="search-inner"><text class="search-icon">⌕</text><input class="search-input" placeholder="搜索专辑、歌手" placeholder-class="search-ph" bindfocus="onSearchFocus" bindblur="onSearchBlur" bindinput="onSearch" value="{{keyword}}" /></view>
    <view wx:if="{{suggestionVisible}}" class="suggestion-panel" style="position:absolute;left:32rpx;right:32rpx;top:calc(100% - 20rpx);z-index:60;max-height:620rpx;overflow-y:auto;background:#120d10;border:2rpx solid #30272c;box-shadow:0 18rpx 42rpx rgba(0,0,0,.58)">
      <view wx:if="{{suggestionLoading}}" class="suggestion-state" style="padding:30rpx 20rpx;text-align:center;font-size:23rpx;color:#766f68">正在搜索…</view>
      <block wx:elif="{{viewMode === 'albums'}}">
        <view wx:if="{{albumSuggestions.length === 0}}" class="suggestion-state" style="padding:30rpx 20rpx;text-align:center;font-size:23rpx;color:#766f68">没有匹配的专辑</view>
        <view wx:for="{{albumSuggestions}}" wx:key="id" class="suggestion-row" style="display:flex;align-items:center;gap:18rpx;min-height:96rpx;padding:14rpx 18rpx;border-bottom:2rpx solid #1b1519;box-sizing:border-box" catchtap="onSuggestionAlbumTap" data-id="{{item.id}}"><image wx:if="{{item.coverUrl}}" style="width:68rpx;height:68rpx;flex-shrink:0" src="{{item.coverUrl}}" mode="aspectFill" /><view wx:else style="width:68rpx;height:68rpx;background:#2D6FE0" /><view style="flex:1;min-width:0"><text class="suggestion-name">{{item.title}}</text><text class="suggestion-meta">{{item.artist}}</text><text class="suggestion-date">{{item.releaseDisplay}}</text></view><text class="suggestion-type">ALBUM</text></view>
      </block>
      <block wx:else>
        <view wx:if="{{artistSuggestions.length === 0}}" class="suggestion-state" style="padding:30rpx 20rpx;text-align:center;font-size:23rpx;color:#766f68">没有匹配的 rapper</view>
        <view wx:for="{{artistSuggestions}}" wx:key="artistId" class="suggestion-row" style="display:flex;align-items:center;gap:18rpx;min-height:96rpx;padding:14rpx 18rpx;border-bottom:2rpx solid #1b1519" catchtap="onSuggestionArtistTap" data-artist-id="{{item.artistId}}" data-artist="{{item.artistName}}"><view class="suggestion-avatar"><image wx:if="{{item.picUrl}}" class="suggestion-avatar-img" src="{{item.picUrl}}" mode="aspectFill" /><text wx:else>{{item.letter || item.artistName[0]}}</text></view><view style="flex:1;min-width:0"><text class="suggestion-name">{{item.artistName}}</text><text class="suggestion-meta">{{item.albumSize || 0}} 张专辑</text></view><text class="suggestion-type">RAPPER</text></view>
      </block>
    </view>
  </view>
  <view class="view-switch"><view class="switch-chip {{viewMode === 'albums' ? 'active' : ''}}" bindtap="onViewModeTap" data-mode="albums"><text>ALBUMS</text></view><view class="switch-chip {{viewMode === 'artists' ? 'active' : ''}}" bindtap="onViewModeTap" data-mode="artists"><text>ARTISTS</text></view></view>
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}" scroll-into-view="{{artistScrollIntoView}}" scroll-with-animation="{{true}}" bindscroll="onContentScroll" bindscrolltolower="onAlbumScrollToLower" lower-threshold="160">
    <block wx:if="{{viewMode === 'albums'}}">
      <view class="side-row"><text class="side-text">SIDE A — SUBMIT</text><view class="side-rule" /></view>
      <view class="artist-submit-row" bindtap="onSubmitAlbumRequest"><text class="artist-submit-icon">＋</text><view class="artist-submit-copy"><text class="artist-submit-title">提交专辑</text><text class="artist-submit-desc">未收录？提交审核</text></view><text class="artist-all-arrow">›</text></view>
      <view class="side-row"><text class="side-text">SIDE B — 年份 YEAR</text><view class="side-rule" /></view>
      <scroll-view class="timeline-scroll" scroll-x enhanced show-scrollbar="{{false}}" scroll-into-view="{{yearScrollIntoView}}" scroll-with-animation="{{true}}"><view class="timeline-track"><view class="timeline-line" /><view wx:for="{{years}}" wx:key="name" id="year-{{item.name}}" class="timeline-item {{activeYear === item.name ? 'active' : ''}}" bindtap="onYearTap" data-year="{{item.name}}"><view class="timeline-dot" /><text class="timeline-label">{{item.name}}</text></view></view></scroll-view>
      <view class="side-row"><text class="side-text">SIDE C — 类型 TYPE</text><view class="side-rule" /></view>
      <view class="role-filter-row"><view wx:for="{{releaseTypeFilters}}" wx:key="key" class="role-chip {{activeReleaseType === item.key ? 'active' : ''}}" bindtap="onReleaseTypeTap" data-type="{{item.key}}"><text>{{item.label}}</text></view></view>
      <view class="side-row"><text class="side-text">SIDE D — {{activeYear ? activeYear : '全部'}}{{activeMonth ? '.' + activeMonth : ''}} · {{loading ? '加载中' : total + ' 张'}}</text><view class="side-rule" /></view>
      <view wx:if="{{loading}}" class="empty-state"><text class="empty-text">加载中…</text></view>
      <view wx:elif="{{list.length === 0}}" class="empty-state"><text class="empty-text">没有找到相关专辑</text></view>
      <block wx:elif="{{activeYear === 'ALL'}}">
        <view wx:if="{{allRatedList.length > 0}}" class="album-list"><view class="artist-letter-row"><text class="artist-letter-title">SCORED</text><view class="artist-letter-rule" /></view><view wx:for="{{allRatedList}}" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{item.id}}"><view class="vinyl-cover-wrap"><view class="vinyl-disc-peek" /><image wx:if="{{item.coverUrl}}" class="cover-sq" src="{{item.coverUrl}}" mode="aspectFill" /></view><view class="album-info"><text class="album-title">{{item.title}}</text><text class="album-artist">{{item.artist}}</text><text class="album-date">{{item.releaseDisplay}}</text></view><text class="album-score" style="width:84rpx;min-width:84rpx;text-align:right;flex-shrink:0;">{{item.score}}</text></view></view>
        <view class="album-list with-alpha-index"><view class="artist-letter-row"><text class="artist-letter-title">UNRATED A-Z</text><view class="artist-letter-rule" /></view><view wx:for="{{allUnratedGroups}}" wx:key="letter" id="album-letter-{{item.letter === '#' ? 'num' : item.letter}}"><view class="artist-letter-row"><text class="artist-letter-title">{{item.letter}}</text><view class="artist-letter-rule" /></view><view wx:for="{{item.list}}" wx:for-item="album" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{album.id}}"><view class="vinyl-cover-wrap"><view class="vinyl-disc-peek" /><image wx:if="{{album.coverUrl}}" class="cover-sq" src="{{album.coverUrl}}" mode="aspectFill" /></view><view class="album-info"><text class="album-title">{{album.title}}</text><text class="album-artist">{{album.artist}}</text><text class="album-date">{{album.releaseDisplay}}</text></view><text class="album-score" style="width:84rpx;min-width:84rpx;text-align:right;flex-shrink:0;">{{album.score}}</text></view></view></view>
      </block>
      <block wx:else>
        <view wx:if="{{yearRatedList.length > 0}}" class="album-list"><view class="artist-letter-row"><text class="artist-letter-title">SCORED</text><view class="artist-letter-rule" /></view><view wx:for="{{yearRatedList}}" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{item.id}}"><view class="vinyl-cover-wrap"><view class="vinyl-disc-peek" /><image wx:if="{{item.coverUrl}}" class="cover-sq" src="{{item.coverUrl}}" mode="aspectFill" /></view><view class="album-info"><text class="album-title">{{item.title}}</text><text class="album-artist">{{item.artist}}</text><text class="album-date">{{item.releaseDisplay}}</text></view><text class="album-score" style="width:84rpx;min-width:84rpx;text-align:right;flex-shrink:0;">{{item.score}}</text></view></view>
        <view wx:if="{{yearUnratedList.length > 0}}" class="album-list with-month-index"><view class="artist-letter-row"><text class="artist-letter-title">UNRATED · RELEASE DATE</text><view class="artist-letter-rule" /></view><view wx:for="{{yearUnratedList}}" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{item.id}}"><view class="vinyl-cover-wrap"><view class="vinyl-disc-peek" /><image wx:if="{{item.coverUrl}}" class="cover-sq" src="{{item.coverUrl}}" mode="aspectFill" /></view><view class="album-info"><text class="album-title">{{item.title}}</text><text class="album-artist">{{item.artist}}</text><text class="album-date">{{item.releaseDisplay}}</text></view><text class="album-score" style="width:84rpx;min-width:84rpx;text-align:right;flex-shrink:0;">{{item.score}}</text></view></view>
      </block>
      <view wx:if="{{loadingMore}}" class="load-more">加载更多专辑…</view><view wx:elif="{{!albumHasMore}}" class="load-more">已显示全部 {{total}} 张专辑</view>
    </block>
    <block wx:else>
      <view class="side-row"><text class="side-text">SIDE A — LABEL 厂牌</text><view class="side-rule" /></view>
      <view class="brand-stamp brand-stamp-all {{activeBrand === '全部' ? 'active' : ''}}" bindtap="onBrandTap" data-brand="全部"><text class="brand-name">全部</text><text class="brand-count">{{artistList.length}}</text></view>
      <scroll-view class="timeline-scroll" scroll-x enhanced show-scrollbar="{{false}}"><view class="timeline-track"><view class="timeline-line" /><view wx:for="{{brandLetters}}" wx:key="*this" class="timeline-item {{activeBrandLetter === item ? 'active' : ''}}" bindtap="onBrandLetterAxisTap" data-letter="{{item}}"><view class="timeline-dot" /><text class="timeline-label">{{item}}</text></view></view></scroll-view>
      <scroll-view wx:if="{{activeBrandLetter}}" scroll-x show-scrollbar="{{false}}" class="brand-scroll">
        <view class="brand-stamps-horizontal">
          <view wx:for="{{currentLetterBrands}}" wx:key="name" class="brand-stamp {{activeBrand === item.name ? 'active' : ''}}" bindtap="onBrandTap" data-brand="{{item.name}}"><text class="brand-name">{{item.name}}</text><text class="brand-count">{{item.count}}</text></view>
        </view>
      </scroll-view>
      <view class="side-row"><text class="side-text">SIDE B — SUBMIT</text><view class="side-rule" /></view>
      <view class="artist-submit-row" bindtap="onSubmitArtistRequest"><text class="artist-submit-icon">＋</text><view class="artist-submit-copy"><text class="artist-submit-title">提交 rapper</text><text class="artist-submit-desc">未收录？提交审核</text></view><text class="artist-all-arrow">›</text></view>
      <view class="artist-submit-row" bindtap="onOpenBrandSubmit"><text class="artist-submit-icon">＋</text><view class="artist-submit-copy"><text class="artist-submit-title">提交厂牌</text><text class="artist-submit-desc">输入厂牌名称，选择所属 rapper，提交审核</text></view><text class="artist-all-arrow">›</text></view>
      <view class="side-row"><text class="side-text">SIDE C — ROLE 身份</text><view class="side-rule" /></view>
      <view class="role-filter-row"><view wx:for="{{roleFilters}}" wx:key="key" class="role-chip {{activeRole === item.key ? 'active' : ''}}" bindtap="onRoleTap" data-role="{{item.key}}"><text>{{item.label}}</text></view></view>
      <view class="side-row artist-result-title"><text class="side-text">SIDE D — {{activeBrand}} · {{artistLoading ? '加载中' : artistTotal + ' 位'}}</text><view class="side-rule" /></view>
      <view wx:if="{{activeBrand !== '全部'}}" class="artist-submit-row" bindtap="onOpenAddToBrand"><text class="artist-submit-icon">＋</text><view class="artist-submit-copy"><text class="artist-submit-title">添加 rapper 到 {{activeBrand}}</text><text class="artist-submit-desc">选择要加入这个厂牌的 rapper，提交审核</text></view><text class="artist-all-arrow">›</text></view>
      <view wx:if="{{artistLoading}}" class="empty-state"><text class="empty-text">加载中…</text></view><view wx:elif="{{artistVisibleList.length === 0}}" class="empty-state"><text class="empty-text">这个分类暂无艺人</text></view>
      <view wx:elif="{{activeBrand === '全部'}}" class="artist-all-list with-alpha-index"><view wx:for="{{artistLetterGroups}}" wx:key="letter" id="artist-letter-{{item.letter === '#' ? 'num' : item.letter}}"><view class="artist-letter-row"><text class="artist-letter-title">{{item.letter}}</text><view class="artist-letter-rule" /></view><view wx:for="{{item.list}}" wx:for-item="artist" wx:key="artistId" class="artist-all-row" bindtap="onArtistTap" data-artist-id="{{artist.artistId}}" data-artist="{{artist.artistName}}"><view class="artist-all-avatar"><image wx:if="{{artist.picUrl}}" class="artist-all-img" src="{{artist.picUrl}}" mode="aspectFill" /><text wx:else class="artist-all-initial">{{artist.letter}}</text></view><view class="artist-all-info"><text class="artist-all-name">{{artist.artistName}}</text><text class="artist-all-meta">{{artist.albumSize || 0}} 张专辑</text></view><text class="artist-all-arrow">›</text></view></view></view>
      <view wx:else class="artist-grid"><view wx:for="{{artistVisibleList}}" wx:key="artistId" class="artist-tile" bindtap="onArtistTap" data-artist-id="{{item.artistId}}" data-artist="{{item.artistName}}"><view class="artist-tile-avatar"><image wx:if="{{item.picUrl}}" class="artist-tile-img" src="{{item.picUrl}}" mode="aspectFill" /><text wx:else class="artist-tile-initial">{{item.letter}}</text></view><text class="artist-tile-name">{{item.artistName}}</text><text class="artist-tile-meta">{{item.albumSize || 0}} 张专辑</text></view></view>
    </block>
  </scroll-view>
  <view wx:if="{{viewMode === 'albums' && activeYear && activeYear !== 'ALL' && activeYear !== '2010s' && activeYear !== '2000s'}}" class="month-index transient" style="opacity:{{monthIndexVisible ? 0.82 : 0}};pointer-events:{{monthIndexVisible ? 'auto' : 'none'}};transition:opacity .22s ease;right:8rpx;background:rgba(6,4,7,.22);box-shadow:none;border-color:rgba(255,255,255,.025);"><view wx:for="{{months}}" wx:key="*this" class="month-index-item {{activeMonth === item ? 'active' : ''}}" bindtap="onMonthTap" data-month="{{item}}"><text>{{item}}</text></view></view>
  <view wx:if="{{viewMode === 'albums' && activeYear === 'ALL' && allAlbumLetters.length > 1}}" class="alphabet-index" data-kind="album" catchtouchstart="onIndexTouchStart" catchtouchmove="onIndexTouchMove" catchtouchend="onIndexTouchEnd" catchtouchcancel="onIndexTouchEnd"><view wx:for="{{allAlbumLetters}}" wx:key="*this" class="alphabet-index-item {{(activeAlbumLetter === item || indexHover === item) ? 'active' : ''}}"><text>{{item}}</text></view></view>
  <view wx:if="{{viewMode === 'artists' && activeBrand === '全部' && artistLetters.length > 1}}" class="alphabet-index" data-kind="artist" catchtouchstart="onIndexTouchStart" catchtouchmove="onIndexTouchMove" catchtouchend="onIndexTouchEnd" catchtouchcancel="onIndexTouchEnd"><view wx:for="{{artistLetters}}" wx:key="*this" class="alphabet-index-item {{(activeLetter === item || indexHover === item) ? 'active' : ''}}"><text>{{item}}</text></view></view>
  <view wx:if="{{indexBubble}}" class="index-bubble"><text>{{indexBubble}}</text></view>
  <view wx:if="{{brandSubmitVisible}}" class="brand-submit-mask" bindtap="onCloseBrandSubmit">
    <view class="brand-submit-sheet" catchtap="noop">
      <view class="brand-submit-handle" />
      <text class="brand-submit-title">{{brandSubmitLocked ? '添加 rapper 到 ' + brandSubmitName : '提交厂牌'}}</text>
      <text class="brand-submit-sub">所有用户都可以提交，管理员审核通过后才会正式生效</text>
      <input class="brand-submit-input {{brandSubmitLocked ? 'locked' : ''}}" value="{{brandSubmitName}}" disabled="{{brandSubmitLocked}}" bindinput="onBrandSubmitNameInput" maxlength="40" placeholder="输入厂牌名称，例如：1SHOT" placeholder-style="color:#6f6762" />

      <view wx:if="{{brandSubmitSelected.length}}" class="brand-submit-chips">
        <view wx:for="{{brandSubmitSelected}}" wx:key="artistId" class="brand-submit-chip" bindtap="onRemoveBrandSubmitArtist" data-id="{{item.artistId}}">
          <text>{{item.artistName}}</text><text class="brand-submit-chip-x">×</text>
        </view>
      </view>
      <text wx:else class="brand-submit-hint">请选择一位或多位所属 rapper</text>

      <input class="brand-submit-input" value="{{brandSubmitKeyword}}" bindinput="onBrandSubmitSearch" placeholder="搜索 rapper…" placeholder-style="color:#6f6762" />

      <scroll-view class="brand-submit-results" scroll-y>
        <view wx:for="{{brandSubmitResults}}" wx:key="artistId" class="brand-submit-row {{item.selected ? 'selected' : ''}}" bindtap="onToggleBrandSubmitArtist" data-id="{{item.artistId}}">
          <view class="brand-submit-avatar"><image wx:if="{{item.picUrl}}" class="brand-submit-avatar-img" src="{{item.picUrl}}" mode="aspectFill" /><text wx:else>{{item.artistName[0]}}</text></view>
          <text class="brand-submit-name">{{item.artistName}}</text>
          <text class="brand-submit-check">{{item.selected ? '已选' : '选择'}}</text>
        </view>
      </scroll-view>

      <view class="brand-submit-actions">
        <view class="brand-submit-cancel" bindtap="onCloseBrandSubmit"><text>取消</text></view>
        <view class="brand-submit-confirm {{brandSubmitting ? 'btn-disabled' : ''}}" bindtap="onSubmitBrand"><text>{{brandSubmitting ? '提交中…' : '提交审核'}}</text></view>
      </view>
    </view>
  </view>

  <bottom-nav selected="{{2}}" />
</view>