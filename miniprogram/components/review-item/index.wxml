<block>
  <view wx:if="{{!hidden}}" class="review-item {{review.userType === 'critic' ? 'is-critic' : ''}}" bindtap="onTap">
    <view class="review-header">
      <view class="review-user-tap" catchtap="onAvatarTap">
        <view class="review-avatar {{review.userType === 'critic' ? 'is-critic' : ''}}"><image wx:if="{{review.userAvatarUrl}}" class="review-avatar-img" src="{{review.userAvatarUrl}}" mode="aspectFill" /><text wx:else>{{review.initial}}</text></view>
        <view class="review-meta"><view class="name-row"><text class="review-user">{{review.userName}}</text><text wx:if="{{review.userType === 'critic'}}" class="critic-badge">乐评人</text></view><text class="review-time">{{review.timeAgo}}</text></view>
      </view>
      <text wx:if="{{showAlbum}}" class="album-badge">{{review.albumTitle}}</text><text class="review-score">{{review.score}}</text>
    </view>
    <text class="review-text {{expanded ? '' : 'clamped'}}" catchtap="onToggleExpand">{{review.content}}</text>
    <view wx:if="{{hasLongContent}}" class="review-expand-toggle" catchtap="onToggleExpand">
      <text>{{expanded ? '收起' : '展开全部'}}</text><text class="review-expand-arrow">{{expanded ? '↑' : '↓'}}</text>
    </view>
    <view class="review-footer">
      <view class="like-btn {{(localLiked || review.likedByMe) ? 'liked' : ''}}" catchtap="onLike"><text>{{(localLiked || review.likedByMe) ? '♥' : '♡'}} {{review.likes}}</text></view>
      <text class="sep"> | </text>
      <view class="reply-btn" catchtap="onReply"><text>↩ {{review.replyCount}}条 · 回复</text></view>
      <text class="sep"> | </text>
      <view class="reply-btn" catchtap="onManage"><text>··· 操作</text></view>
    </view>
  </view>

  <view wx:if="{{reportSheetVisible}}" class="report-sheet-mask" catchtap="onReportCancel">
    <view class="report-sheet" catchtap="noop">
      <view class="report-sheet-handle" />
      <text class="report-sheet-title">举报评论</text>
      <textarea class="report-sheet-textarea" placeholder="请填写举报原因，例如：辱骂、广告、歧视内容" placeholder-style="color:#6f6762" value="{{reportReason}}" bindinput="onReportReasonInput" maxlength="200" />
      <view class="report-sheet-actions">
        <view class="report-sheet-cancel" catchtap="onReportCancel"><text>取消</text></view>
        <view class="report-sheet-submit {{reportSubmitting ? 'btn-disabled' : ''}}" catchtap="onReportSubmit"><text>{{reportSubmitting ? '提交中…' : '提交'}}</text></view>
      </view>
    </view>
  </view>
</block>