<view class="page {{themeClass}}">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <text class="back" bindtap="onBack">←</text>
    <text class="brand">FEATURES</text>
  </view>

  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="article-head">
      <text class="category">榜单 · PLAYLIST POLL</text>
      <text class="title">2026 上半年中文说唱 Top50 单曲</text>
      <text class="intro">提交你的网易云歌单即可参与。乐评人歌单与社区投稿分别展示，并汇总所有有效歌单生成最终 Top50。</text>
    </view>

    <view class="rule" />

    <view class="submit-block">
      <text class="section-kicker">SUBMIT YOUR PLAYLIST</text>
      <text class="section-title">只需要一个网易云歌单链接</text>
      <input class="playlist-input" value="{{playlistUrl}}" bindinput="onUrlInput" placeholder="https://music.163.com/#/playlist?id=..." placeholder-style="color:#6f6762" />
      <view class="own-playlist-row" bindtap="onToggleOwnPlaylist">
        <view class="own-playlist-check {{isOwnPlaylist ? 'checked' : ''}}"><text wx:if="{{isOwnPlaylist}}">✓</text></view>
        <text class="own-playlist-label">这是我自己在网易云上的歌单，关联到我的主页</text>
      </view>
      <view class="submit {{submitting ? 'disabled' : ''}}" bindtap="onSubmitPlaylist"><text>{{submitting ? '正在读取歌单…' : '提交歌单 →'}}</text></view>
    </view>

    <view class="playlist-tabs">
      <view class="playlist-tab {{activePlaylistTab === 'critics' ? 'active' : ''}}" bindtap="onPlaylistTabTap" data-tab="critics"><text>乐评人</text><text class="tab-count">{{criticCount}}</text></view>
      <view class="playlist-tab {{activePlaylistTab === 'community' ? 'active' : ''}}" bindtap="onPlaylistTabTap" data-tab="community"><text>社区</text><text class="tab-count">{{communityCount}}</text></view>
    </view>

    <view class="section tab-section" wx:if="{{activePlaylistTab === 'critics'}}">
      <view class="section-head"><view><text class="section-kicker">FEATURED CRITICS</text><text class="section-title">乐评人歌单</text></view><text class="section-count">{{criticCount}} 份</text></view>
      <view wx:if="{{loading && criticList.length === 0}}" class="empty"><text>加载中…</text></view>
      <view wx:elif="{{criticList.length === 0}}" class="empty"><text>暂未收录乐评人歌单</text></view>
      <view wx:for="{{criticList}}" wx:for-item="playlist" wx:key="_id" class="playlist-card featured" bindtap="onPlaylistTap" data-id="{{playlist._id}}">
        <image class="playlist-cover" src="{{playlist.playlistCoverUrl}}" mode="aspectFill" />
        <view class="playlist-body"><view class="playlist-meta-line"><text class="featured-badge">CRITIC</text><text class="playlist-count">{{playlist.trackCount}} TRACKS</text></view><text class="playlist-creator">{{playlist.creatorName}}</text><text class="playlist-title">{{playlist.playlistTitle}}</text></view>
        <text class="playlist-toggle">›</text>
      </view>
    </view>

    <view class="section tab-section" wx:else>
      <view class="section-head"><view><text class="section-kicker">COMMUNITY PLAYLISTS</text><text class="section-title">社区投稿</text></view><text class="section-count">{{communityCount}} 份</text></view>
      <view wx:if="{{loading && communityList.length === 0}}" class="empty"><text>加载中…</text></view>
      <view wx:elif="{{communityList.length === 0}}" class="empty"><text>还没有社区投稿，来提交第一份歌单吧</text></view>
      <view wx:for="{{communityList}}" wx:for-item="playlist" wx:key="_id" class="playlist-card" bindtap="onPlaylistTap" data-id="{{playlist._id}}">
        <image class="playlist-cover" src="{{playlist.playlistCoverUrl}}" mode="aspectFill" />
        <view class="playlist-body"><text class="playlist-count">{{playlist.trackCount}} TRACKS</text><text class="playlist-creator">{{playlist.creatorName}}</text><text class="playlist-title">{{playlist.playlistTitle}}</text></view>
        <text class="playlist-toggle">›</text>
      </view>
    </view>

    <view class="end-mark"><text>— 2026 H1 TOP 50 —</text></view>
  </scroll-view>
</view>