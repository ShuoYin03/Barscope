<view class="page {{themeClass}}"><view class="topbar" style="height:{{topbarHeight}}px;padding-top:{{statusBarHeight}}px"><text class="back" bindtap="onBack">←</text><text class="title">TRACK CORRECTIONS</text></view><scroll-view class="content" scroll-y><view wx:if="{{loading}}" class="empty">加载中…</view><view wx:elif="{{!list.length}}" class="empty">暂无待审核曲目纠错</view><view wx:for="{{list}}" wx:key="_id" class="card"><text class="album">{{item.albumTitle}}</text><text class="meta">{{item.submitterName || '匿名用户'}} · {{item.tracks.length}} TRACKS</text><view wx:for="{{item.tracks}}" wx:for-item="track" wx:key="songId" class="track"><text class="no">{{track.no}}</text><view class="track-copy"><text class="name">{{track.name}}</text><text class="feat" wx:if="{{track.guests.length}}">Feat. {{track.guests[0].name}}{{track.guests.length>1?' 等':''}}</text></view></view><view class="actions"><view class="reject" data-id="{{item._id}}" bindtap="reject">驳回</view><view class="approve" data-id="{{item._id}}" bindtap="approve">通过并更新</view></view></view></scroll-view></view>
