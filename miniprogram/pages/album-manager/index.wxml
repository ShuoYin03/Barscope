<view class="page {{themeClass}}">

  <!-- TOPBAR -->
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <view class="topbar-back" bindtap="onBack">
      <text class="back-arrow">←</text>
    </view>
    <view class="topbar-titles">
      <text class="topbar-title">{{view === 'albums' ? selectedArtist.artistName : 'ALBUMS'}}</text>
      <text class="topbar-sub">{{view === 'albums' ? 'DISCOGRAPHY' : 'MGMT'}}</text>
    </view>
  </view>

  <!-- ══ ARTIST LIST / TITLE SEARCH ═══════════════════════════════════════════ -->
  <block wx:if="{{view === 'artists'}}">
    <view class="mode-tabs">
      <view class="mode-tab {{searchMode === 'artist' ? 'active' : ''}}" bindtap="onSearchModeTap" data-mode="artist"><text>按艺人</text></view>
      <view class="mode-tab {{searchMode === 'title' ? 'active' : ''}}" bindtap="onSearchModeTap" data-mode="title"><text>按专辑名</text></view>
      <view class="mode-tab {{searchMode === 'all' ? 'active' : ''}}" bindtap="onSearchModeTap" data-mode="all"><text>全部</text></view>
    </view>

    <view class="search-bar" wx:if="{{searchMode !== 'all'}}">
      <view class="search-input-wrap">
        <text class="search-icon">⌕</text>
        <input
          wx:if="{{searchMode === 'artist'}}"
          class="search-input"
          placeholder="搜索已批准艺人…"
          value="{{artistKeyword}}"
          bindinput="onArtistSearch"
          placeholder-style="color:#666"
        />
        <input
          wx:else
          class="search-input"
          placeholder="搜索专辑名称…"
          value="{{titleKeyword}}"
          bindinput="onTitleSearch"
          placeholder-style="color:#666"
        />
      </view>
    </view>

    <scroll-view
      wx:if="{{searchMode === 'artist'}}"
      class="content"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      bindscrolltolower="onReachBottom"
    >
      <view class="cleanup-panel">
        <view class="cleanup-head">
          <view>
            <text class="cleanup-title">重复专辑清理</text>
            <text class="cleanup-desc">按网易云 sourceId 识别重复，保留评论更多/已显示的版本</text>
          </view>
          <view
            class="cleanup-btn {{cleanupLoading ? 'btn-disabled' : ''}}"
            bindtap="onPreviewDuplicates"
          >
            <text class="cleanup-btn-text">{{cleanupLoading ? '扫描中' : '扫描'}}</text>
          </view>
        </view>

        <view wx:if="{{cleanupPreview}}" class="cleanup-result-card">
          <view class="cleanup-stats">
            <view class="cleanup-stat">
              <text class="cleanup-stat-num">{{cleanupPreview.scanned}}</text>
              <text class="cleanup-stat-label">已扫描</text>
            </view>
            <view class="cleanup-stat">
              <text class="cleanup-stat-num">{{cleanupPreview.duplicateGroups}}</text>
              <text class="cleanup-stat-label">重复组</text>
            </view>
            <view class="cleanup-stat danger">
              <text class="cleanup-stat-num">{{cleanupPreview.wouldRemove}}</text>
              <text class="cleanup-stat-label">待删除</text>
            </view>
          </view>

          <block wx:if="{{cleanupPreview.samples.length > 0}}">
            <view wx:for="{{cleanupPreview.samples}}" wx:key="key" class="dup-sample">
              <text class="dup-title">{{item.keep.title}}</text>
              <text class="dup-keep">保留：{{item.keep.artist}} · {{item.keep.reviewCount}} 评</text>
              <text class="dup-remove">删除 {{item.remove.length}} 张重复记录</text>
            </view>
          </block>

          <view
            wx:if="{{cleanupPreview.wouldRemove > 0}}"
            class="cleanup-confirm-btn {{cleanupLoading ? 'btn-disabled' : ''}}"
            bindtap="onRunDuplicateCleanup"
          >
            <text class="cleanup-confirm-text">确认清理 {{cleanupPreview.wouldRemove}} 张</text>
          </view>
        </view>

        <view wx:if="{{cleanupResult}}" class="cleanup-result-card">
          <text class="cleanup-title">清理完成</text>
          <text class="cleanup-desc">已删除 {{cleanupResult.removed}} 张，迁移 {{cleanupResult.reviewsMoved}} 条评论 / {{cleanupResult.favoritesMoved}} 条收藏</text>
        </view>
      </view>

      <block wx:if="{{artistLoading && artistList.length === 0}}">
        <view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="card-skeleton">
          <view class="sk skel-pic"></view>
          <view class="skel-body">
            <view class="sk skel-name"></view>
            <view class="sk skel-meta"></view>
          </view>
        </view>
      </block>

      <view wx:elif="{{artistList.length === 0}}" class="empty-state">
        <text class="empty-icon">○</text>
        <text class="empty-text">{{artistKeyword ? '没有匹配的艺人' : '暂无已批准艺人'}}</text>
      </view>

      <block wx:else>
        <view
          wx:for="{{artistList}}"
          wx:key="_id"
          class="artist-row"
          bindtap="onArtistTap"
          data-artist="{{item}}"
        >
          <view class="artist-photo">
            <image wx:if="{{item.picUrl}}" class="photo-img" src="{{item.picUrl}}" mode="aspectFill" />
            <view wx:else class="photo-fallback">
              <text class="photo-initial">{{item.artistName[0]}}</text>
            </view>
          </view>
          <view class="artist-info">
            <text class="artist-name">{{item.artistName}}</text>
            <text class="artist-meta">{{item.albumSize}} 张专辑</text>
          </view>
          <text class="row-arrow">→</text>
        </view>

        <view wx:if="{{artistLoading}}" class="load-more">
          <text class="load-more-text">加载中…</text>
        </view>
        <view wx:elif="{{!artistHasMore && artistList.length > 0}}" class="list-end">
          <text class="list-end-text">── 已全部加载 ──</text>
        </view>
      </block>
    </scroll-view>

    <scroll-view wx:elif="{{searchMode === 'title'}}" class="content" scroll-y enhanced show-scrollbar="{{false}}">
      <block wx:if="{{titleLoading && titleResults.length === 0}}">
        <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="album-skeleton">
          <view class="sk skel-cover"></view>
          <view class="skel-body">
            <view class="sk skel-name"></view>
            <view class="sk skel-meta"></view>
          </view>
        </view>
      </block>

      <view wx:elif="{{titleResults.length === 0}}" class="empty-state">
        <text class="empty-icon">○</text>
        <text class="empty-text">{{titleKeyword ? '没有匹配的专辑' : '输入专辑名称开始搜索'}}</text>
      </view>

      <block wx:else>
        <view wx:for="{{titleResults}}" wx:key="_id" class="album-row">
          <view class="album-cover-wrap">
            <image wx:if="{{item.coverUrl}}" class="album-cover" src="{{item.coverUrl}}" mode="aspectFill" />
            <view wx:else class="album-cover-fallback">
              <text class="album-cover-icon">♪</text>
            </view>
            <view wx:if="{{!item.approved}}" class="cover-hidden-badge">
              <text class="cover-hidden-text">隐藏</text>
            </view>
          </view>

          <view class="album-info">
            <text class="album-title">{{item.title}}</text>
            <text class="album-artist">{{item.artist}}</text>
            <view class="album-meta-row">
              <text class="album-meta">{{item.releaseYear}}</text>
              <view wx:if="{{item.trackCount > 0}}" class="meta-dot"></view>
              <text wx:if="{{item.trackCount > 0}}" class="album-meta">{{item.trackCount}} 首</text>
              <view wx:if="{{item.reviewCount > 0}}" class="meta-dot"></view>
              <text wx:if="{{item.reviewCount > 0}}" class="album-meta">{{item.reviewCount}} 评</text>
            </view>
          </view>

          <view
            class="toggle-btn {{item.approved ? 'toggle-on' : 'toggle-off'}} {{toggling[item._id] ? 'btn-disabled' : ''}}"
            bindtap="onToggleApproved"
            data-id="{{item._id}}"
            data-approved="{{item.approved}}"
          >
            <text class="toggle-text">{{item.approved ? '显示' : '隐藏'}}</text>
          </view>
        </view>

        <view class="list-end">
          <text class="list-end-text">── 共 {{titleResults.length}} 张 ──</text>
        </view>
      </block>
    </scroll-view>

    <!-- ── 全部专辑（按字母表浏览 + 批量操作） ── -->
    <block wx:else>
      <view class="letter-tabs-wrap">
        <scroll-view class="letter-tabs" scroll-x enhanced show-scrollbar="{{false}}">
          <view
            wx:for="{{allLetters}}"
            wx:key="letter"
            class="letter-tab {{allActiveLetter === item.letter ? 'active' : ''}}"
            bindtap="onAllLetterTap"
            data-letter="{{item.letter}}"
          >
            <text>{{item.letter}}</text>
            <text wx:if="{{item.count}}" class="letter-tab-count">{{item.count}}</text>
          </view>
        </scroll-view>
      </view>

      <view class="all-action-bar">
        <view class="all-action-btn" bindtap="onToggleAllSelectMode">
          <text>{{allSelectMode ? '取消批量' : '批量选择'}}</text>
        </view>
        <block wx:if="{{allSelectMode}}">
          <view class="all-action-btn" bindtap="onAllSelectAll"><text>{{allSelectedCount ? '取消全选' : '全选'}}</text></view>
          <view class="all-action-btn accent {{allBatchWorking ? 'btn-disabled' : ''}}" bindtap="onAllBatchShow"><text>批量显示</text></view>
          <view class="all-action-btn danger {{allBatchWorking ? 'btn-disabled' : ''}}" bindtap="onAllBatchHide"><text>批量隐藏</text></view>
        </block>
        <view wx:else class="all-action-btn ghost {{backfilling ? 'btn-disabled' : ''}}" bindtap="onBackfillLetters">
          <text>{{backfilling ? ('索引中 ' + backfillDone) : '补全字母索引'}}</text>
        </view>
      </view>

      <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="onAllReachBottom">
        <block wx:if="{{allLoading && allList.length === 0}}">
          <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="album-skeleton">
            <view class="sk skel-cover"></view>
            <view class="skel-body">
              <view class="sk skel-name"></view>
              <view class="sk skel-meta"></view>
            </view>
          </view>
        </block>

        <view wx:elif="{{allList.length === 0}}" class="empty-state">
          <text class="empty-icon">○</text>
          <text class="empty-text">该字母下暂无专辑</text>
        </view>

        <block wx:else>
          <view
            wx:for="{{allList}}"
            wx:key="_id"
            class="album-row {{allSelectMode ? 'selectable' : ''}} {{item.selected ? 'selected' : ''}}"
            bindtap="onAllCardTap"
            data-id="{{item._id}}"
          >
            <view wx:if="{{allSelectMode}}" class="select-box {{item.selected ? 'checked' : ''}}"><text wx:if="{{item.selected}}">✓</text></view>
            <view class="album-cover-wrap">
              <image wx:if="{{item.coverUrl}}" class="album-cover" src="{{item.coverUrl}}" mode="aspectFill" />
              <view wx:else class="album-cover-fallback">
                <text class="album-cover-icon">♪</text>
              </view>
              <view wx:if="{{!item.approved}}" class="cover-hidden-badge">
                <text class="cover-hidden-text">隐藏</text>
              </view>
            </view>

            <view class="album-info">
              <text class="album-title">{{item.title}}</text>
              <text class="album-artist">{{item.artist}}</text>
              <view class="album-meta-row">
                <text class="album-meta">{{item.releaseYear}}</text>
                <view wx:if="{{item.trackCount > 0}}" class="meta-dot"></view>
                <text wx:if="{{item.trackCount > 0}}" class="album-meta">{{item.trackCount}} 首</text>
                <view wx:if="{{item.reviewCount > 0}}" class="meta-dot"></view>
                <text wx:if="{{item.reviewCount > 0}}" class="album-meta">{{item.reviewCount}} 评</text>
              </view>
            </view>

            <view
              wx:if="{{!allSelectMode}}"
              class="toggle-btn {{item.approved ? 'toggle-on' : 'toggle-off'}} {{toggling[item._id] ? 'btn-disabled' : ''}}"
              catchtap="onToggleApproved"
              data-id="{{item._id}}"
              data-approved="{{item.approved}}"
            >
              <text class="toggle-text">{{item.approved ? '显示' : '隐藏'}}</text>
            </view>
          </view>

          <view wx:if="{{allLoading}}" class="load-more">
            <text class="load-more-text">加载中…</text>
          </view>
          <view wx:elif="{{!allHasMore && allList.length > 0}}" class="list-end">
            <text class="list-end-text">── 共 {{allTotal}} 张 ──</text>
          </view>
        </block>
      </scroll-view>
    </block>
  </block>

  <!-- ══ ALBUM LIST ══════════════════════════════════════════════════════════ -->
  <block wx:elif="{{view === 'albums'}}">
    <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">

      <block wx:if="{{albumLoading && albumList.length === 0}}">
        <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="album-skeleton">
          <view class="sk skel-cover"></view>
          <view class="skel-body">
            <view class="sk skel-name"></view>
            <view class="sk skel-meta"></view>
          </view>
        </view>
      </block>

      <view wx:elif="{{albumList.length === 0}}" class="empty-state">
        <text class="empty-icon">○</text>
        <text class="empty-text">该艺人暂无已收录专辑</text>
      </view>

      <block wx:else>
        <view wx:for="{{albumList}}" wx:key="_id" class="album-row">
          <view class="album-cover-wrap">
            <image wx:if="{{item.coverUrl}}" class="album-cover" src="{{item.coverUrl}}" mode="aspectFill" />
            <view wx:else class="album-cover-fallback">
              <text class="album-cover-icon">♪</text>
            </view>
            <!-- Approval overlay indicator -->
            <view wx:if="{{!item.approved}}" class="cover-hidden-badge">
              <text class="cover-hidden-text">隐藏</text>
            </view>
          </view>

          <view class="album-info">
            <text class="album-title">{{item.title}}</text>
            <text class="album-artist">{{item.artist}}</text>
            <view class="album-meta-row">
              <text class="album-meta">{{item.releaseYear}}</text>
              <view wx:if="{{item.trackCount > 0}}" class="meta-dot"></view>
              <text wx:if="{{item.trackCount > 0}}" class="album-meta">{{item.trackCount}} 首</text>
              <view wx:if="{{item.reviewCount > 0}}" class="meta-dot"></view>
              <text wx:if="{{item.reviewCount > 0}}" class="album-meta">{{item.reviewCount}} 评</text>
            </view>
          </view>

          <view
            class="toggle-btn {{item.approved ? 'toggle-on' : 'toggle-off'}} {{toggling[item._id] ? 'btn-disabled' : ''}}"
            bindtap="onToggleApproved"
            data-id="{{item._id}}"
            data-approved="{{item.approved}}"
          >
            <text class="toggle-text">{{item.approved ? '显示' : '隐藏'}}</text>
          </view>
        </view>

        <view class="list-end">
          <text class="list-end-text">── 共 {{albumList.length}} 张 ──</text>
        </view>
      </block>
    </scroll-view>
  </block>

</view>
