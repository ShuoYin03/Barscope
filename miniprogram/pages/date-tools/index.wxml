<view class="page {{themeClass}}"><view class="topbar" style="padding-top: {{statusBarHeight}}px"><text class="back" bindtap="onBack">←</text><text class="title">DATE TOOLS</text></view><view class="content"><text class="heading">发行日期回填</text><text class="desc">自动为缺少日期的专辑补充网易云发布日期。</text><view class="stats"><text>已扫描 {{processed}}</text><text>已写入 {{updated}}</text><text>失败 {{failed}}</text></view><text class="status">{{message}}</text><view class="run" bindtap="onRun"><text>{{running ? '处理中…' : done ? '再次检查' : '开始回填'}}</text></view></view></view>