.page{height:100vh;display:flex;flex-direction:column;background:var(--black);color:var(--white)}
.topbar{min-height:92rpx;display:flex;align-items:flex-end;gap:22rpx;padding:0 32rpx 20rpx;border-bottom:2rpx solid var(--accent);box-sizing:content-box;flex-shrink:0}
.back{font-size:42rpx;color:var(--accent);line-height:1}.topbar-copy{display:flex;flex-direction:column;gap:4rpx}.title{font-family:var(--font-bebas);font-size:38rpx;letter-spacing:4rpx;line-height:1}.subtitle{font-size:17rpx;color:var(--gray-mid);letter-spacing:3rpx}.state{flex:1;display:flex;align-items:center;justify-content:center;color:var(--gray-mid)}
.content{flex:1;min-height:0;padding:30rpx 32rpx;box-sizing:border-box}.section{margin-bottom:30rpx}.label{display:block;margin-bottom:12rpx;color:var(--accent);font-size:20rpx;font-weight:800;letter-spacing:2rpx}.input,.textarea{width:100%;box-sizing:border-box;background:#120d0b;border:1rpx solid #332620;color:var(--white);font-size:27rpx}.input{height:88rpx;line-height:88rpx;padding:0 22rpx}.textarea{height:240rpx;padding:20rpx 22rpx;line-height:1.55}
.role-grid{display:flex;gap:12rpx}.role-option{flex:1;height:72rpx;padding:0 16rpx;border:1rpx solid var(--gray-light);display:flex;align-items:center;justify-content:space-between;font-family:var(--font-bebas);font-size:23rpx;letter-spacing:2rpx;color:var(--gray-mid)}.role-option.selected{border-color:var(--accent);color:var(--accent);background:rgba(212,81,36,.08)}
.image-row{display:flex;align-items:center;gap:20rpx}.avatar-preview{width:120rpx;height:120rpx;border-radius:50%;overflow:hidden;background:#17110f;display:flex;align-items:center;justify-content:center;color:var(--gray-mid);font-size:36rpx;flex-shrink:0}.avatar-preview image{width:100%;height:100%}.image-action{height:88rpx;flex:1;padding:0 22rpx;border:1rpx solid #332620;background:#120d0b;display:flex;align-items:center;justify-content:space-between;font-size:25rpx}.image-action text:last-child{color:var(--accent);font-size:34rpx}
.hero-preview{height:250rpx;position:relative;overflow:hidden;background:#17110f;display:flex;align-items:center;justify-content:center}.hero-preview image,.hero-overlay{position:absolute;inset:0;width:100%;height:100%}.hero-overlay{background:rgba(0,0,0,.42)}.hero-preview text{position:relative;z-index:2;padding:14rpx 22rpx;border:1rpx solid rgba(255,255,255,.45);font-size:23rpx;font-weight:800}
.submit{height:84rpx;margin-top:8rpx;background:var(--accent);color:#000;display:flex;align-items:center;justify-content:center;font-size:27rpx;font-weight:900}.submit.disabled{opacity:.5}.note{display:block;margin-top:12rpx;text-align:center;color:var(--gray-mid);font-size:18rpx}.bottom-space{height:70rpx}