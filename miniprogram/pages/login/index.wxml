<view class="page {{themeClass}}">
  <view
    class="back-btn"
    style="top: {{capsuleTop}}px; height: {{capsuleHeight}}px"
    bindtap="onBack"
  >
    <text class="back-icon">‹</text>
    <text class="back-label">返回</text>
  </view>

  <scroll-view class="scroll-area" scroll-y enhanced show-scrollbar="{{false}}" style="padding-top: {{capsuleTop + capsuleHeight + 16}}px">
    <text wx:if="{{isUpdating}}" class="edit-title">编辑资料</text>
    <view wx:else class="logo-area">
      <view class="logo-vinyl-disc">
        <view class="logo-vinyl-label">
          <text class="logo-vinyl-text">韵</text>
        </view>
        <view class="logo-vinyl-spindle" />
      </view>
      <text class="logo-zh">BEATWEEN</text>
      <text class="logo-en">韵镜</text>
      <text class="tagline">授权头像和昵称，加入说唱评分社区</text>
    </view>

    <view class="cover-section">
      <view class="cover-frame" bindtap="onChooseCover">
        <image wx:if="{{coverUrl}}" class="cover-img" src="{{coverUrl}}" mode="aspectFill" />
        <view wx:else class="cover-img cover-ph"><text class="cover-plus">+ 设置封面图</text></view>
      </view>
      <text class="cover-hint">封面图 · 展示在你的个人主页顶部</text>
    </view>

    <view class="avatar-section">
      <view class="avatar-frame">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
          <view wx:else class="avatar-img avatar-ph"><text class="avatar-plus">+</text></view>
        </button>
      </view>
      <text class="avatar-hint">点击授权并裁剪头像</text>
    </view>

    <view class="nick-section">
      <text class="nick-label">昵称</text>
      <input
        type="nickname"
        class="nick-input"
        placeholder="点击使用微信昵称"
        placeholder-class="nick-ph"
        bindinput="onNickInput"
        value="{{nickName}}"
      />
    </view>

    <view class="nick-section">
      <text class="nick-label">个人简介</text>
      <textarea
        class="bio-input"
        placeholder="写点什么介绍一下自己（选填）"
        placeholder-class="nick-ph"
        bindinput="onBioInput"
        value="{{bio}}"
        maxlength="100"
        auto-height
      />
      <text class="bio-count">{{bio.length}}/100</text>
    </view>

    <view class="login-btn {{loading ? 'loading' : ''}}" bindtap="onLogin">
      <text>{{loading ? '处理中...' : (isUpdating ? '保存资料' : '授权并登录')}}</text>
    </view>

    <text class="hint">头像、封面与昵称仅用于韵镜个人主页和社区互动</text>
  </scroll-view>
</view>
