<view class="page {{themeClass}}">
  <view class="topbar" style="padding-top: {{statusBarHeight}}px"><text class="back" bindtap="onBack">←</text><text class="title">NOTIFICATIONS</text></view>
  <scroll-view class="content" scroll-y>
    <view wx:if="{{loading}}" class="empty">加载中…</view>
    <view wx:elif="{{loadError}}" class="empty"><text>{{loadError}}</text><view class="retry" bindtap="loadList">重新加载</view></view>
    <view wx:elif="{{list.length === 0}}" class="empty">暂无通知</view>
    <block wx:else>
      <view wx:for="{{list}}" wx:key="_id" class="card {{item.read ? '' : 'unread'}}" bindtap="onItemTap" data-album-id="{{item.albumId}}">
        <text class="icon">{{item.icon}}</text>
        <view class="info">
          <text class="message">{{item.message}}</text>
          <text class="time">{{item.timeAgo}}</text>
        </view>
        <view wx:if="{{!item.read}}" class="dot" />
      </view>
    </block>
  </scroll-view>
</view>
