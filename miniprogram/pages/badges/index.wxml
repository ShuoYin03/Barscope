<view class="page {{themeClass}}">
  <view class="topbar" style="padding-top: {{statusBarHeight}}px"><text class="back" bindtap="onBack">←</text><text class="title">BADGES</text></view>

  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="head">
      <text class="head-title">成就徽章</text>
      <text wx:if="{{hasEarnedCount}}" class="head-sub">已解锁 {{earnedCount}} / {{badges.length}}</text>
    </view>

    <view wx:for="{{badges}}" wx:key="id" class="badge-card {{item.earned ? 'earned' : 'locked'}}">
      <view class="badge-card-icon"><text>{{item.icon}}</text></view>
      <view class="badge-card-info">
        <view class="badge-card-head"><text class="badge-card-name">{{item.name}}</text><text wx:if="{{item.earned}}" class="badge-card-tag">已解锁</text></view>
        <text class="badge-card-desc">{{item.desc}}</text>
        <block wx:if="{{item.hasProgress}}">
          <view class="badge-progress-track"><view class="badge-progress-fill" style="width: {{item.pct}}%" /></view>
          <text class="badge-progress-text">{{item.current}} / {{item.target}}</text>
        </block>
        <text wx:else class="badge-progress-dev">进度统计功能仍在开发中</text>
      </view>
    </view>
  </scroll-view>
</view>
