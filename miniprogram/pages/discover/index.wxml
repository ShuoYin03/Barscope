<view class="page">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px"><text class="topbar-title">DISCOVER</text><text class="topbar-filter">⊞</text></view>
  <view class="search-wrap" style="position:relative;z-index:40">
    <view class="search-inner"><text class="search-icon">⌕</text><input class="search-input" placeholder="搜索专辑、歌手" placeholder-class="search-ph" bindfocus="onSearchFocus" bindblur="onSearchBlur" bindinput="onSearch" value="{{keyword}}" /></view>
    <view wx:if="{{suggestionVisible}}" class="suggestion-panel" style="position:absolute;left:32rpx;right:32rpx;top:calc(100% - 20rpx);z-index:60;max-height:620rpx;overflow-y:auto;background:#120d10;border:2rpx solid #30272c;box-shadow:0 18rpx 42rpx rgba(0,0,0,.58)">
      <view wx:if="{{suggestionLoading}}" class="suggestion-state" style="padding:30rpx 20rpx;text-align:center;font-size:23rpx;color:#766f68">正在搜索…</view>
      <block wx:elif="{{viewMode === 'albums'}}">
        <view wx:if="{{albumSuggestions.length === 0}}" class="suggestion-state" style="padding:30rpx 20rpx;text-align:center;font-size:23rpx;color:#766f68">没有匹配的专辑</view>
        <view wx:for="{{albumSuggestions}}" wx:key="id" class="suggestion-row" style="display:flex;align-items:center;gap:18rpx;min-height:96rpx;padding:14rpx 18rpx;border-bottom:2rpx solid #1b1519;box-sizing:border-box" catchtap="onSuggestionAlbumTap" data-id="{{item.id}}">
          <image wx:if="{{item.coverUrl}}" class="suggestion-cover" style="width:68rpx;height:68rpx;flex-shrink:0;background:#30272c" src="{{item.coverUrl}}" mode="aspectFill" /><view wx:else class="suggestion-cover suggestion-cover-ph" style="width:68rpx;height:68rpx;flex-shrink:0;background:#C94E25" />
          <view class="suggestion-copy" style="flex:1;min-width:0"><text class="suggestion-name" style="display:block;font-size:27rpx;font-weight:700;color:#F5F0E7;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{item.title}}</text><text class="suggestion-meta" style="display:block;margin-top:5rpx;font-size:20rpx;color:#766f68;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{item.artist}}</text><text class="suggestion-date">{{item.releaseDisplay}}</text></view>
          <text class="suggestion-type" style="flex-shrink:0;font-family:var(--font-bebas);font-size:19rpx;letter-spacing:2rpx;color:#C94E25">ALBUM</text>
        </view>
      </block>
      <block wx:else>
        <view wx:if="{{artistSuggestions.length === 0}}" class="suggestion-state" style="padding:30rpx 20rpx;text-align:center;font-size:23rpx;color:#766f68">没有匹配的 rapper</view>
        <view wx:for="{{artistSuggestions}}" wx:key="artistId" class="suggestion-row" style="display:flex;align-items:center;gap:18rpx;min-height:96rpx;padding:14rpx 18rpx;border-bottom:2rpx solid #1b1519;box-sizing:border-box" catchtap="onSuggestionArtistTap" data-artist-id="{{item.artistId}}" data-artist="{{item.artistName}}">
          <view class="suggestion-avatar" style="width:68rpx;height:68rpx;border-radius:50%;overflow:hidden;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:#C94E25;font-family:var(--font-bebas);font-size:30rpx;color:#080608"><image wx:if="{{item.picUrl}}" class="suggestion-avatar-img" style="width:100%;height:100%;display:block" src="{{item.picUrl}}" mode="aspectFill" /><text wx:else>{{item.letter || item.artistName[0]}}</text></view>
          <view class="suggestion-copy" style="flex:1;min-width:0"><text class="suggestion-name" style="display:block;font-size:27rpx;font-weight:700;color:#F5F0E7;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{item.artistName}}</text><text class="suggestion-meta" style="display:block;margin-top:5rpx;font-size:20rpx;color:#766f68;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{item.albumSize || 0}} 张专辑</text></view>
          <text class="suggestion-type" style="flex-shrink:0;font-family:var(--font-bebas);font-size:19rpx;letter-spacing:2rpx;color:#C94E25">RAPPER</text>
        </view>
      </block>
    </view>
  </view>
  <view class="view-switch"><view class="switch-chip {{viewMode === 'albums' ? 'active' : ''}}" bindtap="onViewModeTap" data-mode="albums"><text>ALBUMS</text></view><view class="switch-chip {{viewMode === 'artists' ? 'active' : ''}}" bindtap="onViewModeTap" data-mode="artists"><text>ARTISTS</text></view></view>
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}" scroll-into-view="{{artistScrollIntoView}}" scroll-with-animation="{{true}}" bindscrolltolower="onAlbumScrollToLower" lower-threshold="160">
    <block wx:if="{{viewMode === 'albums'}}">
      <view class="side-row"><text class="side-text">SIDE A — 年份 YEAR</text><view class="side-rule" /></view>
      <view class="year-stamps"><view wx:for="{{years}}" wx:key="name" class="year-stamp {{activeYear === item.name ? 'active' : ''}}" bindtap="onYearTap" data-year="{{item.name}}"><text class="year-name">{{item.name}}</text></view></view>
      <view class="side-row"><text class="side-text">SIDE B — {{activeYear ? activeYear : '全部'}}{{activeMonth ? '.' + activeMonth : ''}} · {{loading ? '加载中' : total + ' 张'}}</text><view class="side-rule" /></view>
      <view wx:if="{{loading}}" class="album-list"><view wx:for="{{[1,2,3,4,5,6,7,8]}}" wx:key="*this" class="skel-row"><view class="sk" style="width:160rpx;height:120rpx;flex-shrink:0;" /><view class="skel-info"><view class="sk" style="width:70%;height:26rpx;" /><view class="sk" style="width:55%;height:20rpx;" /><view class="sk" style="width:40%;height:18rpx;" /></view><view class="sk" style="width:40rpx;height:34rpx;flex-shrink:0;" /></view></view>
      <view wx:elif="{{list.length === 0}}" class="empty-state"><text class="empty-text">没有找到相关专辑</text></view>
      <block wx:elif="{{activeYear === 'ALL'}}">
        <view wx:if="{{allRatedList.length > 0}}" class="album-list all-album-list"><view class="artist-letter-row" id="album-rated"><text class="artist-letter-title">SCORED</text><view class="artist-letter-rule" /></view><view wx:for="{{allRatedList}}" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{item.id}}"><view class="vinyl-cover-wrap"><view class="vinyl-disc-peek" /><image wx:if="{{item.coverUrl}}" class="cover-sq" src="{{item.coverUrl}}" mode="aspectFill" /><view wx:else class="cover-sq cover-sq-ph" /></view><view class="album-info"><text class="album-title">{{item.title}}</text><text class="album-artist" catchtap="onArtistTap" data-artist-id="{{item.neteaseArtistId}}" data-artist="{{item.primaryArtist}}">{{item.artist}}</text><text class="album-date">{{item.releaseDisplay}}</text></view><text class="album-score">{{item.score}}</text></view></view>
        <view class="album-list all-album-list with-alpha-index"><view class="artist-letter-row"><text class="artist-letter-title">UNRATED A-Z</text><view class="artist-letter-rule" /></view><view wx:for="{{allUnratedGroups}}" wx:key="letter" class="artist-letter-group" id="album-letter-{{item.letter === '#' ? 'num' : item.letter}}"><view class="artist-letter-row"><text class="artist-letter-title">{{item.letter}}</text><view class="artist-letter-rule" /></view><view wx:for="{{item.list}}" wx:for-item="album" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{album.id}}"><view class="vinyl-cover-wrap"><view class="vinyl-disc-peek" /><image wx:if="{{album.coverUrl}}" class="cover-sq" src="{{album.coverUrl}}" mode="aspectFill" /><view wx:else class="cover-sq cover-sq-ph" /></view><view class="album-info"><text class="album-title">{{album.title}}</text><text class="album-artist" catchtap="onArtistTap" data-artist-id="{{album.neteaseArtistId}}" data-artist="{{album.primaryArtist}}">{{album.artist}}</text><text class="album-date">{{album.releaseDisplay}}</text></view><text class="album-score">{{album.score}}</text></view></view></view>
      </block>
      <block wx:else>
        <view wx:if="{{yearRatedList.length > 0}}" class="album-list"><view class="artist-letter-row"><text class="artist-letter-title">SCORED</text><view class="artist-letter-rule" /></view><view wx:for="{{yearRatedList}}" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{item.id}}"><view class="vinyl-cover-wrap"><view class="vinyl-disc-peek" /><image wx:if="{{item.coverUrl}}" class="cover-sq" src="{{item.coverUrl}}" mode="aspectFill" /><view wx:else class="cover-sq cover-sq-ph" /></view><view class="album-info"><text class="album-title">{{item.title}}</text><text class="album-artist" catchtap="onArtistTap" data-artist-id="{{item.neteaseArtistId}}" data-artist="{{item.primaryArtist}}">{{item.artist}}</text><text class="album-date">{{item.releaseDisplay}}</text></view><text class="album-score">{{item.score}}</text></view></view>
        <view wx:if="{{yearUnratedList.length > 0}}" class="album-list with-month-index"><view class="artist-letter-row"><text class="artist-letter-title">UNRATED · RELEASE DATE</text><view class="artist-letter-rule" /></view><view wx:for="{{yearUnratedList}}" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{item.id}}"><view class="vinyl-cover-wrap"><view class="vinyl-disc-peek" /><image wx:if="{{item.coverUrl}}" class="cover-sq" src="{{item.coverUrl}}" mode="aspectFill" /><view wx:else class="cover-sq cover-sq-ph" /></view><view class="album-info"><text class="album-title">{{item.title}}</text><text class="album-artist" catchtap="onArtistTap" data-artist-id="{{item.neteaseArtistId}}" data-artist="{{item.primaryArtist}}">{{item.artist}}</text><text class="album-date">{{item.releaseDisplay}}</text></view><text class="album-score">{{item.score}}</text></view></view>
      </block>
      <view wx:if="{{loadingMore}}" class="load-more"><text>加载更多专辑…</text></view><view wx:elif="{{!albumHasMore}}" class="load-more"><text>已显示全部 {{total}} 张专辑</text></view>
    </block>
    <block wx:else>
      <view class="side-row"><text class="side-text">SIDE A — LABEL 厂牌</text><view class="side-rule" /></view>
      <scroll-view scroll-x show-scrollbar="{{false}}" class="brand-scroll"><view class="brand-stamps brand-stamps-horizontal"><view wx:for="{{brandCards}}" wx:key="name" class="brand-stamp {{activeBrand === item.name ? 'active' : ''}}" bindtap="onBrandTap" data-brand="{{item.name}}"><text class="brand-name">{{item.name}}</text><text class="brand-count">{{item.count}}</text></view></view></scroll-view>
      <view class="side-row artist-result-title"><text class="side-text">SIDE B — {{activeBrand}} · {{artistLoading ? '加载中' : artistTotal + ' 位'}}</text><view class="side-rule" /></view>
      <view wx:if="{{artistLoading}}" class="artist-grid"><view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="artist-tile"><view class="sk" style="width:110rpx;height:110rpx;border-radius:50%;" /><view class="sk" style="width:100rpx;height:24rpx;margin-top:16rpx;" /></view></view>
      <view wx:elif="{{artistVisibleList.length === 0}}" class="empty-state"><text class="empty-text">这个分类暂无艺人</text></view>
      <view wx:elif="{{activeBrand === '全部'}}" class="artist-all-list with-alpha-index"><view wx:for="{{artistLetterGroups}}" wx:key="letter" class="artist-letter-group" id="artist-letter-{{item.letter === '#' ? 'num' : item.letter}}"><view class="artist-letter-row"><text class="artist-letter-title">{{item.letter}}</text><view class="artist-letter-rule" /></view><view wx:for="{{item.list}}" wx:for-item="artist" wx:key="artistId" class="artist-all-row" bindtap="onArtistTap" data-artist-id="{{artist.artistId}}" data-artist="{{artist.artistName}}"><view class="artist-all-avatar"><image wx:if="{{artist.picUrl}}" class="artist-all-img" src="{{artist.picUrl}}" mode="aspectFill" /><text wx:else class="artist-all-initial">{{artist.letter}}</text></view><view class="artist-all-info"><text class="artist-all-name">{{artist.artistName}}</text><text class="artist-all-meta">{{artist.albumSize || 0}} 张专辑</text></view><text class="artist-all-arrow">›</text></view></view></view>
      <view wx:else class="artist-grid"><view wx:for="{{artistVisibleList}}" wx:key="artistId" class="artist-tile" bindtap="onArtistTap" data-artist-id="{{item.artistId}}" data-artist="{{item.artistName}}"><view class="artist-tile-avatar"><image wx:if="{{item.picUrl}}" class="artist-tile-img" src="{{item.picUrl}}" mode="aspectFill" /><text wx:else class="artist-tile-initial">{{item.letter}}</text></view><text class="artist-tile-name">{{item.artistName}}</text><text class="artist-tile-meta">{{item.albumSize || 0}} 张专辑</text></view></view>
    </block>
  </scroll-view>
  <view wx:if="{{viewMode === 'albums' && activeYear && activeYear !== 'ALL' && activeYear !== '2010s' && activeYear !== '2000s'}}" class="month-index"><view wx:for="{{months}}" wx:key="*this" class="month-index-item {{activeMonth === item ? 'active' : ''}}" bindtap="onMonthTap" data-month="{{item}}"><text>{{item}}</text></view></view>
  <view wx:if="{{viewMode === 'albums' && activeYear === 'ALL' && allAlbumLetters.length > 1}}" class="alphabet-index"><view wx:for="{{allAlbumLetters}}" wx:key="*this" class="alphabet-index-item {{activeAlbumLetter === item ? 'active' : ''}}" bindtap="onAlbumLetterTap" data-letter="{{item}}"><text>{{item}}</text></view></view>
  <view wx:if="{{viewMode === 'artists' && activeBrand === '全部' && artistLetters.length > 1}}" class="alphabet-index"><view wx:for="{{artistLetters}}" wx:key="*this" class="alphabet-index-item {{activeLetter === item ? 'active' : ''}}" bindtap="onLetterTap" data-letter="{{item}}"><text>{{item}}</text></view></view>
  <bottom-nav selected="{{2}}" />
</view>