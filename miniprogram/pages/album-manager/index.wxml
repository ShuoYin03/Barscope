<view class="page {{themeClass}}">

  <!-- TOPBAR -->
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <view class="topbar-back" bindtap="onBack">
      <text class="back-arrow">←</text>
    </view>
    <view class="topbar-titles">
      <text class="topbar-title">{{view === 'albums' ? selectedArtist.artistName : 'ALBUMS'}}</text>
      <text class="topbar-sub">{{view === 'albums' ? 'DISCOGRAPHY' : 'MGMT'}}</text>
    </view>
  </view>

  <!-- ══ ARTIST LIST / TITLE SEARCH ═══════════════════════════════════════════ -->
  <block wx:if="{{view === 'artists'}}">
    <view class="mode-tabs">
      <view class="mode-tab {{searchMode === 'artist' ? 'active' : ''}}" bindtap="onSearchModeTap" data-mode="artist"><text>按艺人</text></view>
      <view class="mode-tab {{searchMode === 'title' ? 'active' : ''}}" bindtap="onSearchModeTap" data-mode="title"><text>按专辑名</text></view>
      <view class="mode-tab {{searchMode === 'all' ? 'active' : ''}}" bindtap="onSearchModeTap" data-mode="all"><text>全部</text></view>
      <view class="mode-tab {{searchMode === 'multi' ? 'active' : ''}}" bindtap="onSearchModeTap" data-mode="multi"><text>多人合作</text></view>
      <view class="mode-tab {{searchMode === 'uncategorized' ? 'active' : ''}}" bindtap="onSearchModeTap" data-mode="uncategorized"><text>未分类</text></view>
      <view class="mode-tab {{searchMode === 'ownership-audit' ? 'active' : ''}}" bindtap="onSearchModeTap" data-mode="ownership-audit"><text>排查</text></view>
      <view class="mode-tab {{searchMode === 'hidden-audit' ? 'active' : ''}}" bindtap="onSearchModeTap" data-mode="hidden-audit"><text>误隐藏排查</text></view>
    </view>

    <view class="search-bar" wx:if="{{searchMode === 'artist' || searchMode === 'title' || searchMode === 'all'}}">
      <view class="search-input-wrap">
        <text class="search-icon">⌕</text>
        <input
          wx:if="{{searchMode === 'artist'}}"
          class="search-input"
          placeholder="搜索已批准艺人…"
          value="{{artistKeyword}}"
          bindinput="onArtistSearch"
          placeholder-style="color:#666"
        />
        <input
          wx:elif="{{searchMode === 'title'}}"
          class="search-input"
          placeholder="搜索专辑名称…"
          value="{{titleKeyword}}"
          bindinput="onTitleSearch"
          placeholder-style="color:#666"
        />
        <input
          wx:else
          class="search-input"
          placeholder="搜索专辑名 / 歌手 / 专辑ID…"
          value="{{allSearchKeyword}}"
          bindinput="onAllSearch"
          placeholder-style="color:#666"
        />
      </view>
    </view>

    <scroll-view
      wx:if="{{searchMode === 'artist'}}"
      class="content"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      bindscrolltolower="onReachBottom"
    >
      <view class="cleanup-panel">
        <view class="cleanup-head">
          <view>
            <text class="cleanup-title">重复专辑清理</text>
            <text class="cleanup-desc">按网易云 sourceId 识别重复，保留评论更多/已显示的版本</text>
          </view>
          <view
            class="cleanup-btn {{cleanupLoading ? 'btn-disabled' : ''}}"
            bindtap="onPreviewDuplicates"
          >
            <text class="cleanup-btn-text">{{cleanupLoading ? '扫描中' : '扫描'}}</text>
          </view>
        </view>

        <view wx:if="{{cleanupPreview}}" class="cleanup-result-card">
          <view class="cleanup-stats">
            <view class="cleanup-stat">
              <text class="cleanup-stat-num">{{cleanupPreview.scanned}}</text>
              <text class="cleanup-stat-label">已扫描</text>
            </view>
            <view class="cleanup-stat">
              <text class="cleanup-stat-num">{{cleanupPreview.duplicateGroups}}</text>
              <text class="cleanup-stat-label">重复组</text>
            </view>
            <view class="cleanup-stat danger">
              <text class="cleanup-stat-num">{{cleanupPreview.wouldRemove}}</text>
              <text class="cleanup-stat-label">待删除</text>
            </view>
          </view>

          <block wx:if="{{cleanupPreview.samples.length > 0}}">
            <view wx:for="{{cleanupPreview.samples}}" wx:key="key" class="dup-sample">
              <text class="dup-title">{{item.keep.title}}</text>
              <text class="dup-keep">保留：{{item.keep.artist}} · {{item.keep.reviewCount}} 评</text>
              <text class="dup-remove">删除 {{item.remove.length}} 张重复记录</text>
            </view>
          </block>

          <view
            wx:if="{{cleanupPreview.wouldRemove > 0}}"
            class="cleanup-confirm-btn {{cleanupLoading ? 'btn-disabled' : ''}}"
            bindtap="onRunDuplicateCleanup"
          >
            <text class="cleanup-confirm-text">确认清理 {{cleanupPreview.wouldRemove}} 张</text>
          </view>
        </view>

        <view wx:if="{{cleanupResult}}" class="cleanup-result-card">
          <text class="cleanup-title">清理完成</text>
          <text class="cleanup-desc">已删除 {{cleanupResult.removed}} 张，迁移 {{cleanupResult.reviewsMoved}} 条评论 / {{cleanupResult.favoritesMoved}} 条收藏</text>
        </view>
      </view>

      <block wx:if="{{artistLoading && artistList.length === 0}}">
        <view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="card-skeleton">
          <view class="sk skel-pic"></view>
          <view class="skel-body">
            <view class="sk skel-name"></view>
            <view class="sk skel-meta"></view>
          </view>
        </view>
      </block>

      <view wx:elif="{{artistList.length === 0}}" class="empty-state">
        <text class="empty-icon">○</text>
        <text class="empty-text">{{artistKeyword ? '没有匹配的艺人' : '暂无已批准艺人'}}</text>
      </view>

      <block wx:else>
        <view
          wx:for="{{artistList}}"
          wx:key="_id"
          class="artist-row"
          bindtap="onArtistTap"
          data-artist="{{item}}"
        >
          <view class="artist-photo">
            <image wx:if="{{item.picUrl}}" class="photo-img" src="{{item.picUrl}}" mode="aspectFill" />
            <view wx:else class="photo-fallback">
              <text class="photo-initial">{{item.artistName[0]}}</text>
            </view>
          </view>
          <view class="artist-info">
            <text class="artist-name">{{item.artistName}}</text>
            <text class="artist-meta">{{item.albumSize}} 张专辑</text>
          </view>
          <text class="row-arrow">→</text>
        </view>

        <view wx:if="{{artistLoading}}" class="load-more">
          <text class="load-more-text">加载中…</text>
        </view>
        <view wx:elif="{{!artistHasMore && artistList.length > 0}}" class="list-end">
          <text class="list-end-text">── 已全部加载 ──</text>
        </view>
      </block>
    </scroll-view>

    <scroll-view wx:elif="{{searchMode === 'title'}}" class="content" scroll-y enhanced show-scrollbar="{{false}}">
      <block wx:if="{{titleLoading && titleResults.length === 0}}">
        <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="album-skeleton">
          <view class="sk skel-cover"></view>
          <view class="skel-body">
            <view class="sk skel-name"></view>
            <view class="sk skel-meta"></view>
          </view>
        </view>
      </block>

      <view wx:elif="{{titleResults.length === 0}}" class="empty-state">
        <text class="empty-icon">○</text>
        <text class="empty-text">{{titleKeyword ? '没有匹配的专辑' : '输入专辑名称开始搜索'}}</text>
      </view>

      <block wx:else>
        <view wx:for="{{titleResults}}" wx:key="_id" class="album-row" bindtap="onTitleCardTap" data-id="{{item._id}}">
          <view class="album-cover-wrap">
            <image wx:if="{{item.coverUrl}}" class="album-cover" src="{{item.coverUrl}}" mode="aspectFill" />
            <view wx:else class="album-cover-fallback">
              <text class="album-cover-icon">♪</text>
            </view>
            <view wx:if="{{!item.approved}}" class="cover-hidden-badge">
              <text class="cover-hidden-text">隐藏</text>
            </view>
          </view>

          <view class="album-info">
            <text class="album-title">{{item.title}}</text>
            <text class="album-artist">{{item.artist}}</text>
            <view class="album-meta-row">
              <text class="album-meta">{{item.releaseYear}}</text>
              <view wx:if="{{item.trackCount > 0}}" class="meta-dot"></view>
              <text wx:if="{{item.trackCount > 0}}" class="album-meta">{{item.trackCount}} 首</text>
              <view wx:if="{{item.reviewCount > 0}}" class="meta-dot"></view>
              <text wx:if="{{item.reviewCount > 0}}" class="album-meta">{{item.reviewCount}} 评</text>
            </view>
          </view>

          <view class="release-tag {{item.releaseType ? 'set' : ''}}" catchtap="onSetReleaseType" data-id="{{item._id}}">
            <text>{{item.releaseType || '类型'}}</text>
          </view>

          <view
            class="toggle-btn {{item.approved ? 'toggle-on' : 'toggle-off'}} {{toggling[item._id] ? 'btn-disabled' : ''}}"
            catchtap="onToggleApproved"
            data-id="{{item._id}}"
            data-approved="{{item.approved}}"
          >
            <text class="toggle-text">{{item.approved ? '显示' : '隐藏'}}</text>
          </view>
        </view>

        <view class="list-end">
          <text class="list-end-text">── 共 {{titleResults.length}} 张 ──</text>
        </view>
      </block>
    </scroll-view>

    <!-- ── 全部专辑（按字母表浏览 + 批量操作） ── -->
    <block wx:elif="{{searchMode === 'all'}}">
      <view class="letter-tabs-wrap">
        <scroll-view class="letter-tabs" scroll-x enhanced show-scrollbar="{{false}}">
          <view
            wx:for="{{allLetters}}"
            wx:key="letter"
            class="letter-tab {{allActiveLetter === item.letter ? 'active' : ''}}"
            bindtap="onAllLetterTap"
            data-letter="{{item.letter}}"
          >
            <text>{{item.letter}}</text>
            <text wx:if="{{item.count}}" class="letter-tab-count">{{item.count}}</text>
          </view>
        </scroll-view>
      </view>

      <view class="all-action-bar">
        <view class="all-action-btn" bindtap="onToggleAllSelectMode">
          <text>{{allSelectMode ? '取消批量' : '批量选择'}}</text>
        </view>
        <block wx:if="{{allSelectMode}}">
          <view class="all-action-btn" bindtap="onAllSelectAll"><text>{{allSelectedCount ? '取消全选' : '全选'}}</text></view>
          <view class="all-action-btn accent {{allBatchWorking ? 'btn-disabled' : ''}}" bindtap="onAllBatchShow"><text>批量显示</text></view>
          <view class="all-action-btn danger {{allBatchWorking ? 'btn-disabled' : ''}}" bindtap="onAllBatchHide"><text>批量隐藏</text></view>
          <view class="all-action-btn accent" bindtap="onAllBatchOwnership"><text>批量设置归属</text></view>
          <view class="all-action-btn accent" bindtap="onAllBatchSetType"><text>批量设置类型</text></view>
          <view class="all-action-btn ghost {{resyncWorking ? 'btn-disabled' : ''}}" bindtap="onAllBatchResync">
            <text>{{resyncWorking ? ('同步中 ' + resyncDone + '/' + resyncTotal) : '重新同步Tracks'}}</text>
          </view>
        </block>
        <block wx:else>
          <view class="all-action-btn ghost {{backfilling ? 'btn-disabled' : ''}}" bindtap="onBackfillLetters">
            <text>{{backfilling ? ('索引中 ' + backfillDone) : '补全字母索引'}}</text>
          </view>
          <view class="all-action-btn ghost {{applyingRules ? 'btn-disabled' : ''}}" bindtap="onApplyReleaseTypeRules">
            <text>{{applyingRules ? ('打标签中 ' + applyRulesDone) : '一键打标签'}}</text>
          </view>
          <view class="all-action-btn ghost {{applyingOwnerFix ? 'btn-disabled' : ''}}" bindtap="onApplyOwnerArtistFix">
            <text>{{applyingOwnerFix ? ('修正中 ' + applyOwnerFixDone) : '一键修正专辑归属'}}</text>
          </view>
          <view class="all-action-btn ghost {{applyingYearFix ? 'btn-disabled' : ''}}" bindtap="onApplyReleaseYearFix">
            <text>{{applyingYearFix ? ('修正中 ' + applyYearFixDone) : '一键修正发行年份'}}</text>
          </view>
        </block>
      </view>

      <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="onAllReachBottom">
        <block wx:if="{{allLoading && allList.length === 0}}">
          <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="album-skeleton">
            <view class="sk skel-cover"></view>
            <view class="skel-body">
              <view class="sk skel-name"></view>
              <view class="sk skel-meta"></view>
            </view>
          </view>
        </block>

        <view wx:elif="{{allList.length === 0}}" class="empty-state">
          <text class="empty-icon">○</text>
          <text class="empty-text">{{allSearching ? '没有匹配的专辑' : '该字母下暂无专辑'}}</text>
        </view>

        <block wx:else>
          <view
            wx:for="{{allList}}"
            wx:key="_id"
            class="album-row {{allSelectMode ? 'selectable' : ''}} {{item.selected ? 'selected' : ''}}"
            bindtap="onAllCardTap"
            data-id="{{item._id}}"
          >
            <view wx:if="{{allSelectMode}}" class="select-box {{item.selected ? 'checked' : ''}}"><text wx:if="{{item.selected}}">✓</text></view>
            <view class="album-cover-wrap">
              <image wx:if="{{item.coverUrl}}" class="album-cover" src="{{item.coverUrl}}" mode="aspectFill" />
              <view wx:else class="album-cover-fallback">
                <text class="album-cover-icon">♪</text>
              </view>
              <view wx:if="{{!item.approved}}" class="cover-hidden-badge">
                <text class="cover-hidden-text">隐藏</text>
              </view>
            </view>

            <view class="album-info">
              <text class="album-title">{{item.title}}</text>
              <text class="album-artist">{{item.artist}}</text>
              <view class="album-meta-row">
                <text class="album-meta">{{item.releaseYear}}</text>
                <view wx:if="{{item.trackCount > 0}}" class="meta-dot"></view>
                <text wx:if="{{item.trackCount > 0}}" class="album-meta">{{item.trackCount}} 首</text>
                <view wx:if="{{item.reviewCount > 0}}" class="meta-dot"></view>
                <text wx:if="{{item.reviewCount > 0}}" class="album-meta">{{item.reviewCount}} 评</text>
              </view>
            </view>

            <view wx:if="{{!allSelectMode}}" class="release-tag {{item.releaseType ? 'set' : ''}}" catchtap="onSetReleaseType" data-id="{{item._id}}">
              <text>{{item.releaseType || '类型'}}</text>
            </view>

            <view
              wx:if="{{!allSelectMode}}"
              class="toggle-btn {{item.approved ? 'toggle-on' : 'toggle-off'}} {{toggling[item._id] ? 'btn-disabled' : ''}}"
              catchtap="onToggleApproved"
              data-id="{{item._id}}"
              data-approved="{{item.approved}}"
            >
              <text class="toggle-text">{{item.approved ? '显示' : '隐藏'}}</text>
            </view>
          </view>

          <view wx:if="{{allLoading}}" class="load-more">
            <text class="load-more-text">加载中…</text>
          </view>
          <view wx:elif="{{!allHasMore && allList.length > 0}}" class="list-end">
            <text class="list-end-text">── 共 {{allTotal}} 张 ──</text>
          </view>
        </block>
      </scroll-view>
    </block>

    <!-- ── 多人合作专辑 ── -->
    <block wx:elif="{{searchMode === 'multi'}}">
      <view class="all-action-bar">
        <view class="all-action-btn" bindtap="onToggleMultiSelectMode">
          <text>{{multiSelectMode ? '取消批量' : '批量选择'}}</text>
        </view>
        <block wx:if="{{multiSelectMode}}">
          <view class="all-action-btn" bindtap="onMultiSelectAll"><text>{{multiSelectedCount ? '取消全选' : '全选'}}</text></view>
          <view class="all-action-btn accent {{allBatchWorking ? 'btn-disabled' : ''}}" bindtap="onMultiBatchShow"><text>批量显示</text></view>
          <view class="all-action-btn danger {{allBatchWorking ? 'btn-disabled' : ''}}" bindtap="onMultiBatchHide"><text>批量隐藏</text></view>
          <view class="all-action-btn accent" bindtap="onMultiBatchOwnership"><text>批量设置归属</text></view>
          <view class="all-action-btn accent" bindtap="onMultiBatchSetType"><text>批量设置类型</text></view>
          <view class="all-action-btn ghost {{resyncWorking ? 'btn-disabled' : ''}}" bindtap="onMultiBatchResync">
            <text>{{resyncWorking ? ('同步中 ' + resyncDone + '/' + resyncTotal) : '重新同步Tracks'}}</text>
          </view>
        </block>
        <view wx:else class="all-action-btn ghost {{multiReindexing ? 'btn-disabled' : ''}}" bindtap="onRebuildMultiArtistIndex">
          <text>{{multiReindexing ? ('扫描中 ' + multiReindexDone) : '扫描全部合作专辑'}}</text>
        </view>
      </view>
      <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="onMultiReachBottom">
      <block wx:if="{{multiLoading && multiList.length === 0}}">
        <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="album-skeleton">
          <view class="sk skel-cover"></view>
          <view class="skel-body">
            <view class="sk skel-name"></view>
            <view class="sk skel-meta"></view>
          </view>
        </view>
      </block>

      <view wx:elif="{{multiList.length === 0}}" class="empty-state">
        <text class="empty-icon">○</text>
        <text class="empty-text">暂无多人合作专辑</text>
      </view>

      <block wx:else>
        <view wx:for="{{multiList}}" wx:key="_id" class="album-row {{multiSelectMode ? 'selectable' : ''}} {{item.selected ? 'selected' : ''}}" bindtap="onMultiCardTap" data-id="{{item._id}}">
          <view wx:if="{{multiSelectMode}}" class="select-box {{item.selected ? 'checked' : ''}}"><text wx:if="{{item.selected}}">✓</text></view>
          <view class="album-cover-wrap">
            <image wx:if="{{item.coverUrl}}" class="album-cover" src="{{item.coverUrl}}" mode="aspectFill" />
            <view wx:else class="album-cover-fallback">
              <text class="album-cover-icon">♪</text>
            </view>
            <view wx:if="{{!item.approved}}" class="cover-hidden-badge">
              <text class="cover-hidden-text">隐藏</text>
            </view>
          </view>

          <view class="album-info">
            <text class="album-title">{{item.title}}</text>
            <text class="album-artist">{{item.artist}}</text>
            <view class="album-meta-row">
              <text class="album-meta">{{item.releaseYear}}</text>
              <view wx:if="{{item.trackCount > 0}}" class="meta-dot"></view>
              <text wx:if="{{item.trackCount > 0}}" class="album-meta">{{item.trackCount}} 首</text>
              <view wx:if="{{item.reviewCount > 0}}" class="meta-dot"></view>
              <text wx:if="{{item.reviewCount > 0}}" class="album-meta">{{item.reviewCount}} 评</text>
            </view>
          </view>

          <view wx:if="{{!multiSelectMode}}" class="release-tag {{item.releaseType ? 'set' : ''}}" catchtap="onSetReleaseType" data-id="{{item._id}}">
            <text>{{item.releaseType || '类型'}}</text>
          </view>

          <view
            wx:if="{{!multiSelectMode}}"
            class="toggle-btn {{item.approved ? 'toggle-on' : 'toggle-off'}} {{toggling[item._id] ? 'btn-disabled' : ''}}"
            catchtap="onToggleApproved"
            data-id="{{item._id}}"
            data-approved="{{item.approved}}"
          >
            <text class="toggle-text">{{item.approved ? '显示' : '隐藏'}}</text>
          </view>
        </view>

        <view wx:if="{{multiLoading}}" class="load-more">
          <text class="load-more-text">加载中…</text>
        </view>
        <view wx:elif="{{!multiHasMore && multiList.length > 0}}" class="list-end">
          <text class="list-end-text">── 共 {{multiTotal}} 张 ──</text>
        </view>
      </block>
      </scroll-view>
    </block>

    <!-- ── 归属排查：拿 NetEase 专辑级歌手信息实时核对，标出多出来的（很可能是被 track 级 feat. 污染的） ── -->
    <block wx:elif="{{searchMode === 'ownership-audit'}}">
      <view class="all-action-bar">
        <view class="all-action-btn ghost {{ownershipAuditScanning ? 'btn-disabled' : ''}}" bindtap="onScanOwnershipMismatches">
          <text>{{ownershipAuditScanning ? ('排查中 ' + ownershipAuditScanDone) : '开始排查'}}</text>
        </view>
        <view wx:if="{{ownershipAuditList.length > 0}}" class="all-action-btn accent {{ownershipAuditApplying ? 'btn-disabled' : ''}}" bindtap="onApplyOwnershipAuditFix">
          <text>{{ownershipAuditApplying ? ('修正中 ' + ownershipAuditApplyDone + '/' + ownershipAuditList.length) : ('一键跟随网易云修正 ' + ownershipAuditList.length)}}</text>
        </view>
      </view>
      <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
        <view wx:if="{{!ownershipAuditScanning && ownershipAuditList.length === 0 && !ownershipAuditScanDone}}" class="empty-state">
          <text class="empty-icon">○</text>
          <text class="empty-text">点击"开始排查"，会拿每张多人合作专辑跟网易云专辑页实时核对，标出疑似被曲目级 feat. 污染归属的专辑</text>
        </view>

        <view wx:elif="{{!ownershipAuditScanning && ownershipAuditList.length === 0 && ownershipAuditScanDone}}" class="empty-state">
          <text class="empty-icon">○</text>
          <text class="empty-text">排查完成，已检查 {{ownershipAuditScanDone}} 张多人合作专辑，没有发现疑似问题</text>
        </view>

        <block wx:else>
          <view wx:for="{{ownershipAuditList}}" wx:key="_id" class="album-row" bindtap="onOwnershipAuditCardTap" data-id="{{item._id}}">
            <view class="album-cover-wrap">
              <image wx:if="{{item.coverUrl}}" class="album-cover" src="{{item.coverUrl}}" mode="aspectFill" />
              <view wx:else class="album-cover-fallback"><text class="album-cover-icon">♪</text></view>
            </view>
            <view class="album-info">
              <text class="album-title">{{item.title}}</text>
              <text class="album-artist">{{item.artist}}</text>
              <text class="album-meta" style="color:#d45124;">疑似多出：{{item.extraNamesText}}</text>
              <text class="album-meta">网易云实际歌手：{{item.liveArtistNamesText}}</text>
            </view>
          </view>

          <view wx:if="{{ownershipAuditScanning}}" class="load-more">
            <text class="load-more-text">排查中，已检查 {{ownershipAuditScanDone}} 张，发现 {{ownershipAuditList.length}} 张疑似有问题…</text>
          </view>
          <view wx:elif="{{ownershipAuditList.length > 0}}" class="list-end">
            <text class="list-end-text">── 共检查 {{ownershipAuditScanDone}} 张，{{ownershipAuditList.length}} 张疑似有问题，点击专辑去核实/修改归属 ──</text>
          </view>
        </block>
      </scroll-view>
    </block>

    <!-- ── 误隐藏排查：找出已有评分但当前处于隐藏状态、且没有任何明确隐藏标记的专辑（很可能是艺人审核拒绝时按名字误连坐隐藏的） ── -->
    <block wx:elif="{{searchMode === 'hidden-audit'}}">
      <view class="all-action-bar">
        <view class="all-action-btn ghost {{hiddenAuditScanning ? 'btn-disabled' : ''}}" bindtap="onScanWronglyHiddenAlbums">
          <text>{{hiddenAuditScanning ? ('排查中 ' + hiddenAuditScanDone) : '开始排查'}}</text>
        </view>
        <view wx:if="{{hiddenAuditList.length > 0}}" class="all-action-btn accent {{hiddenAuditApplying ? 'btn-disabled' : ''}}" bindtap="onRestoreWronglyHiddenAlbums">
          <text>{{hiddenAuditApplying ? ('恢复中 ' + hiddenAuditApplyDone + '/' + hiddenAuditList.length) : ('一键恢复显示 ' + hiddenAuditList.length)}}</text>
        </view>
      </view>
      <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
        <view wx:if="{{!hiddenAuditScanning && hiddenAuditList.length === 0 && !hiddenAuditScanDone}}" class="empty-state">
          <text class="empty-icon">○</text>
          <text class="empty-text">点击"开始排查"，会找出已经有评分、但目前处于隐藏状态、且没有管理员手动隐藏/用户举报等明确标记的专辑</text>
        </view>

        <view wx:elif="{{!hiddenAuditScanning && hiddenAuditList.length === 0 && hiddenAuditScanDone}}" class="empty-state">
          <text class="empty-icon">○</text>
          <text class="empty-text">排查完成，已检查 {{hiddenAuditScanDone}} 张，没有发现疑似被误隐藏的专辑</text>
        </view>

        <block wx:else>
          <view wx:for="{{hiddenAuditList}}" wx:key="id" class="album-row" bindtap="onHiddenAuditCardTap" data-id="{{item.id}}">
            <view class="album-info">
              <text class="album-title">{{item.title}}</text>
              <text class="album-artist">{{item.artist}}</text>
              <text class="album-meta" style="color:#d45124;">共 {{item.reviewCount}} 人打分 {{item.avgScore}}，但当前隐藏</text>
            </view>
          </view>

          <view wx:if="{{hiddenAuditScanning}}" class="load-more">
            <text class="load-more-text">排查中，已检查 {{hiddenAuditScanDone}} 张，发现 {{hiddenAuditList.length}} 张疑似被误隐藏…</text>
          </view>
          <view wx:elif="{{hiddenAuditList.length > 0}}" class="list-end">
            <text class="list-end-text">── 共检查 {{hiddenAuditScanDone}} 张，{{hiddenAuditList.length}} 张疑似被误隐藏 ──</text>
          </view>
        </block>
      </scroll-view>
    </block>

    <!-- ── 未分类专辑（没有 LP/Mixtape/Live/Beat Tape 类型标签）── -->
    <block wx:else>
      <view class="all-action-bar">
        <view class="all-action-btn" bindtap="onToggleUncategorizedSelectMode">
          <text>{{uncategorizedSelectMode ? '取消批量' : '批量选择'}}</text>
        </view>
        <block wx:if="{{uncategorizedSelectMode}}">
          <view class="all-action-btn" bindtap="onUncategorizedSelectAll"><text>{{uncategorizedSelectedCount ? '取消全选' : '全选'}}</text></view>
          <view class="all-action-btn accent {{allBatchWorking ? 'btn-disabled' : ''}}" bindtap="onUncategorizedBatchShow"><text>批量显示</text></view>
          <view class="all-action-btn danger {{allBatchWorking ? 'btn-disabled' : ''}}" bindtap="onUncategorizedBatchHide"><text>批量隐藏</text></view>
          <view class="all-action-btn accent" bindtap="onUncategorizedBatchOwnership"><text>批量设置归属</text></view>
          <view class="all-action-btn accent" bindtap="onUncategorizedBatchSetType"><text>批量设置类型</text></view>
          <view class="all-action-btn ghost {{resyncWorking ? 'btn-disabled' : ''}}" bindtap="onUncategorizedBatchResync">
            <text>{{resyncWorking ? ('同步中 ' + resyncDone + '/' + resyncTotal) : '重新同步Tracks'}}</text>
          </view>
        </block>
      </view>
      <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="onUncategorizedReachBottom">
      <block wx:if="{{uncategorizedLoading && uncategorizedList.length === 0}}">
        <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="album-skeleton">
          <view class="sk skel-cover"></view>
          <view class="skel-body">
            <view class="sk skel-name"></view>
            <view class="sk skel-meta"></view>
          </view>
        </view>
      </block>

      <view wx:elif="{{uncategorizedList.length === 0}}" class="empty-state">
        <text class="empty-icon">○</text>
        <text class="empty-text">暂无未分类专辑</text>
      </view>

      <block wx:else>
        <view wx:for="{{uncategorizedList}}" wx:key="_id" class="album-row {{uncategorizedSelectMode ? 'selectable' : ''}} {{item.selected ? 'selected' : ''}}" bindtap="onUncategorizedCardTap" data-id="{{item._id}}">
          <view wx:if="{{uncategorizedSelectMode}}" class="select-box {{item.selected ? 'checked' : ''}}"><text wx:if="{{item.selected}}">✓</text></view>
          <view class="album-cover-wrap">
            <image wx:if="{{item.coverUrl}}" class="album-cover" src="{{item.coverUrl}}" mode="aspectFill" />
            <view wx:else class="album-cover-fallback">
              <text class="album-cover-icon">♪</text>
            </view>
            <view wx:if="{{!item.approved}}" class="cover-hidden-badge">
              <text class="cover-hidden-text">隐藏</text>
            </view>
          </view>

          <view class="album-info">
            <text class="album-title">{{item.title}}</text>
            <text class="album-artist">{{item.artist}}</text>
            <view class="album-meta-row">
              <text class="album-meta">{{item.releaseYear}}</text>
              <view wx:if="{{item.trackCount > 0}}" class="meta-dot"></view>
              <text wx:if="{{item.trackCount > 0}}" class="album-meta">{{item.trackCount}} 首</text>
              <view wx:if="{{item.reviewCount > 0}}" class="meta-dot"></view>
              <text wx:if="{{item.reviewCount > 0}}" class="album-meta">{{item.reviewCount}} 评</text>
            </view>
          </view>

          <view wx:if="{{!uncategorizedSelectMode}}" class="release-tag" catchtap="onSetReleaseType" data-id="{{item._id}}">
            <text>类型</text>
          </view>

          <view
            wx:if="{{!uncategorizedSelectMode}}"
            class="toggle-btn {{item.approved ? 'toggle-on' : 'toggle-off'}} {{toggling[item._id] ? 'btn-disabled' : ''}}"
            catchtap="onToggleApproved"
            data-id="{{item._id}}"
            data-approved="{{item.approved}}"
          >
            <text class="toggle-text">{{item.approved ? '显示' : '隐藏'}}</text>
          </view>
        </view>

        <view wx:if="{{uncategorizedLoading}}" class="load-more">
          <text class="load-more-text">加载中…</text>
        </view>
        <view wx:elif="{{!uncategorizedHasMore && uncategorizedList.length > 0}}" class="list-end">
          <text class="list-end-text">── 共 {{uncategorizedTotal}} 张 ──</text>
        </view>
      </block>
      </scroll-view>
    </block>
  </block>

  <!-- ══ ALBUM LIST ══════════════════════════════════════════════════════════ -->
  <block wx:elif="{{view === 'albums'}}">
    <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">

      <block wx:if="{{albumLoading && albumList.length === 0}}">
        <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="album-skeleton">
          <view class="sk skel-cover"></view>
          <view class="skel-body">
            <view class="sk skel-name"></view>
            <view class="sk skel-meta"></view>
          </view>
        </view>
      </block>

      <view wx:elif="{{albumList.length === 0}}" class="empty-state">
        <text class="empty-icon">○</text>
        <text class="empty-text">该艺人暂无已收录专辑</text>
      </view>

      <block wx:else>
        <view wx:for="{{albumList}}" wx:key="_id" class="album-row" bindtap="onAlbumCardTap" data-id="{{item._id}}">
          <view class="album-cover-wrap">
            <image wx:if="{{item.coverUrl}}" class="album-cover" src="{{item.coverUrl}}" mode="aspectFill" />
            <view wx:else class="album-cover-fallback">
              <text class="album-cover-icon">♪</text>
            </view>
            <!-- Approval overlay indicator -->
            <view wx:if="{{!item.approved}}" class="cover-hidden-badge">
              <text class="cover-hidden-text">隐藏</text>
            </view>
          </view>

          <view class="album-info">
            <text class="album-title">{{item.title}}</text>
            <text class="album-artist">{{item.artist}}</text>
            <view class="album-meta-row">
              <text class="album-meta">{{item.releaseYear}}</text>
              <view wx:if="{{item.trackCount > 0}}" class="meta-dot"></view>
              <text wx:if="{{item.trackCount > 0}}" class="album-meta">{{item.trackCount}} 首</text>
              <view wx:if="{{item.reviewCount > 0}}" class="meta-dot"></view>
              <text wx:if="{{item.reviewCount > 0}}" class="album-meta">{{item.reviewCount}} 评</text>
            </view>
          </view>

          <view class="release-tag {{item.releaseType ? 'set' : ''}}" catchtap="onSetReleaseType" data-id="{{item._id}}">
            <text>{{item.releaseType || '类型'}}</text>
          </view>

          <view
            class="toggle-btn {{item.approved ? 'toggle-on' : 'toggle-off'}} {{toggling[item._id] ? 'btn-disabled' : ''}}"
            catchtap="onToggleApproved"
            data-id="{{item._id}}"
            data-approved="{{item.approved}}"
          >
            <text class="toggle-text">{{item.approved ? '显示' : '隐藏'}}</text>
          </view>
        </view>

        <view class="list-end">
          <text class="list-end-text">── 共 {{albumList.length}} 张 ──</text>
        </view>
      </block>
    </scroll-view>
  </block>

  <!-- ── 批量设置归属 sheet ── -->
  <view wx:if="{{ownerPickerVisible}}" class="owner-sheet-mask" bindtap="onOwnerPickerCancel">
    <view class="owner-sheet" catchtap="noop">
      <view class="owner-sheet-handle" />
      <text class="owner-sheet-title">设置归属 · 已选 {{ownerPickerAlbumCount}} 张专辑</text>

      <view wx:if="{{ownerPickerSelected.length}}" class="owner-sheet-chips">
        <view wx:for="{{ownerPickerSelected}}" wx:key="artistId" class="owner-chip" bindtap="onOwnerPickerRemove" data-id="{{item.artistId}}">
          <text>{{item.artistName}}</text><text class="owner-chip-x">×</text>
        </view>
      </view>
      <view wx:else class="owner-sheet-hint"><text>请选择一位或多位归属歌手</text></view>

      <input class="owner-sheet-input" placeholder="搜索归属歌手…" value="{{ownerPickerKeyword}}" bindinput="onOwnerPickerSearch" placeholder-style="color:#766f68" />

      <scroll-view class="owner-sheet-results" scroll-y>
        <view wx:for="{{ownerPickerResults}}" wx:key="artistId" class="owner-sheet-row {{item.selected ? 'selected' : ''}}" bindtap="onOwnerPickerPick" data-id="{{item.artistId}}">
          <view class="owner-sheet-avatar"><image wx:if="{{item.picUrl}}" class="owner-sheet-avatar-img" src="{{item.picUrl}}" mode="aspectFill" /><text wx:else>{{item.artistName[0]}}</text></view>
          <text class="owner-sheet-name">{{item.artistName}}</text>
          <text class="owner-sheet-check">{{item.selected ? '已选' : '选择'}}</text>
        </view>
      </scroll-view>

      <view class="owner-sheet-actions">
        <view class="owner-sheet-cancel" bindtap="onOwnerPickerCancel"><text>取消</text></view>
        <view class="owner-sheet-confirm {{ownerApplyWorking ? 'btn-disabled' : ''}}" bindtap="onOwnerPickerConfirm"><text>{{ownerApplyWorking ? '处理中…' : '确认设置'}}</text></view>
      </view>
    </view>
  </view>

</view>
