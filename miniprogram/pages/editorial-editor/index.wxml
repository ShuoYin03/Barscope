<view class="page {{themeClass}}">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <text class="back" bindtap="onBack">←</text>
    <view class="topbar-copy"><text class="brand">EDITORIAL</text><text class="sub">{{previewMode ? '文章预览' : '内容编辑器'}}</text></view>
    <view class="preview-toggle" bindtap="onTogglePreview"><text>{{previewMode ? '编辑' : '预览'}}</text></view>
  </view>

  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <block wx:if="{{!previewMode}}">
      <view class="editor-shell">
        <view class="status-row"><text class="status-label">STATUS</text><text class="status-value">{{submitted ? 'SUBMITTED' : 'DRAFT'}}</text></view>

        <view class="template-picker">
          <view class="template-option {{template==='review'?'active':''}}" data-template="review" bindtap="onTemplateTap"><text>REVIEW</text><text class="mini">专辑乐评</text></view>
          <view class="template-option {{template==='feature'?'active':''}}" data-template="feature" bindtap="onTemplateTap"><text>FEATURE</text><text class="mini">深度专题</text></view>
          <view class="template-option {{template==='interview'?'active':''}}" data-template="interview" bindtap="onTemplateTap"><text>INTERVIEW</text><text class="mini">人物访谈</text></view>
        </view>

        <view class="form-section">
          <text class="section-kicker">01 · ARTICLE INFO</text>
          <view class="field"><text class="field-label">TITLE</text><input class="input title-input" data-field="title" value="{{title}}" bindinput="onFieldInput" placeholder="输入文章标题" /></view>
          <view class="field"><text class="field-label">DECK</text><textarea class="textarea deck-input" data-field="deck" value="{{deck}}" bindinput="onFieldInput" placeholder="一句话导语 / 核心观点" maxlength="200" auto-height /></view>
          <view class="field two-col"><view><text class="field-label">AUTHOR</text><input class="input" data-field="author" value="{{author}}" bindinput="onFieldInput" placeholder="作者" /></view><view wx:if="{{template==='review'}}"><text class="field-label">SCORE</text><input class="input score-input" type="digit" data-field="score" value="{{score}}" bindinput="onFieldInput" placeholder="8.8" /></view></view>
        </view>

        <view class="form-section">
          <view class="section-head"><view><text class="section-kicker">02 · BLOCKS</text><text class="section-note">字体、字号与间距由模板自动控制</text></view><view class="add-mini" bindtap="onAddBlock"><text>＋ ADD</text></view></view>

          <view wx:for="{{blocks}}" wx:key="id" class="block-card">
            <view class="block-top"><text class="block-type">{{item.type}}</text><view class="block-actions"><text data-index="{{index}}" data-direction="up" bindtap="onMoveBlock">↑</text><text data-index="{{index}}" data-direction="down" bindtap="onMoveBlock">↓</text><text class="danger" data-index="{{index}}" bindtap="onDeleteBlock">×</text></view></view>

            <block wx:if="{{item.type==='paragraph'}}"><textarea class="textarea block-input" data-index="{{index}}" data-field="content" value="{{item.content}}" bindinput="onBlockInput" placeholder="输入正文。正文固定使用阅读字号与 1.8 行高。" auto-height /></block>
            <block wx:elif="{{item.type==='heading'}}"><input class="input heading-input" data-index="{{index}}" data-field="content" value="{{item.content}}" bindinput="onBlockInput" placeholder="章节标题" /></block>
            <block wx:elif="{{item.type==='quote' || item.type==='pullquote'}}"><textarea class="textarea quote-input" data-index="{{index}}" data-field="content" value="{{item.content}}" bindinput="onBlockInput" placeholder="输入引用内容" auto-height /></block>
            <block wx:elif="{{item.type==='divider'}}"><view class="two-col"><input class="input" data-index="{{index}}" data-field="label" value="{{item.label}}" bindinput="onBlockInput" placeholder="SIDE A" /><input class="input" data-index="{{index}}" data-field="content" value="{{item.content}}" bindinput="onBlockInput" placeholder="章节名称" /></view></block>
            <block wx:elif="{{item.type==='qa'}}"><text class="field-label">QUESTION</text><textarea class="textarea" data-index="{{index}}" data-field="question" value="{{item.question}}" bindinput="onBlockInput" placeholder="输入问题" auto-height /><text class="field-label qa-answer-label">ANSWER</text><textarea class="textarea" data-index="{{index}}" data-field="answer" value="{{item.answer}}" bindinput="onBlockInput" placeholder="输入回答" auto-height /></block>
            <block wx:elif="{{item.type==='image'}}"><view class="image-editor"><view class="image-drop" data-index="{{index}}" bindtap="onChooseImage"><image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" /><text wx:else>＋ 上传图片</text></view><view class="image-meta"><view class="layout-btn" data-index="{{index}}" bindtap="onImageLayout"><text>LAYOUT · {{item.layout}}</text></view><input class="input" data-index="{{index}}" data-field="label" value="{{item.label}}" bindinput="onBlockInput" placeholder="Caption / Photo Credit" /></view></view></block>
          </view>

          <view class="add-block" bindtap="onAddBlock"><text>＋ ADD BLOCK</text><text class="add-sub">Paragraph / Heading / Image / Quote / Divider / Q&A</text></view>
        </view>

        <view class="design-spec">
          <text class="section-kicker">DESIGN SYSTEM</text>
          <view class="spec-row"><text>Title</text><text>56–72rpx · Display</text></view>
          <view class="spec-row"><text>Heading</text><text>36–48rpx · Bold</text></view>
          <view class="spec-row"><text>Body</text><text>28–30rpx · 1.8 line-height</text></view>
          <view class="spec-row"><text>Caption</text><text>18–20rpx · Muted</text></view>
          <text class="spec-note">创作者选择内容和版式，不直接修改字体与字号，以保持 Barscope 的统一编辑风格。</text>
        </view>

        <view class="bottom-actions"><view class="secondary-btn" bindtap="onSave"><text>{{saving?'保存中':'SAVE DRAFT'}}</text></view><view class="primary-btn" bindtap="onSubmit"><text>SUBMIT FOR REVIEW</text></view></view>
      </view>
    </block>

    <block wx:else>
      <view class="article-preview {{template}}">
        <view class="preview-hero"><text class="preview-kicker">{{template==='review'?'ALBUM REVIEW':template==='feature'?'LONGFORM FEATURE':'IN CONVERSATION WITH'}}</text><text class="preview-title">{{title || '未命名文章'}}</text><text class="preview-deck">{{deck}}</text><view class="preview-meta"><text>BY {{author || 'BARSCOPE'}}</text><text wx:if="{{template==='review' && score}}" class="preview-score">{{score}}</text></view></view>
        <view class="preview-body">
          <block wx:for="{{blocks}}" wx:key="id">
            <text wx:if="{{item.type==='paragraph'}}" class="p-body">{{item.content}}</text>
            <text wx:elif="{{item.type==='heading'}}" class="p-heading">{{item.content}}</text>
            <view wx:elif="{{item.type==='quote'}}" class="p-quote"><text>“{{item.content}}”</text></view>
            <view wx:elif="{{item.type==='pullquote'}}" class="p-pullquote"><text>{{item.content}}</text></view>
            <view wx:elif="{{item.type==='divider'}}" class="p-divider"><text class="divider-label">{{item.label}}</text><text class="divider-title">{{item.content}}</text></view>
            <view wx:elif="{{item.type==='image'}}" class="p-image {{item.layout}}"><image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" /><view wx:else class="image-placeholder"><text>IMAGE</text></view><text wx:if="{{item.label}}" class="caption">{{item.label}}</text></view>
            <view wx:elif="{{item.type==='qa'}}" class="p-qa"><text class="speaker barscope">BARSCOPE</text><text class="question">{{item.question}}</text><text class="speaker">ARTIST</text><text class="answer">{{item.answer}}</text></view>
          </block>
        </view>
      </view>
    </block>
  </scroll-view>
</view>
