<view class="page-wrapper">

  <!-- TOPBAR -->
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <view class="topbar-logo">
      <text class="logo-zh">韵镜</text>
      <text class="logo-en">Barscope</text>
    </view>
  </view>

  <!-- SCROLLABLE CONTENT -->
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- TICKER -->
    <ticker songs="{{tickerSongs}}" />

    <!-- ── HERO ─────────────────────────────────────────────────────── -->
    <!-- skeleton -->
    <view wx:if="{{loading}}" class="hero">
      <view class="hero-eyebrow">
        <view class="sk-dark" style="width:80rpx;height:28rpx;" />
        <view class="eyebrow-line" />
        <view class="sk-dark" style="width:70rpx;height:20rpx;" />
      </view>
      <view class="hero-content">
        <view class="hero-cover sk-dark" />
        <view class="hero-info">
          <view class="sk-dark" style="width:200rpx;height:36rpx;margin-bottom:14rpx;" />
          <view class="sk-dark" style="width:150rpx;height:22rpx;margin-bottom:24rpx;" />
          <view class="sk-dark" style="width:90rpx;height:64rpx;" />
        </view>
      </view>
      <view class="hero-bar-row">
        <view class="sk-dark" style="width:100%;height:10rpx;" />
      </view>
    </view>
    <!-- real -->
    <view wx:elif="{{hero}}" class="hero" bindtap="onHeroTap">
      <view class="hero-eyebrow">
        <view class="week-badge"><text>评分最高</text></view>
        <view class="eyebrow-line" />
        <text class="eyebrow-date">Barscope</text>
      </view>
      <view class="hero-content">
        <view class="hero-cover">
          <image wx:if="{{hero.coverUrl}}" class="cover-img" src="{{hero.coverUrl}}" mode="aspectFill" />
          <view wx:else class="cover-grid">
            <view class="cover-block b1" />
            <view class="cover-block b2" />
            <view class="cover-block b3" />
            <view class="cover-block b4" />
          </view>
        </view>
        <view class="hero-info">
          <text class="hero-title">{{hero.title}}</text>
          <text class="hero-artist">{{hero.artist}} · {{hero.year}}</text>
          <view class="hero-score-row">
            <text class="hero-score">{{hero.score}}</text>
            <text class="hero-score-max">/5</text>
            <text class="hero-score-label">TOP</text>
          </view>
        </view>
      </view>
      <view class="hero-bar-row">
        <score-bar score="{{hero.score}}" maxScore="{{5}}" />
      </view>
    </view>

    <!-- ── SECTION 01: CHART TOP 5 ────────────────────────────────── -->
    <view class="section-block">
      <section-header num="01" title="总榜 · TOP 10" bind:more="onChartMore" />
      <!-- skeleton -->
      <view wx:if="{{loading}}" class="chart-list">
        <view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="skel-row">
          <view class="sk" style="width:40rpx;height:40rpx;flex-shrink:0;" />
          <view class="sk" style="width:92rpx;height:92rpx;flex-shrink:0;" />
          <view class="skel-info">
            <view class="sk" style="width:65%;height:26rpx;" />
            <view class="sk" style="width:50%;height:20rpx;" />
          </view>
          <view class="sk" style="width:40rpx;height:34rpx;flex-shrink:0;" />
        </view>
      </view>
      <!-- real -->
      <view wx:else class="chart-list">
        <view
          wx:for="{{chartItems}}"
          wx:key="rank"
          class="chart-item"
          bindtap="onAlbumTap"
          data-id="{{item.albumId}}"
        >
          <text class="chart-rank {{item.rank <= 3 ? 'top3' : ''}}">{{item.rank}}</text>
          <view class="chart-cover">
            <image wx:if="{{item.coverUrl}}" class="cover-img" src="{{item.coverUrl}}" mode="aspectFill" />
            <view wx:else class="cover-pat">
              <view /><view /><view />
              <view /><view /><view />
              <view /><view /><view />
            </view>
          </view>
          <view class="chart-info">
            <text class="chart-title">{{item.title}}</text>
            <view class="chart-meta">
              <text>{{item.artist}}</text>
              <view class="meta-dot" />
              <text>{{item.year}}</text>
            </view>
          </view>
          <view class="chart-score-col">
            <text class="chart-score">{{item.score}}</text>
            <view class="mini-bar">
              <view class="mini-bar-fill" style="width: {{item.scoreFill}}" />
            </view>
            <text class="chart-trend {{item.trend}}">{{item.trendText}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ── SECTION 02: NEW RELEASES ────────────────────────────────── -->
    <view class="section-block">
      <section-header num="02" title="本月新碟" bind:more="onReleasesMore" />
      <!-- skeleton -->
      <view wx:if="{{loading}}" class="grid2">
        <view wx:for="{{[1,2]}}" wx:key="*this" class="skel-cell">
          <view class="sk" style="width:80rpx;height:56rpx;margin-bottom:12rpx;" />
          <view class="sk" style="width:100%;aspect-ratio:1;margin-bottom:16rpx;" />
          <view class="sk" style="width:80%;height:24rpx;margin-bottom:8rpx;" />
          <view class="sk" style="width:60%;height:20rpx;" />
        </view>
      </view>
      <!-- real -->
      <view wx:else class="grid2">
        <view
          wx:for="{{newReleases}}"
          wx:key="rank"
          class="grid2-cell"
          bindtap="onAlbumTap"
          data-id="{{item.albumId}}"
        >
          <text class="g2-rank">{{item.rank}}</text>
          <view class="g2-cover">
            <image wx:if="{{item.coverUrl}}" class="cover-img" src="{{item.coverUrl}}" mode="aspectFill" />
            <view wx:else class="g2-cover-lines">
              <view class="g2-line l1" />
              <view class="g2-line l2" />
              <view class="g2-line l3" />
            </view>
          </view>
          <text class="g2-title">{{item.title}}</text>
          <text class="g2-artist">{{item.artist}} · {{item.year}}</text>
          <view class="g2-score-row">
            <text class="g2-score">{{item.score}}</text>
            <view class="g2-bar">
              <view class="g2-bar-fill" style="width: {{item.scoreFill}}" />
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ── GENRE GRID (static, always shows) ─────────────────────── -->
    <view class="genre-section">
      <view class="genre-hd">
        <text class="genre-hd-title">按风格浏览</text>
        <text class="genre-hd-more" bindtap="onGenreMore">全部风格 →</text>
      </view>
      <view class="genre-grid">
        <view
          wx:for="{{genres}}"
          wx:key="name"
          class="genre-cell"
          bindtap="onGenreTap"
          data-genre="{{item.name}}"
        >
          <text class="genre-name">{{item.name}}</text>
          <text class="genre-count">{{item.count}}</text>
        </view>
      </view>
    </view>

    <!-- ── SECTION 03: RECENT REVIEWS ─────────────────────────────── -->
    <view class="section-block">
      <section-header num="03" title="最新评论" bind:more="onReviewMore" />
      <!-- skeleton -->
      <view wx:if="{{loading}}" class="reviews-list">
        <view wx:for="{{[1,2,3]}}" wx:key="*this" class="review-item">
          <view class="review-header">
            <view class="sk" style="width:60rpx;height:60rpx;flex-shrink:0;" />
            <view class="skel-info">
              <view class="sk" style="width:120rpx;height:24rpx;" />
              <view class="sk" style="width:80rpx;height:20rpx;" />
            </view>
          </view>
          <view class="sk" style="width:100%;height:22rpx;margin-bottom:8rpx;" />
          <view class="sk" style="width:80%;height:22rpx;" />
        </view>
      </view>
      <!-- real -->
      <view wx:else class="reviews-list">
        <view
          wx:for="{{reviews}}"
          wx:key="id"
          class="review-item {{item.userType === 'critic' ? 'is-critic' : ''}}"
        >
          <view class="review-header">
            <view class="review-avatar {{item.userType === 'critic' ? 'is-critic' : ''}}">
              <text>{{item.initial}}</text>
            </view>
            <view class="review-meta">
              <view class="review-name-row">
                <text class="review-user">{{item.userName}}</text>
                <text wx:if="{{item.userType === 'critic'}}" class="critic-badge">乐评人</text>
              </view>
              <text class="review-time">{{item.timeAgo}}</text>
            </view>
            <text class="review-album-badge">{{item.albumTitle}}</text>
            <text class="review-score">{{item.score}}</text>
          </view>
          <text class="review-text">{{item.content}}</text>
          <view class="review-footer">
            <text>❤ {{item.likes}}</text>
            <text class="sep"> | </text>
            <text>💬 {{item.replyCount}}条回复</text>
          </view>
        </view>
      </view>
    </view>

    <!-- STATS STRIP -->
    <view class="stat-strip">
      <view class="stat-cell">
        <view class="stat-num-row">
          <text class="stat-accent">{{totalAlbums}}</text>
        </view>
        <text class="stat-label">收录专辑</text>
      </view>
      <view class="stat-cell stat-mid">
        <view class="stat-num-row">
          <text class="stat-accent">38</text><text class="stat-plain">K</text>
        </view>
        <text class="stat-label">评分用户</text>
      </view>
      <view class="stat-cell">
        <view class="stat-num-row">
          <text class="stat-accent">126</text><text class="stat-plain">K</text>
        </view>
        <text class="stat-label">评论总数</text>
      </view>
    </view>

    <!-- CTA -->
    <view class="cta-section">
      <view class="cta-headline">
        <text>加入韵镜</text>
        <text>留下你的打分</text>
      </view>
      <text class="cta-sub">华语说唱最大评分社区，每一张专辑都值得被认真对待。</text>
      <view class="cta-buttons">
        <view class="btn-primary" bindtap="onRegister"><text>立即注册</text></view>
        <view class="btn-secondary" bindtap="onLearnMore"><text>了解更多</text></view>
      </view>
    </view>

  </scroll-view>

  <bottom-nav selected="{{0}}" />
</view>
