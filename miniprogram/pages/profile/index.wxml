<view class="page {{themeClass}}">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px"><view class="topbar-left"><text class="topbar-title">PROFILE</text><view class="theme-switch" bindtap="onToggleTheme"><view class="theme-switch-item {{themeMode === 'light' ? 'active' : ''}}"><text class="theme-switch-icon">☀</text></view><view class="theme-switch-divider"></view><view class="theme-switch-item {{themeMode === 'dark' ? 'active' : ''}}"><text class="theme-switch-icon">☾</text></view></view></view></view>
  <view wx:if="{{!isLoggedIn}}" class="gate-content"><view class="vinyl-gate-disc"><view class="vinyl-gate-label"><text class="gate-disc-icon">○</text></view></view><text class="gate-title">登录查看个人主页</text><text class="gate-sub">授权头像和昵称，追踪你的评分记录</text><view class="gate-btn" bindtap="onLogin"><text>微信登录</text></view></view>
  <scroll-view wx:else class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{userInfo.coverUrl}}" class="cover-banner"><image class="cover-banner-img" src="{{userInfo.coverUrl}}" mode="aspectFill" /></view>
    <view class="user-card"><view class="user-avatar vinyl-disc"><image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" /><block wx:else><view class="vinyl-disc-center"><text class="avatar-initial">{{userInfo.nickName[0]}}</text></view><view class="vinyl-disc-spindle" /></block></view><view class="user-info-col"><text class="user-name">{{userInfo.nickName}}</text><view wx:if="{{isCritic}}" class="critic-badge-wrap"><text class="critic-badge">乐评人</text></view><text wx:if="{{userInfo.bio}}" class="user-bio">{{userInfo.bio}}</text></view></view>
    <view class="stat-strip"><view class="stat-cell stat-badge" bindtap="onMyReviews"><text class="stat-num">{{reviews.length}}</text><text class="stat-lbl">评论 →</text></view><view class="stat-cell stat-badge" bindtap="onMyFollowers"><text class="stat-num">{{followerCount}}</text><text class="stat-lbl">粉丝 →</text></view><view class="stat-cell"><text class="stat-num">{{likesReceived}}</text><text class="stat-lbl">获赞</text></view><view class="stat-cell stat-badge" bindtap="onViewAllBadges"><text class="stat-num">{{earnedBadgeCount}}</text><text class="stat-lbl">徽章 →</text></view></view>
    <view class="side-row"><text class="side-text">SIDE A — 我的</text></view>
    <view class="menu-row" bindtap="onEditWeChatProfile"><text class="menu-label">个人信息</text><text class="menu-arrow">→</text></view><view class="menu-row" bindtap="onNotifications"><text class="menu-label">通知中心</text><view wx:if="{{unreadCount > 0}}" class="pending-badge"><text class="pending-num">{{unreadCount}}</text></view><text class="menu-arrow">→</text></view><view class="menu-row" bindtap="onMyFollowers"><text class="menu-label">我的粉丝</text><text wx:if="{{followerCount > 0}}" class="menu-count">{{followerCount}}</text><text class="menu-arrow">→</text></view><view class="menu-row" bindtap="onMyLikes"><text class="menu-label">我的点赞</text><text class="menu-arrow">→</text></view><view class="menu-row" bindtap="onMyFavorites"><text class="menu-label">我的收藏</text><text wx:if="{{favCount > 0}}" class="menu-count">{{favCount}}</text><text class="menu-arrow">→</text></view><view wx:if="{{approvedEditorials.length > 0}}" class="menu-row" bindtap="onEditorialProjects"><text class="menu-label">我的专题编辑</text><text class="menu-count">{{approvedEditorials.length}} 个已通过</text><text class="menu-arrow">→</text></view><view class="menu-row" bindtap="onSettingsTap"><text class="menu-label">偏好设置</text><text class="menu-arrow">→</text></view><view class="menu-row" bindtap="onFeedback"><text class="menu-label">点播台</text><text class="menu-arrow">→</text></view><view class="menu-row" bindtap="onArtistDataContribution"><text class="menu-label">艺人资料共建</text><text class="menu-count">审核制</text><text class="menu-arrow">→</text></view><view class="menu-row" bindtap="onCriticApplication"><text class="menu-label">乐评人申请</text><text wx:if="{{isCritic}}" class="menu-count">已认证</text><text wx:elif="{{isAdmin}}" class="menu-count">测试</text><text class="menu-arrow">→</text></view><view class="menu-row" bindtap="onArtistVerification"><text class="menu-label">艺人入驻申请</text><text wx:if="{{artistVerificationStatus === 'approved'}}" class="menu-count">已认证</text><text wx:elif="{{artistVerificationStatus === 'pending'}}" class="menu-count">审核中</text><text class="menu-arrow">→</text></view>
    <block wx:if="{{isAdmin}}"><view class="side-row b"><text class="side-text">SIDE B — ADMIN</text></view><view class="menu-row" bindtap="onAdminCms"><text class="menu-icon">▣</text><text class="menu-label">BARSCOPE CMS</text><text class="menu-count">CONTROL ROOM</text><view wx:if="{{reviewCenterCount + albumAdminCount > 0}}" class="pending-badge"><text class="pending-num">{{reviewCenterCount + albumAdminCount}}</text></view><text class="menu-arrow">→</text></view><view class="menu-row" bindtap="onAdminManagement"><text class="menu-label">管理员管理</text><text class="menu-arrow">→</text></view></block>
    <view class="logout-row" bindtap="onLogout"><text class="logout-text">退出登录</text></view>
  </scroll-view><bottom-nav selected="{{4}}" />
</view>