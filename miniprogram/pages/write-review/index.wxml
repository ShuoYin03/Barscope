<view class="page {{themeClass}}">
  <!-- TOPBAR -->
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <view class="back-btn" bindtap="onBack">
      <text class="back-arrow">←</text>
    </view>
    <text class="topbar-title">WRITE REVIEW</text>
  </view>

  <!-- ALBUM SUBTITLE -->
  <view class="album-sub">{{albumTitle || '专辑'}}</view>

  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="content-inner">

    <!-- TURNTABLE — decorative easter egg, independent from rating -->
    <view class="dial-section">
      <view class="vinyl-player">
        <view class="turntable-base">
          <view class="deck-fader"><view class="deck-fader-grip" /></view>
          <view class="deck-knob deck-knob-power"><view class="deck-knob-mark" /></view>
          <view class="deck-square-btn" />
          <view class="deck-knob deck-knob-speed"><view class="deck-knob-mark" /></view>
          <view class="deck-foot deck-foot-tl" />
          <view class="deck-foot deck-foot-tr" />
          <view class="deck-foot deck-foot-bl" />
          <view class="deck-foot deck-foot-br" />
        </view>
        <view class="vinyl-score-disc {{needleOnRecord ? 'is-lit is-spinning' : ''}}">
          <image wx:if="{{albumCoverUrl}}" class="vinyl-score-cover" src="{{albumCoverUrl}}" mode="aspectFill" />
          <view class="vinyl-score-spindle" />
        </view>
        <view
          class="tonearm {{needleOnRecord ? 'is-dropped' : ''}}"
          catchtouchstart="onTonearmTouchStart"
          catchtouchmove="onTonearmTouchMove"
          catchtouchend="onTonearmTouchEnd"
        >
          <view class="tonearm-hub" />
          <view class="tonearm-pivot" />
          <view class="tonearm-arm {{tonearmDragging ? 'is-dragging' : ''}}" style="transform: rotate({{tonearmAngle}}deg)">
            <view class="tonearm-head" />
          </view>
        </view>
      </view>

      <text class="dial-hint">{{needleOnRecord ? '唱片播放中 · 拖动唱针可停止' : '拖动唱针可播放唱片（彩蛋）'}}</text>

      <!-- Rating remains available regardless of tonearm state -->
      <view class="score-axis-wrap">
        <text class="dial-hint">{{rating > 0 ? ratingDisplay + ' / 10' : '拖动评分轴选择分数'}}</text>
        <slider
          class="score-axis"
          min="1"
          max="10"
          step="0.5"
          value="{{sliderValue}}"
          activeColor="#5E9BFA"
          backgroundColor="#DCE5F2"
          block-color="#F2EBDD"
          block-size="32"
          bindchanging="onRateChange"
          bindchange="onRateChange"
        />
        <view class="score-axis-labels">
          <text>1</text>
          <text>5.5</text>
          <text>10</text>
        </view>
        <view class="score-axis-note">
          <text>每格 0.5 分</text>
        </view>
      </view>
    </view>

    <!-- CONTENT INPUT -->
    <view class="input-section">
      <text class="input-label">评语</text>
      <textarea
        class="content-input"
        placeholder="写下你对这张专辑的感受..."
        placeholder-class="content-ph"
        bindinput="onContentInput"
        maxlength="500"
        auto-height
      />
      <text class="char-count {{content.length > 0 && content.length < 10 ? 'char-count-warn' : ''}}">{{content.length}}/500{{content.length < 10 ? '（至少10字）' : ''}}</text>
    </view>

    </view>
  </scroll-view>

  <!-- SUBMIT BAR -->
  <view class="submit-bar">
    <view class="submit-btn {{(rating > 0 && content.length >= 10 && !submitting) ? '' : 'disabled'}}" bindtap="onSubmit">
      <text>{{submitting ? '发布中...' : '提交评论'}}</text>
    </view>
  </view>
</view>