<view class="page"><view class="topbar" style="padding-top: {{statusBarHeight}}px"><text class="back" bindtap="onBack">←</text><text class="title">DATE BACKFILL</text></view><view class="content"><text class="eyebrow">DATABASE MAINTENANCE</text><text class="heading">回填发行日期</text><text class="desc">为缺少发行日期的专辑补全网易云日期。</text><view class="stats"><view><text class="num">{{processed}}</text><text class="label">已扫描</text></view><view><text class="num accent">{{updated}}</text><text class="label">已写入</text></view><view><text class="num">{{failed}}</text><text class="label">未获取</text></view></view><text class="status">{{message}}</text><view class="run {{running ? 'disabled' : ''}}" bindtap="onRun"><text>{{running ? '回填进行中…' : done ? '再次检查' : '开始回填'}}</text></view></view></view>