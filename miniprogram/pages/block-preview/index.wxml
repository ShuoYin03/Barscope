<view class="page {{themeClass}}">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <text class="back" bindtap="onBack">←</text>
    <view><text class="brand">BLOCKS</text><text class="sub">区块类型预览</text></view>
  </view>

  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="legend">
      <text class="legend-title">当前共 {{legend.length}} 种区块类型</text>
      <view class="legend-row">
        <view wx:for="{{legend}}" wx:key="key" class="legend-chip"><text>{{item.label}}</text></view>
      </view>
    </view>

    <view class="preview-head">
      <text class="preview-title">下面按顺序演示每种区块的样式</text>
    </view>

    <article-blocks blocks="{{blocks}}" />

    <view class="end-mark"><text>— END OF PREVIEW —</text></view>
  </scroll-view>
</view>
