<view class="page {{themeClass}}">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <text class="back" bindtap="onBack">←</text>
    <text class="brand">FEATURES</text>
  </view>

  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}" wx:if="{{article}}" bindscrolltolower="onCommunityReachBottom">
    <view class="article-head">
      <text class="category">{{article.category}} · {{isTop10 ? 'COMMUNITY VOTE' : 'OPEN CALL'}}</text>
      <text class="title">{{article.title}}</text>
      <text class="intro">{{article.intro}}</text>
    </view>

    <view class="rule" />

    <block wx:if="{{isTop10}}">
      <view class="top10-tabs">
        <view class="top10-tab {{top10Tab === 'mine' ? 'active' : ''}}" bindtap="onTop10TabTap" data-tab="mine"><text>我的榜单</text></view>
        <view class="top10-tab {{top10Tab === 'community' ? 'active' : ''}}" bindtap="onTop10TabTap" data-tab="community"><text>社区榜单</text></view>
      </view>
      <view class="top10-status">
        <text class="top10-status-text">{{votingOpen ? '投票进行中 · 截止 2026-12-31' : '投票已截止'}}</text>
        <text class="top10-status-count">{{voterTotal}} 人已投票</text>
      </view>

      <block wx:if="{{top10Tab === 'mine'}}">
        <view wx:if="{{myLoading}}" class="top10-empty"><text>加载中…</text></view>
        <block wx:else>
          <view wx:if="{{myEntries.length === 0}}" class="top10-empty"><text>还没有选择专辑，点击下方添加</text></view>
          <view wx:for="{{myEntries}}" wx:key="albumId" class="top10-entry-row">
            <text class="top10-rank">{{index + 1}}</text>
            <image class="top10-cover" src="{{item.coverUrl}}" mode="aspectFill" />
            <view class="top10-entry-body">
              <text class="top10-entry-title">{{item.title}}</text>
              <text class="top10-entry-artist">{{item.artist}}</text>
              <textarea class="top10-note-input" value="{{item.note}}" data-index="{{index}}" bindinput="onEntryNoteInput" maxlength="200" placeholder="写下你选择这张专辑的理由（选填）" placeholder-style="color:#6f6762" auto-height />
            </view>
            <view class="top10-entry-actions">
              <view class="top10-move {{index === 0 ? 'disabled' : ''}}" data-index="{{index}}" data-dir="up" bindtap="onMoveEntry"><text>↑</text></view>
              <view class="top10-move {{index === myEntries.length - 1 ? 'disabled' : ''}}" data-index="{{index}}" data-dir="down" bindtap="onMoveEntry"><text>↓</text></view>
              <view class="top10-remove" data-index="{{index}}" bindtap="onRemoveEntry"><text>×</text></view>
            </view>
          </view>

          <view wx:if="{{myEntries.length < 10 && votingOpen}}" class="top10-add-btn" bindtap="onOpenPicker">
            <text>+ 添加专辑（{{myEntries.length}}/10）</text>
          </view>
          <view class="top10-save {{mySaving ? 'disabled' : ''}}" bindtap="onSaveBallot">
            <text>{{mySaving ? '保存中…' : '保存我的榜单'}}</text>
          </view>
        </block>
      </block>

      <block wx:else>
        <view wx:if="{{communityLoading && communityList.length === 0}}" class="top10-empty"><text>加载中…</text></view>
        <view wx:elif="{{communityList.length === 0}}" class="top10-empty"><text>还没有人公开榜单，来做第一个吧</text></view>
        <block wx:else>
          <view wx:for="{{communityList}}" wx:for-item="ballot" wx:key="_id" class="top10-card">
            <view class="top10-card-head">
              <view class="top10-card-avatar"><image wx:if="{{ballot.userAvatarUrl}}" class="top10-card-avatar-img" src="{{ballot.userAvatarUrl}}" mode="aspectFill" /><text wx:else>{{ballot.userNickName[0]}}</text></view>
              <text class="top10-card-name">{{ballot.userNickName}}</text>
              <text class="top10-card-date">{{ballot.updatedAtDisplay}}</text>
            </view>
            <view wx:for="{{ballot.entries}}" wx:key="albumId" class="top10-card-entry">
              <text class="top10-card-rank">{{index + 1}}</text>
              <view class="top10-card-entry-body">
                <text class="top10-card-entry-title">{{item.title}} <text class="top10-card-entry-artist">{{item.artist}}</text></text>
                <text wx:if="{{item.note}}" class="top10-card-note">{{item.note}}</text>
              </view>
            </view>
          </view>
          <view wx:if="{{communityLoading}}" class="top10-empty"><text>加载中…</text></view>
          <view wx:elif="{{!communityHasMore}}" class="top10-empty"><text>── 共 {{communityTotal}} 人 ──</text></view>
        </block>
      </block>
    </block>

    <view wx:else class="form">
      <view class="field">
        <view class="field-head"><text class="field-label">项目标题 *</text><text class="field-count">{{proposalTitle.length}} / 80</text></view>
        <input class="input" data-field="proposalTitle" value="{{proposalTitle}}" bindinput="onFieldInput" maxlength="80" placeholder="{{article.proposalPlaceholder}}" placeholder-style="color:#6f6762" />
      </view>

      <view class="field">
        <view class="field-head"><text class="field-label">项目想法 *</text><text class="field-count">{{idea.length}} / 1200</text></view>
        <textarea class="textarea idea" data-field="idea" value="{{idea}}" bindinput="onFieldInput" maxlength="1200" placeholder="{{article.ideaPlaceholder}}" placeholder-style="color:#6f6762" />
      </view>

      <view class="field">
        <view class="field-head"><text class="field-label">大纲或补充说明</text><text class="field-count">{{outline.length}} / 1600</text></view>
        <textarea class="textarea" data-field="outline" value="{{outline}}" bindinput="onFieldInput" maxlength="1600" placeholder="{{article.outlinePlaceholder}}" placeholder-style="color:#6f6762" />
      </view>

      <view class="field">
        <text class="field-label">微信号 *</text>
        <input class="input" data-field="wechat" value="{{wechat}}" bindinput="onFieldInput" maxlength="80" placeholder="用于编辑部联系，请确认填写正确" placeholder-style="color:#6f6762" />
      </view>

      <view class="field">
        <text class="field-label">作品或社交主页链接</text>
        <input class="input" data-field="links" value="{{links}}" bindinput="onFieldInput" maxlength="500" placeholder="公众号、豆瓣、B站、小红书或其他作品链接" placeholder-style="color:#6f6762" />
      </view>

      <view class="privacy-note">
        <text>提交内容和微信号不会公开，仅供编辑部审核并联系你。</text>
      </view>

      <view class="submit {{submitting ? 'disabled' : ''}}" bindtap="onSubmit">
        <text>{{submitting ? '提交中…' : '提交企划 PROPOSAL'}}</text>
      </view>
    </view>

    <view class="end-mark"><text>{{isTop10 ? '— COMMUNITY VOTE —' : '— OPEN CALL —'}}</text></view>
  </scroll-view>

  <view wx:if="{{pickerVisible}}" class="picker-mask" bindtap="onClosePicker">
    <view class="picker-sheet" catchtap="noop">
      <view class="picker-handle" />
      <text class="picker-title">添加 2026 年专辑</text>
      <input class="picker-input" value="{{pickerKeyword}}" bindinput="onPickerInput" placeholder="搜索专辑名 / 歌手" placeholder-style="color:#6f6762" focus />
      <scroll-view class="picker-results" scroll-y>
        <view wx:if="{{pickerLoading}}" class="picker-empty"><text>搜索中…</text></view>
        <view wx:elif="{{pickerResults.length === 0}}" class="picker-empty"><text>{{pickerKeyword ? '没有匹配的 2026 年专辑' : '2026 年发行的专辑会显示在这里'}}</text></view>
        <block wx:else>
          <view wx:for="{{pickerResults}}" wx:key="_id" class="picker-row" bindtap="onPickerSelect" data-id="{{item._id}}">
            <image class="picker-cover" src="{{item.coverUrl}}" mode="aspectFill" />
            <view class="picker-row-info">
              <text class="picker-row-title">{{item.title}}</text>
              <text class="picker-row-artist">{{item.artist}}</text>
            </view>
          </view>
        </block>
      </scroll-view>
      <view class="picker-cancel" bindtap="onClosePicker"><text>取消</text></view>
    </view>
  </view>
</view>
