<view class="page">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px"><text class="topbar-title">DISCOVER</text><text class="topbar-filter">⊞</text></view>
  <view class="search-wrap"><view class="search-inner"><text class="search-icon">⌕</text><input class="search-input" placeholder="搜索专辑、歌手" placeholder-class="search-ph" bindinput="onSearch" value="{{keyword}}" /></view></view>
  <view class="view-switch"><view class="switch-chip {{viewMode === 'albums' ? 'active' : ''}}" bindtap="onViewModeTap" data-mode="albums"><text>ALBUMS</text></view><view class="switch-chip {{viewMode === 'artists' ? 'active' : ''}}" bindtap="onViewModeTap" data-mode="artists"><text>ARTISTS</text></view></view>
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="onAlbumScrollToLower" lower-threshold="160">
    <block wx:if="{{viewMode === 'albums'}}"><view class="side-row"><text class="side-text">SIDE A — 年份 YEAR</text><view class="side-rule" /></view><view class="year-stamps"><view wx:for="{{years}}" wx:key="name" class="year-stamp {{activeYear === item.name ? 'active' : ''}}" bindtap="onYearTap" data-year="{{item.name}}"><text class="year-name">{{item.name}}</text></view></view><view class="side-row"><text class="side-text">SIDE B — {{activeYear ? activeYear : '全部'}}{{activeMonth ? '.' + activeMonth : ''}} · {{loading ? '加载中' : total + ' 张'}}</text><view class="side-rule" /></view><view wx:if="{{loading}}" class="album-list"><view wx:for="{{[1,2,3,4,5,6,7,8]}}" wx:key="*this" class="skel-row"><view class="sk" style="width:128rpx;height:128rpx;border-radius:50%;flex-shrink:0;" /><view class="skel-info"><view class="sk" style="width:70%;height:26rpx;" /><view class="sk" style="width:55%;height:20rpx;" /><view class="sk" style="width:40%;height:18rpx;" /></view><view class="sk" style="width:40rpx;height:34rpx;flex-shrink:0;" /></view></view><view wx:elif="{{list.length === 0}}" class="empty-state"><text class="empty-text">没有找到相关专辑</text></view><view wx:else class="album-list with-month-index"><view wx:for="{{list}}" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{item.id}}"><view class="album-disc"><view class="disc-label"><image wx:if="{{item.coverUrl}}" class="cover-img" src="{{item.coverUrl}}" mode="aspectFill" /><view wx:else class="disc-label-fallback" /></view><view class="disc-spindle" /></view><view class="album-info"><text class="album-title">{{item.title}}</text><text class="album-artist" catchtap="onArtistTap" data-artist-id="{{item.neteaseArtistId}}" data-artist="{{item.primaryArtist}}">{{item.artist}} · {{item.releaseDisplay}}</text></view><text class="album-score">{{item.score}}</text></view><view wx:if="{{loadingMore}}" class="load-more"><text>加载更多专辑…</text></view><view wx:elif="{{!albumHasMore}}" class="load-more"><text>已显示全部 {{total}} 张专辑</text></view></view></block>
    <block wx:else><view class="side-row"><text class="side-text">SIDE A — LABEL 厂牌</text><view class="side-rule" /></view><scroll-view scroll-x show-scrollbar="{{false}}" class="brand-scroll"><view class="brand-stamps brand-stamps-horizontal"><view wx:for="{{brandCards}}" wx:key="name" class="brand-stamp {{activeBrand === item.name ? 'active' : ''}}" bindtap="onBrandTap" data-brand="{{item.name}}"><text class="brand-name">{{item.name}}</text><text class="brand-count">{{item.count}}</text></view></view></scroll-view><view class="side-row artist-result-title"><text class="side-text">SIDE B — {{activeBrand}} · {{artistLoading ? '加载中' : artistTotal + ' 位'}}</text><view class="side-rule" /></view><view wx:if="{{artistLoading}}" class="artist-grid"><view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="artist-tile"><view class="sk" style="width:110rpx;height:110rpx;border-radius:50%;" /><view class="sk" style="width:100rpx;height:24rpx;margin-top:16rpx;" /></view></view><view wx:elif="{{artistVisibleList.length === 0}}" class="empty-state"><text class="empty-text">这个分类暂无艺人</text></view><view wx:elif="{{activeBrand === '全部'}}" class="artist-all-list"><view wx:for="{{artistVisibleList}}" wx:key="artistId" class="artist-all-row" bindtap="onArtistTap" data-artist-id="{{item.artistId}}" data-artist="{{item.artistName}}"><view class="artist-all-avatar"><image wx:if="{{item.picUrl}}" class="artist-all-img" src="{{item.picUrl}}" mode="aspectFill" /><text wx:else class="artist-all-initial">{{item.letter}}</text></view><view class="artist-all-info"><text class="artist-all-name">{{item.artistName}}</text><text class="artist-all-meta">{{item.albumSize || 0}} 张专辑</text></view><text class="artist-all-arrow">›</text></view></view><view wx:else class="artist-grid"><view wx:for="{{artistVisibleList}}" wx:key="artistId" class="artist-tile" bindtap="onArtistTap" data-artist-id="{{item.artistId}}" data-artist="{{item.artistName}}"><view class="artist-tile-avatar"><image wx:if="{{item.picUrl}}" class="artist-tile-img" src="{{item.picUrl}}" mode="aspectFill" /><text wx:else class="artist-tile-initial">{{item.letter}}</text></view><text class="artist-tile-name">{{item.artistName}}</text><text class="artist-tile-meta">{{item.albumSize || 0}} 张专辑</text></view></view></block>
  </scroll-view>
  <view wx:if="{{viewMode === 'albums' && activeYear && activeYear !== '2010s' && activeYear !== '2000s'}}" class="month-index"><view wx:for="{{months}}" wx:key="*this" class="month-index-item {{activeMonth === item ? 'active' : ''}}" bindtap="onMonthTap" data-month="{{item}}"><text>{{item}}</text></view></view><bottom-nav selected="{{2}}" />
</view>