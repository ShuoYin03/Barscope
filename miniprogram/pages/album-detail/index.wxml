<view class="page">

  <!-- LOADING -->
  <view wx:if="{{loading}}" class="loading-state" style="padding-top: {{topbarHeight}}px">
    <text class="loading-text">加载中…</text>
  </view>

  <scroll-view wx:elif="{{album}}" class="content" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- BACK BAR -->
    <view class="back-bar" style="padding-top: {{statusBarHeight}}px" bindtap="onBack">
      <text class="back-icon">←</text>
      <text class="back-label">ALBUM</text>
    </view>

    <!-- HERO: vinyl disc, cover as center label -->
    <view class="hero">
      <view class="hero-disc">
        <view class="disc-label">
          <image wx:if="{{album.coverUrl}}" class="cover-img" src="{{album.coverUrl}}" mode="aspectFill" />
          <view wx:else class="disc-label-score">
            <text class="disc-score-num">{{album.avgScore}}</text>
            <text class="disc-score-sub">BARSCOPE</text>
          </view>
        </view>
        <view class="disc-spindle" />
      </view>
      <text class="hero-title">{{album.title}}</text>
      <text class="hero-meta">{{album.artist}} · {{album.year}}</text>

      <!-- stat strip -->
      <view class="stat-strip">
        <view class="stat-cell">
          <text class="stat-num">{{album.avgScore}}</text>
          <text class="stat-label">评分</text>
        </view>
        <view class="stat-cell">
          <text class="stat-num">{{album.reviewCount}}</text>
          <text class="stat-label">评论</text>
        </view>
        <view class="stat-cell">
          <text class="stat-num">{{album.year}}</text>
          <text class="stat-label">年份</text>
        </view>
      </view>
    </view>

    <!-- INFO: genre chips + score bar -->
    <view class="info-block">
      <view wx:if="{{album.genres.length > 0}}" class="genre-chips">
        <text
          wx:for="{{album.genres}}"
          wx:key="*this"
          class="genre-chip {{index === 0 ? 'primary' : ''}}"
        >{{item}}</text>
      </view>
      <view class="score-bar-wrap">
        <view class="score-bar-track">
          <view class="score-bar-fill" style="width: {{album.scoreFill}}" />
        </view>
      </view>
    </view>

    <!-- REVIEWS -->
    <view class="reviews-section">
      <view class="reviews-head">
        <text class="reviews-label">SIDE B — 乐评 REVIEWS</text>
        <text class="reviews-count">{{reviews.length}}条</text>
      </view>
      <view wx:if="{{reviews.length === 0}}" class="no-reviews">
        <text class="no-reviews-text">还没有评论，来写第一条吧</text>
      </view>
      <view wx:for="{{reviews}}" wx:key="_id">
        <review-item review="{{item}}" bind:like="onLike" />
      </view>
    </view>

  </scroll-view>

  <!-- not found -->
  <view wx:elif="{{!loading}}" class="loading-state">
    <text class="loading-text">专辑不存在</text>
  </view>

  <!-- FIXED BOTTOM: write review + fav -->
  <view wx:if="{{album}}" class="bottom-bar">
    <view class="btn-fav {{isFavorited ? 'is-fav' : ''}}" bindtap="onFavoriteToggle">
      <text class="btn-fav-icon">{{isFavorited ? '★' : '☆'}}</text>
    </view>
    <view class="btn-write" bindtap="onWriteReview">
      <text>＋ 写评论</text>
    </view>
  </view>

</view>
