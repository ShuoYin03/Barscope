<view class="bottom-nav">
  <view
    wx:for="{{tabs}}"
    wx:key="path"
    class="nav-item {{selected === index ? 'active' : ''}}"
    bindtap="onTap"
    data-path="{{item.path}}"
    data-index="{{index}}"
  >
    <view class="nav-indicator"></view>
    <image class="nav-icon-img" src="{{selected === index ? item.iconActive : item.icon}}" mode="aspectFit"/>
    <text class="nav-label">{{item.text}}</text>
  </view>
</view>
