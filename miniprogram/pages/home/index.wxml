<view class="page-wrapper">

  <!-- TOPBAR -->
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <view class="logo-col">
      <text class="logo-main">BARSCOPE</text>
      <text class="logo-sub">中文说唱</text>
    </view>
    <text class="logo-search" bindtap="onSearchTap">⌕</text>
  </view>

  <!-- SCROLLABLE CONTENT -->
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- TICKER -->
    <ticker songs="{{tickerSongs}}" />

    <!-- ── HERO — vinyl record, score on orange label (H-A) ─────────── -->
    <view wx:if="{{loading}}" class="hero-banner hero-banner-sk" />
    <view wx:elif="{{hero}}" class="hero-banner" bindtap="onHeroTap">
      <view class="vinyl-hero-disc">
        <view class="vinyl-hero-label">
          <text class="vinyl-label-score-num">{{hero.score}}</text>
          <text class="vinyl-label-score-sub">BARSCOPE</text>
        </view>
        <view class="vinyl-hero-spindle" />
      </view>
      <view class="hero-info">
        <text class="hero-title">{{hero.title}}</text>
        <text class="hero-meta">{{hero.artist}} · {{hero.year}}</text>
      </view>
    </view>

    <!-- ── SIDE A — TOP CHARTS (H-A text rows) ────────────────────── -->
    <view class="section-block">
      <view class="side-a-rule" />
      <view class="side-a-head">
        <text class="side-a-label">SIDE A — TOP CHARTS</text>
      </view>
      <view wx:if="{{loading}}" class="ca-list">
        <view class="ca-rows">
          <view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="ca-row">
            <view class="sk" style="width:48rpx;height:28rpx;flex-shrink:0;" />
            <view class="skel-info" style="flex:1;">
              <view class="sk" style="width:60%;height:24rpx;" />
            </view>
            <view class="sk" style="width:56rpx;height:30rpx;flex-shrink:0;" />
          </view>
        </view>
      </view>
      <view wx:else class="ca-list">
        <view class="ca-rows">
          <view
            wx:for="{{chartItems}}"
            wx:key="rank"
            class="ca-row"
            bindtap="onAlbumTap"
            data-id="{{item.albumId}}"
          >
            <text class="ca-rank {{item.rank === 1 ? 'top' : ''}}">{{item.rank <= 5 ? 'A' + item.rank : 'B' + (item.rank - 5)}}</text>
            <view class="ca-info">
              <text class="ca-title">{{item.title}}</text>
              <text class="ca-artist">{{item.artist}}</text>
            </view>
            <text class="ca-score">{{item.scoreDisplay}}</text>
          </view>
        </view>
        <view class="ca-more" bindtap="onChartMore"><text>更多 →</text></view>
      </view>
    </view>

    <!-- ── SECTION 02: NEW RELEASES ────────────────────────────────── -->
    <view class="section-block">
      <section-header num="02" title="本月新碟" more="{{true}}" bind:more="onReleasesMore" />
      <view wx:if="{{loading}}" class="grid2">
        <view wx:for="{{[1,2]}}" wx:key="*this" class="skel-cell">
          <view class="sk" style="width:80rpx;height:56rpx;margin-bottom:12rpx;" />
          <view class="sk" style="width:100%;aspect-ratio:1;margin-bottom:16rpx;" />
          <view class="sk" style="width:80%;height:24rpx;margin-bottom:8rpx;" />
          <view class="sk" style="width:60%;height:20rpx;" />
        </view>
      </view>
      <view wx:else class="grid2">
        <view
          wx:for="{{newReleases}}"
          wx:key="rank"
          class="grid2-cell"
          bindtap="onAlbumTap"
          data-id="{{item.albumId}}"
        >
          <text class="g2-rank">{{item.rank}}</text>
          <view class="g2-cover">
            <image wx:if="{{item.coverUrl}}" class="cover-img" src="{{item.coverUrl}}" mode="aspectFill" />
            <view wx:else class="vinyl-cover-sq" />
          </view>
          <text class="g2-title">{{item.title}}</text>
          <text class="g2-artist">{{item.artist}} · {{item.year}}</text>
          <view class="g2-score-row">
            <text class="g2-score">{{item.scoreDisplay}}</text>
            <view class="g2-bar">
              <view class="g2-bar-fill" style="width: {{item.scoreFill}}" />
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ── GENRE GRID ─────────────────────────────────────────────── -->
    <view class="genre-section">
      <view class="genre-hd">
        <view class="genre-hd-left">
          <text class="genre-num">03</text>
          <text class="genre-hd-title">按风格浏览</text>
        </view>
        <text class="genre-hd-more" bindtap="onGenreMore">全部 →</text>
      </view>
      <view class="genre-grid">
        <view
          wx:for="{{genres}}"
          wx:key="name"
          class="genre-cell"
          bindtap="onGenreTap"
          data-genre="{{item.name}}"
        >
          <text class="genre-name">{{item.name}}</text>
          <text class="genre-count">{{item.count}}</text>
        </view>
        <view class="genre-cell genre-all" bindtap="onGenreMore">
          <text class="genre-name">全部 →</text>
          <text class="genre-count">{{genres.length}} 类型</text>
        </view>
      </view>
    </view>

    <!-- ── SECTION 04: RECENT REVIEWS ─────────────────────────────── -->
    <view class="section-block">
      <section-header num="04" title="最新评论" more="{{true}}" bind:more="onReviewMore" />
      <view wx:if="{{loading}}" class="reviews-list">
        <view wx:for="{{[1,2,3]}}" wx:key="*this" class="review-item">
          <view class="review-header">
            <view class="sk" style="width:60rpx;height:60rpx;border-radius:50%;flex-shrink:0;" />
            <view class="skel-info">
              <view class="sk" style="width:120rpx;height:24rpx;" />
              <view class="sk" style="width:80rpx;height:20rpx;" />
            </view>
          </view>
          <view class="sk" style="width:100%;height:22rpx;margin-bottom:8rpx;" />
          <view class="sk" style="width:80%;height:22rpx;" />
        </view>
      </view>
      <view wx:else class="reviews-list">
        <view
          wx:for="{{reviews}}"
          wx:key="id"
          class="review-item {{item.userType === 'critic' ? 'is-critic' : ''}}"
        >
          <view class="review-header">
            <view class="review-avatar {{item.userType === 'critic' ? 'is-critic' : ''}}">
              <text>{{item.initial}}</text>
            </view>
            <view class="review-meta">
              <view class="review-name-row">
                <text class="review-user">{{item.userName}}</text>
                <text wx:if="{{item.userType === 'critic'}}" class="critic-badge">乐评人</text>
              </view>
              <text class="review-time">{{item.timeAgo}}</text>
            </view>
            <text class="review-album-badge">{{item.albumTitle}}</text>
            <text class="review-score">{{item.score}}</text>
          </view>
          <text class="review-text">{{item.content}}</text>
          <view class="review-footer">
            <text>❤ {{item.likes}}</text>
            <text class="sep"> | </text>
            <text>💬 {{item.replyCount}}条回复</text>
          </view>
        </view>
      </view>
    </view>

    <!-- STATS STRIP -->
    <view class="stat-strip">
      <view class="stat-cell">
        <view class="stat-num-row">
          <text class="stat-accent">{{totalAlbums}}</text>
        </view>
        <text class="stat-label">收录专辑</text>
      </view>
      <view class="stat-cell stat-mid">
        <view class="stat-num-row">
          <text class="stat-accent">38</text><text class="stat-plain">K</text>
        </view>
        <text class="stat-label">评分用户</text>
      </view>
      <view class="stat-cell">
        <view class="stat-num-row">
          <text class="stat-accent">126</text><text class="stat-plain">K</text>
        </view>
        <text class="stat-label">评论总数</text>
      </view>
    </view>

    <!-- CTA -->
    <view class="cta-section">
      <view class="cta-headline">
        <text>加入韵镜</text>
        <text>留下你的打分</text>
      </view>
      <text class="cta-sub">华语说唱最大评分社区，每一张专辑都值得被认真对待。</text>
      <view class="cta-buttons">
        <view class="btn-primary" bindtap="onRegister"><text>立即注册</text></view>
        <view class="btn-secondary" bindtap="onLearnMore"><text>了解更多</text></view>
      </view>
    </view>

  </scroll-view>

  <bottom-nav selected="{{0}}" />
</view>
