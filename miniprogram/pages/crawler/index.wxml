<view class="page">

  <!-- TOPBAR -->
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <view class="topbar-back" bindtap="onBack">
      <text class="back-arrow">←</text>
    </view>
    <view class="topbar-titles">
      <text class="topbar-title">CRAWLER</text>
      <text class="topbar-sub">MGMT</text>
    </view>
  </view>

  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- STATUS CARD -->
    <view class="card">
      <view class="section-title">运行状态</view>

      <view class="status-row">
        <view class="status-dot {{crawlerTriggering ? 'running' : crawlerStatus.status}}"></view>
        <text class="status-text">
          {{crawlerTriggering ? '启动中' :
            crawlerStatus.status === 'idle'    ? '空闲' :
            crawlerStatus.status === 'pending' ? '等待中' :
            crawlerStatus.status === 'running' ? '运行中' :
            crawlerStatus.status === 'done'    ? '已完成' :
            crawlerStatus.status === 'aborted' ? '已中止' :
            crawlerStatus.status === 'error'   ? '出错' : '—'}}
        </text>
        <view wx:if="{{crawlerStatus.mode && crawlerStatus.status !== 'idle'}}" class="mode-tag">
          <text>{{ crawlerStatus.mode === 'allApproved' ? '全部已批准' :
                   crawlerStatus.mode === 'artist'      ? '艺人 ' + crawlerStatus.param :
                   crawlerStatus.mode === 'album'       ? '专辑 ' + crawlerStatus.param :
                   '裂变' }}</text>
        </view>
        <text wx:if="{{!crawlerTriggering && crawlerStatus.completedAt}}" class="time-text">上次完成: {{crawlerStatus.completedAt}}</text>
      </view>

      <!-- PROGRESS BAR -->
      <block wx:if="{{crawlerTriggering || crawlerStatus.status === 'running' || crawlerStatus.status === 'pending'}}">
        <!-- Determinate: real progress numbers available -->
        <block wx:if="{{!crawlerTriggering && crawlerStatus.status === 'running' && crawlerStatus.progress.totalArtists > 0}}">
          <view class="progress-track">
            <view class="progress-fill" style="width: {{crawlerProgressPct}}%" />
          </view>
          <view class="meta-row">
            <text class="meta">艺人 {{crawlerStatus.progress.processedArtists}}/{{crawlerStatus.progress.totalArtists}}</text>
            <view class="dot"></view>
            <text class="meta">新增专辑 {{crawlerStatus.progress.albumsFound}} 张</text>
          </view>
        </block>
        <!-- Indeterminate: launching or waiting -->
        <block wx:else>
          <view class="progress-track progress-indeterminate"></view>
          <view class="meta-row">
            <text class="meta">{{ crawlerStatus.status === 'pending' && !crawlerTriggering ? '等待本地爬虫认领…' : crawlerTriggering ? '正在启动，请稍候…' : '云端处理中…' }}</text>
          </view>
        </block>

        <!-- LAST LOG LINE — visible without scrolling -->
        <view wx:if="{{crawlerLastLog}}" class="last-log-row">
          <text class="last-log-text">{{crawlerLastLog}}</text>
        </view>
      </block>

      <!-- LAST RUN SUMMARY -->
      <block wx:if="{{!crawlerTriggering && (crawlerStatus.status === 'done' || crawlerStatus.status === 'aborted') && crawlerStatus.lastRunSummary}}">
        <view class="summary-row">
          <view class="summary-chip">
            <text class="summary-num">+{{crawlerStatus.lastRunSummary.newAlbums}}</text>
            <text class="summary-label">新专辑</text>
          </view>
          <view class="summary-chip">
            <text class="summary-num">+{{crawlerStatus.lastRunSummary.newCandidates}}</text>
            <text class="summary-label">新候选</text>
          </view>
        </view>
      </block>

      <!-- ERRORS -->
      <block wx:if="{{!crawlerTriggering && (crawlerStatus.status === 'error' || crawlerStatus.status === 'aborted') && crawlerStatus.lastRunSummary.errors.length > 0}}">
        <view class="error-box">
          <text wx:for="{{crawlerStatus.lastRunSummary.errors}}" wx:key="*this" class="error-line">{{item}}</text>
        </view>
      </block>
    </view>

    <!-- MODE PICKER -->
    <view class="card">
      <view class="section-title">爬取模式</view>
      <view class="mode-grid">
        <view
          wx:for="{{crawlerModes}}"
          wx:key="key"
          class="mode-chip {{crawlerMode === item.key ? 'active' : ''}}"
          bindtap="onCrawlerModeTap"
          data-key="{{item.key}}"
        >
          <text class="mode-label">{{item.label}}</text>
        </view>
      </view>
      <text class="mode-desc">{{crawlerDesc}}</text>
      <input
        wx:if="{{crawlerNeedsId}}"
        class="id-input"
        type="number"
        value="{{crawlerParam}}"
        placeholder="{{crawlerPlaceholder}}"
        placeholder-style="color:#888"
        bindinput="onCrawlerParamInput"
      />
    </view>

    <!-- CONTROLS -->
    <view class="card">
      <view class="section-title">操作</view>
      <view class="actions-row">
        <view
          wx:if="{{crawlerStatus.status === 'running' || crawlerStatus.status === 'pending'}}"
          class="btn-abort"
          bindtap="onCrawlerAbort"
        >
          <text class="btn-text">中止</text>
        </view>
        <view
          wx:else
          class="btn-run {{crawlerTriggering ? 'btn-disabled' : ''}}"
          bindtap="onCrawlerTrigger"
        >
          <text class="btn-text">立即运行</text>
        </view>
        <view class="btn-clear" bindtap="onCrawlerClearLog">
          <text class="btn-text">清除日志</text>
        </view>
      </view>
      <view class="actions-row" style="margin-top:16rpx">
        <view class="btn-clear" style="flex:1" bindtap="onCleanupSingles">
          <text class="btn-text">清除单曲</text>
        </view>
        <view class="btn-clear {{metadataSyncing ? 'btn-disabled' : ''}}" style="flex:1" bindtap="onSyncArtistMetadata">
          <text class="btn-text">{{metadataSyncing ? '同步中' : '同步艺人资料'}}</text>
        </view>
      </view>
    </view>

    <!-- SCHEDULE -->
    <view class="card">
      <view class="section-title">定时设置</view>
      <view class="schedule-row">
        <text class="schedule-label">启用定时</text>
        <switch checked="{{crawlerScheduleEnabled}}" bindchange="onScheduleToggle" color="#C94E25" />
      </view>
      <view wx:if="{{crawlerScheduleEnabled}}" class="interval-row">
        <view class="interval-chip {{crawlerScheduleInterval === 'daily'  ? 'active' : ''}}" bindtap="onScheduleInterval" data-v="daily">
          <text>每天</text>
        </view>
        <view class="interval-chip {{crawlerScheduleInterval === 'weekly' ? 'active' : ''}}" bindtap="onScheduleInterval" data-v="weekly">
          <text>每周</text>
        </view>
      </view>
    </view>

    <!-- LOG -->
    <view class="card card-log">
      <view class="section-title">运行日志</view>
      <view wx:if="{{!crawlerStatus.log || crawlerStatus.log.length === 0}}" class="log-empty">
        <text class="meta">暂无日志</text>
      </view>
      <view wx:else class="log-list">
        <text wx:for="{{crawlerStatus.log}}" wx:key="*this" class="log-line">{{item}}</text>
      </view>
    </view>

  </scroll-view>
</view>
