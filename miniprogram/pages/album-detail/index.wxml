<view class="page">
  <view wx:if="{{loading}}" class="loading-state" style="padding-top: {{topbarHeight}}px"><text class="loading-text">加载中…</text></view>
  <scroll-view wx:elif="{{album}}" class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="back-bar" style="padding-top: {{statusBarHeight}}px" bindtap="onBack"><text class="back-icon">←</text><text class="back-label">ALBUM</text></view>
    <view class="hero">
      <view class="hero-main-row">
        <view class="hero-sleeve-wrap"><view class="hero-vinyl"><view class="hero-vinyl-label" /><view class="hero-vinyl-hole" /></view><view class="hero-sleeve"><image wx:if="{{album.coverUrl}}" class="hero-sleeve-img" src="{{album.coverUrl}}" mode="aspectFill" /><view wx:else class="hero-sleeve-fallback"><text>{{album.avgScore}}</text></view></view></view>
        <view class="hero-info">
          <text class="hero-title">{{album.title}}</text>
          <view class="hero-artist-row" bindtap="onArtistTap"><text class="hero-field-label">歌手</text><text class="hero-artist">{{album.primaryArtist || album.artist}}</text><text class="hero-arrow">›</text></view>
          <view class="hero-date-row"><text class="hero-field-label">发行日期</text><text class="hero-meta-year">{{album.releaseDisplay}}</text></view>
        </view>
      </view>
      <view class="stat-strip"><view class="stat-cell"><text class="stat-num">{{album.avgScore}}</text><text class="stat-label">评分</text></view><view class="stat-cell"><text class="stat-num">{{album.reviewCount}}</text><text class="stat-label">评论</text></view><view class="stat-cell"><text class="stat-num">{{album.tracks.length || '—'}}</text><text class="stat-label">曲目</text></view></view>
    </view>
    <view class="album-section"><view class="section-head"><text class="section-label">SIDE A — 专辑简介</text></view><block wx:if="{{album.description}}"><text class="desc-text">{{descriptionExpanded ? album.description : descriptionPreview}}</text><view wx:if="{{hasLongDescription}}" class="desc-toggle" bindtap="onDescriptionToggle"><text>{{descriptionExpanded ? '收起' : '展开简介'}}</text><text class="desc-toggle-arrow">{{descriptionExpanded ? '↑' : '↓'}}</text></view></block><view wx:elif="{{trackSyncing}}" class="placeholder-row"><text class="placeholder-text">正在同步专辑简介…</text></view><view wx:else class="placeholder-row"><text class="placeholder-text">暂无专辑简介</text></view></view>
    <view class="album-section"><view class="section-head"><text class="section-label">SIDE B — Tracks</text><text class="section-count">{{album.tracks.length}}首</text></view><view wx:if="{{trackSyncing && album.tracks.length === 0}}" class="placeholder-row"><text class="placeholder-text">正在同步曲目…</text></view><view wx:elif="{{album.tracks.length === 0}}" class="placeholder-row"><text class="placeholder-text">暂无曲目信息</text></view><view wx:for="{{album.tracks}}" wx:key="songId" class="track-row"><text class="track-no">{{item.no < 10 ? '0' + item.no : item.no}}</text><view class="track-main"><text class="track-name">{{item.name}}</text><text class="track-artists">{{item.artistText}}</text></view><text wx:if="{{item.guestText}}" class="track-guest">Feat.</text></view></view>
    <view class="album-section"><view class="section-head"><text class="section-label">SIDE C — Featuring Guests</text><text class="section-count">{{album.featuringGuests.length}}人</text></view><view wx:if="{{album.featuringGuests.length === 0}}" class="placeholder-row"><text class="placeholder-text">暂无帮唱嘉宾</text></view><view wx:else class="guest-grid"><view wx:for="{{album.featuringGuests}}" wx:key="name" class="guest-chip guest-chip-link" bindtap="onGuestTap" data-id="{{item.id}}" data-name="{{item.name}}"><text class="guest-name">{{item.name}}</text><text class="guest-count">×{{item.count}}</text><text class="guest-arrow">›</text></view></view></view>
    <view class="reviews-section"><view class="reviews-head"><text class="reviews-label">SIDE D — 乐评 REVIEWS</text><text class="reviews-count">{{reviews.length}}条</text></view><view wx:if="{{reviews.length === 0}}" class="no-reviews"><text class="no-reviews-text">还没有评论，来写第一条吧</text></view><view wx:for="{{reviews}}" wx:key="_id"><review-item review="{{item}}" bind:like="onLike" bind:reply="onReply" /></view></view>
  </scroll-view>
  <view wx:elif="{{!loading}}" class="loading-state"><text class="loading-text">专辑不存在</text></view>
  <view wx:if="{{album}}" class="bottom-bar"><view class="btn-fav {{isFavorited ? 'is-fav' : ''}}" bindtap="onFavoriteToggle"><text class="btn-fav-icon">{{isFavorited ? '★' : '☆'}}</text></view><view class="btn-write" bindtap="onWriteReview"><text>＋ 写评论</text></view></view>
</view>