<view class="page {{themeClass}}">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px"><view class="topbar-back" bindtap="onBack"><text class="back-arrow">←</text></view><view class="topbar-titles"><text class="topbar-title">ARTIST</text><text class="topbar-sub">CANDIDATES</text></view></view>
  <view class="tab-bar"><view wx:for="{{tabs}}" wx:key="key" class="tab-item {{activeTab === item.key ? 'active' : ''}}" bindtap="onTabTap" data-key="{{item.key}}"><text class="tab-label">{{item.label}}</text><view wx:if="{{item.count > 0}}" class="tab-badge {{activeTab === item.key ? 'active' : ''}}"><text class="badge-num">{{item.count}}</text></view></view></view>
  <view class="search-bar"><view class="search-input-wrap"><text class="search-icon">⌕</text><input class="search-input" placeholder="搜索艺人名…" value="{{keyword}}" bindinput="onSearch" placeholder-style="color:#666" /><view wx:if="{{keyword}}" class="search-clear" bindtap="onClearSearch"><text>✕</text></view></view><view class="select-toggle" bindtap="onOpenEditorialTemplates"><text class="select-toggle-text">文章模板</text></view><view wx:if="{{activeTab === 'approved'}}" class="select-toggle {{exporting ? 'disabled' : ''}}" bindtap="onCopyApprovedList"><text class="select-toggle-text">{{exporting ? '导出中' : '复制名单'}}</text></view><view wx:else class="select-toggle {{selectMode ? 'active' : ''}}" bindtap="onToggleSelectMode"><text class="select-toggle-text">{{selectMode ? '取消' : '多选'}}</text></view></view>
  <view wx:if="{{activeTab === 'declined' && !selectMode && list.length > 0}}" class="purge-bar"><view class="purge-btn {{purging ? 'btn-disabled' : ''}}" bindtap="onPurgeDeclined"><text>{{purging ? ('清库中 ' + purgedCount) : '一键清空已拒绝名单'}}</text></view></view>
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}" bindscrolltolower="onReachBottom">
    <block wx:if="{{loading && list.length === 0}}"><view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="card-skeleton"><view class="sk skel-pic"></view><view class="skel-body"><view class="sk skel-name"></view><view class="sk skel-meta"></view><view class="sk skel-meta skel-meta-short"></view></view></view></block>
    <view wx:elif="{{list.length === 0}}" class="empty-state"><text class="empty-icon">{{keyword ? '⌕' : '✓'}}</text><text class="empty-text">{{keyword ? '没有匹配的艺人' : activeTab === 'pending' ? '暂无待审核艺人' : activeTab === 'approved' ? '暂无已批准记录' : '暂无已拒绝记录'}}</text></view>
    <block wx:else><view wx:for="{{list}}" wx:key="_id" class="card {{selectMode && selected[item._id] ? 'card-selected' : ''}}" bindtap="onCardTap" data-id="{{item._id}}"><view wx:if="{{selectMode}}" class="card-checkbox"><view class="checkbox {{selected[item._id] ? 'checked' : ''}}"><text wx:if="{{selected[item._id]}}" class="check-mark">✓</text></view></view><view class="card-photo"><image wx:if="{{item.picUrl}}" class="photo-img" src="{{item.picUrl}}" mode="aspectFill" /><view wx:else class="photo-fallback"><text class="photo-initial">{{item.artistName[0]}}</text></view></view><view class="card-body"><view class="card-name-row"><text class="card-name">{{item.artistName}}</text><view wx:if="{{item.status === 'approved'}}" class="status-chip approved">批准</view><view wx:if="{{item.status === 'declined'}}" class="status-chip declined">拒绝</view></view><text class="card-from">{{item.manualEntry ? '用户提交（网易云未找到，需人工补充资料）' : item.requestSource === 'profile-submit' ? '用户提交申请' : '来自 ' + item.foundFrom + ' 的合作'}}</text><text wx:if="{{item.fromAlbum}}" class="card-album">《{{item.fromAlbum}}》</text><view class="card-meta-row"><text class="card-meta">第 {{item.round}} 轮</text><view class="meta-dot"></view><text class="card-meta">{{item.albumSize}} 张专辑</text><block wx:if="{{item.fansText}}"><view class="meta-dot"></view><text class="card-meta">{{item.fansText}}</text></block></view><view wx:if="{{!selectMode}}" class="card-actions"><view wx:if="{{activeTab === 'pending'}}" class="btn-approve {{deciding[item._id] ? 'btn-disabled' : ''}}" catchtap="onApprove" data-id="{{item._id}}"><text class="btn-icon">✓</text><text class="btn-label">批准</text></view><view wx:if="{{activeTab === 'pending'}}" class="btn-decline {{deciding[item._id] ? 'btn-disabled' : ''}}" catchtap="onDecline" data-id="{{item._id}}"><text class="btn-icon">✗</text><text class="btn-label">拒绝</text></view><view wx:if="{{activeTab === 'approved'}}" class="btn-revoke {{deciding[item._id] ? 'btn-disabled' : ''}}" catchtap="onRevoke" data-id="{{item._id}}"><text class="btn-icon">↩</text><text class="btn-label">撤销</text></view><view wx:if="{{activeTab === 'declined'}}" class="btn-restore {{deciding[item._id] ? 'btn-disabled' : ''}}" catchtap="onRestore" data-id="{{item._id}}"><text class="btn-icon">↩</text><text class="btn-label">恢复</text></view><view wx:if="{{!item.manualEntry}}" class="btn-refresh {{refreshing[item._id] ? 'btn-disabled' : ''}}" catchtap="onRefresh" data-id="{{item._id}}"><text class="btn-refresh-icon">↻</text></view></view></view></view><view wx:if="{{loading}}" class="load-more"><text class="load-more-text">加载中…</text></view><view wx:elif="{{!hasMore && list.length > 0}}" class="list-end"><text class="list-end-text">── 已全部加载 ──</text></view></block>
  </scroll-view>
  <view wx:if="{{selectMode}}" class="batch-bar"><view class="batch-info"><text class="batch-count">已选 {{Object.keys(selected).length}} 位</text><view class="batch-sel-all" bindtap="onSelectAll"><text class="batch-sel-all-text">全选</text></view></view><view class="batch-actions"><view wx:if="{{activeTab === 'pending'}}" class="batch-btn batch-approve {{batchDeciding ? 'btn-disabled' : ''}}" bindtap="onBatchApprove"><text>批准</text></view><view wx:if="{{activeTab === 'pending'}}" class="batch-btn batch-decline {{batchDeciding ? 'btn-disabled' : ''}}" bindtap="onBatchDecline"><text>拒绝</text></view><view wx:if="{{activeTab === 'approved'}}" class="batch-btn batch-revoke {{batchDeciding ? 'btn-disabled' : ''}}" bindtap="onBatchRestore"><text>撤销</text></view><view wx:if="{{activeTab === 'declined'}}" class="batch-btn batch-restore {{batchDeciding ? 'btn-disabled' : ''}}" bindtap="onBatchRestore"><text>恢复</text></view></view></view>
</view>