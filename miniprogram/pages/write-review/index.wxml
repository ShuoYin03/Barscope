<view class="page {{themeClass}}">
  <!-- TOPBAR -->
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <view class="back-btn" bindtap="onBack">
      <text class="back-arrow">←</text>
    </view>
    <text class="topbar-title">WRITE REVIEW</text>
  </view>

  <!-- ALBUM SUBTITLE -->
  <view class="album-sub">{{albumTitle || '专辑'}}</view>

  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- RATING — vinyl dial -->
    <view class="dial-section">
      <view class="vinyl-score-disc">
        <view class="vinyl-score-label">
          <text class="vinyl-score-num">{{ratingDisplay}}</text>
          <text class="vinyl-score-cap">SCORE</text>
        </view>
        <view class="vinyl-score-spindle" />
      </view>

      <text class="dial-hint">{{rating > 0 ? ratingDisplay + ' / 10' : '支持 0.5 分档评分'}}</text>

      <!-- 1-10 scores in 0.5 increments -->
      <view class="num-grid">
        <view
          wx:for="{{scoreOptions}}"
          wx:key="value"
          class="num-btn {{rating === item.value ? 'sel' : (item.value < rating ? 'fill' : '')}}"
          bindtap="onRateNum"
          data-n="{{item.value}}"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- CONTENT INPUT -->
    <view class="input-section">
      <text class="input-label">评语</text>
      <textarea
        class="content-input"
        placeholder="写下你对这张专辑的感受..."
        placeholder-class="content-ph"
        bindinput="onContentInput"
        maxlength="500"
        auto-height
      />
      <text class="char-count">{{content.length}}/500</text>
    </view>

  </scroll-view>

  <!-- SUBMIT BAR -->
  <view class="submit-bar">
    <view class="submit-btn {{(rating > 0 && !submitting) ? '' : 'disabled'}}" bindtap="onSubmit">
      <text>{{submitting ? '发布中...' : '提交评论'}}</text>
    </view>
  </view>
</view>