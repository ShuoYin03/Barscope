<view class="page">
  <view class="topbar" style="padding-top: {{statusBarHeight}}px">
    <text class="back" bindtap="onBack">←</text>
    <text class="title">ALBUM REVIEW</text>
  </view>
  <view class="mode-tabs">
    <view class="mode-tab {{mode === 'pending' ? 'active' : ''}}" bindtap="switchMode" data-mode="pending">待审核</view>
    <view class="mode-tab {{mode === 'hidden' ? 'active' : ''}}" bindtap="switchMode" data-mode="hidden">隐藏专辑</view>
  </view>
  <view class="head">
    <view class="head-copy">
      <text class="head-title">{{mode === 'hidden' ? '隐藏专辑处理' : '专辑审核'}}</text>
      <text class="head-desc">{{mode === 'hidden' ? '集中查看所有未显示专辑，可重新显示或永久删除' : '包含被举报专辑、网易云匹配提交和用户手动提交'}}</text>
    </view>
    <text class="count">{{list.length}} {{mode === 'hidden' ? '张隐藏' : '待处理'}}</text>
  </view>
  <view wx:if="{{!loading && !loadError && list.length}}" class="batch-toolbar">
    <view class="select-all" bindtap="toggleSelectAll"><view class="checkbox {{allSelected ? 'checked' : ''}}"><text wx:if="{{allSelected}}">✓</text></view><text>{{allSelected ? '取消全选' : '全选当前列表'}}</text></view>
    <text class="selected-count">已选 {{selectedIds.length}} 张</text>
    <view class="batch-actions">
      <view class="batch-keep {{selectedIds.length ? '' : 'disabled'}}" bindtap="batchDecide" data-decision="keep">{{mode === 'hidden' ? '批量显示' : '批量保留'}}</view>
      <view class="batch-delete {{selectedIds.length ? '' : 'disabled'}}" bindtap="batchDecide" data-decision="delete">批量删除</view>
    </view>
  </view>
  <scroll-view class="content" scroll-y>
    <block wx:if="{{loading}}"><view class="empty">加载中…</view></block>
    <block wx:else>
      <block wx:if="{{loadError}}"><view class="empty"><text>{{loadError}}</text><view class="retry" bindtap="loadCandidates">重新加载</view></view></block>
      <block wx:elif="{{list.length === 0}}"><view class="empty">{{mode === 'hidden' ? '暂无隐藏专辑' : '暂无待审核专辑'}}</view></block>
      <block wx:else>
        <view wx:for="{{list}}" wx:key="_id" class="card {{item.selected ? 'selected' : ''}}">
          <view class="card-check" bindtap="toggleSelect" data-id="{{item._id}}"><view class="checkbox {{item.selected ? 'checked' : ''}}"><text wx:if="{{item.selected}}">✓</text></view></view>
          <image class="cover" src="{{item.coverUrl}}" mode="aspectFill" />
          <view class="info">
            <text class="album">{{item.title}}</text>
            <text class="artist">{{item.artist || item.primaryArtist}} · {{item.releaseDate || item.releaseYear || '未知日期'}}</text>
            <text wx:if="{{item.company}}" class="artist">发行公司：{{item.company}}</text>
            <block wx:if="{{mode === 'hidden'}}">
              <text class="reason">状态：当前隐藏</text>
              <text class="reason">说明：{{item.hiddenReason}}</text>
            </block>
            <block wx:else>
              <text class="reason">来源：{{item.submissionMode === 'manual' ? '用户手动提交' : item.submissionMode === 'netease' ? '网易云匹配' : '专辑举报'}}</text>
              <text class="reason">说明：{{item.reportReason || item.candidateReason || '待管理员复核'}}</text>
            </block>
            <text wx:if="{{item.tracks && item.tracks.length}}" class="tracks">曲目：<block wx:for="{{item.tracks}}" wx:for-item="track" wx:key="no">{{index ? ' / ' : ''}}{{track.name || track}}</block></text>
            <text wx:if="{{item.description}}" class="tracks">简介：{{item.description}}</text>
            <text wx:if="{{item.duplicateTrackExample}}" class="tracks">{{item.duplicateTrackExample.join(' / ')}}</text>
          </view>
          <view class="actions">
            <view class="approve" bindtap="decide" data-id="{{item._id}}" data-decision="keep">{{mode === 'hidden' ? '显示' : '保留'}}</view>
            <view class="decline" bindtap="decide" data-id="{{item._id}}" data-decision="delete">删除</view>
          </view>
        </view>
      </block>
    </block>
  </scroll-view>
</view>
