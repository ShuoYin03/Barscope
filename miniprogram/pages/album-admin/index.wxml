<view class="page {{themeClass}}">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <view class="topbar-back" bindtap="onBack"><text class="back-arrow">←</text></view>
    <view class="topbar-titles">
      <text class="topbar-title">ALBUMS</text>
      <text class="topbar-sub">ADMIN</text>
    </view>
  </view>

  <view class="section-tabs">
    <view class="section-tab active" bindtap="onSectionTap" data-section="library">
      <text class="section-tab-label">专辑库</text>
    </view>
    <view class="section-tab" bindtap="onSectionTap" data-section="pending">
      <text class="section-tab-label">待审核</text>
      <view wx:if="{{pendingCount > 0}}" class="tab-badge"><text>{{pendingCount}}</text></view>
    </view>
    <view class="section-tab" bindtap="onSectionTap" data-section="ownership">
      <text class="section-tab-label">归属纠错</text>
      <view wx:if="{{ownershipCount > 0}}" class="tab-badge"><text>{{ownershipCount}}</text></view>
    </view>
  </view>

  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="intro">
      <text class="intro-kicker">ALBUM CONTROL DESK</text>
      <text class="intro-title">专辑管理</text>
      <text class="intro-copy">统一处理专辑入库、候选审核与艺人归属纠错。</text>
    </view>

    <view class="admin-card" bindtap="onSectionTap" data-section="library">
      <view class="card-icon">◉</view>
      <view class="card-body">
        <text class="card-title">专辑库</text>
        <text class="card-desc">按艺人检索专辑，管理显示状态与重复记录。</text>
      </view>
      <text class="card-arrow">→</text>
    </view>

    <view class="admin-card" bindtap="onSectionTap" data-section="pending">
      <view class="card-icon">⚑</view>
      <view class="card-body">
        <view class="card-title-row">
          <text class="card-title">待审核</text>
          <view wx:if="{{pendingCount > 0}}" class="count-chip"><text>{{pendingCount}}</text></view>
        </view>
        <text class="card-desc">审核新抓取或用户提交的专辑候选。</text>
      </view>
      <text class="card-arrow">→</text>
    </view>

    <view class="admin-card" bindtap="onSectionTap" data-section="ownership">
      <view class="card-icon">⇄</view>
      <view class="card-body">
        <view class="card-title-row">
          <text class="card-title">归属纠错</text>
          <view wx:if="{{ownershipCount > 0}}" class="count-chip"><text>{{ownershipCount}}</text></view>
        </view>
        <text class="card-desc">处理专辑与艺人之间的错误归属申请。</text>
      </view>
      <text class="card-arrow">→</text>
    </view>

    <view wx:if="{{loading}}" class="loading-row"><text>同步待处理数量中…</text></view>
  </scroll-view>
</view>
