<view class="page">
  <view class="topbar" style="padding-top: {{statusBarHeight}}px"><text class="back" bindtap="onBack">←</text><text class="title">OWNERSHIP</text></view>
  <view class="card"><text class="label">专辑</text><text class="album">{{title}}</text></view>
  <view class="card">
    <text class="label">应该归属到哪个 rapper？</text>
    <input class="input" placeholder="搜索已收录 rapper" placeholder-style="color:#766f68" value="{{targetArtistName}}" bindinput="onTargetInput" />
    <text wx:if="{{targetArtistId}}" class="picked-note">已选择：{{targetArtistName}}</text>
    <text wx:elif="{{artistSearching}}" class="picked-note">搜索中…</text>
    <view class="artist-results">
      <view wx:for="{{artistResults}}" wx:key="artistId" class="artist-row {{targetArtistId === item.artistId ? 'selected' : ''}}" bindtap="onPickArtist" data-id="{{item.artistId}}" data-name="{{item.artistName}}">
        <view class="artist-avatar"><image wx:if="{{item.picUrl}}" class="artist-img" src="{{item.picUrl}}" mode="aspectFill" /><text wx:else>{{item.letter || item.artistName[0]}}</text></view>
        <view class="artist-copy"><text class="artist-name">{{item.artistName}}</text><text class="artist-meta">{{item.albumSize || 0}} 张专辑</text></view>
        <text class="artist-check">{{targetArtistId === item.artistId ? '已选' : '选择'}}</text>
      </view>
    </view>
  </view>
  <view class="card"><text class="label">原因</text><textarea class="textarea" placeholder="例如：专辑页主艺人应为该 rapper / 当前归属错误" placeholder-style="color:#766f68" value="{{reason}}" bindinput="onReasonInput" /></view>
  <view class="submit" bindtap="onSubmit">提交管理员审核</view>
</view>