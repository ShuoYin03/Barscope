.page{min-height:100vh;background:#050307;color:#f4eee5}.topbar{height:72px;display:flex;align-items:center;padding-left:18px;padding-right:18px;border-bottom:1px solid #d64d22}.back{font-size:30px;color:#d64d22;margin-right:18px}.titles{display:flex;flex-direction:column}.title{font-size:22px;font-weight:800;letter-spacing:1px}.sub{font-size:11px;color:#8f8177;margin-top:2px}.content{height:calc(100vh - 144px);box-sizing:border-box;padding:24px 18px}.search-box{display:flex;gap:10px}.input{flex:1;background:#1a1512;color:#f4eee5;padding:13px 14px;font-size:15px}.ph{color:#6f625a}.search-btn{background:#d64d22;color:#090506;padding:13px 18px;font-weight:700}.toolbar{display:flex;justify-content:space-between;align-items:center;margin:22px 0 12px}.summary{font-size:12px;color:#9b8d83}.select-all{font-size:12px;color:#d64d22}.album-card{display:flex;align-items:center;padding:12px 0;border-bottom:1px solid #211a17}.cover{width:64px;height:64px;background:#181310}.meta{flex:1;display:flex;flex-direction:column;margin-left:12px;min-width:0}.album-title{font-size:16px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.artist{font-size:12px;color:#a99a90;margin-top:5px}.mid{font-size:10px;color:#675b55;margin-top:5px}.check{font-size:22px;color:#d64d22;padding-left:12px}.empty{text-align:center;color:#756860;font-size:13px;padding:80px 20px}.footer{position:fixed;left:0;right:0;bottom:0;padding:12px 18px 20px;background:#080508;border-top:1px solid #211a17}.promote{background:#d64d22;color:#080508;text-align:center;padding:15px;font-weight:800}.bottom-space{height:100px}
