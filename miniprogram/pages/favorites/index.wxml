<view class="page {{themeClass}}">
  <!-- TOPBAR -->
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <text class="topbar-title">COLLECTION</text>
    <text class="topbar-sub">收藏</text>
  </view>

  <!-- LOGGED-OUT STATE -->
  <view wx:if="{{!isLoggedIn}}" class="gate-content">
    <text class="gate-icon">☆</text>
    <text class="gate-title">登录后查看你的专辑收藏架</text>
    <text class="gate-sub">收藏喜欢的专辑，随时回顾你的品味历程</text>
    <view class="gate-btn" bindtap="onLogin"><text>立即登录</text></view>
  </view>

  <!-- LOADING STATE -->
  <scroll-view wx:elif="{{loading}}" class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="side-row">
      <view class="sk" style="width:200rpx;height:24rpx;" />
      <view class="side-rule" />
    </view>
    <view class="album-grid">
      <view wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this" class="skel-cell">
        <view class="sk" style="width:240rpx;height:240rpx;border-radius:50%;" />
        <view class="sk" style="width:80%;height:24rpx;margin-top:18rpx;" />
      </view>
    </view>
  </scroll-view>

  <!-- LOGGED-IN: EMPTY STATE -->
  <view wx:elif="{{favorites.length === 0}}" class="empty-shelf">
    <text class="empty-icon">▨</text>
    <text class="empty-title">收藏架还是空的</text>
    <text class="empty-sub">去发现页面找找你喜欢的专辑吧</text>
    <view class="discover-btn" bindtap="onGoDiscover"><text>去发现</text></view>
  </view>

  <!-- LOGGED-IN: SHELF -->
  <scroll-view wx:else class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="side-row">
      <text class="side-text">SIDE A — 唱片墙 · {{favorites.length}} 张</text>
      <view class="side-rule" />
    </view>
    <view class="album-grid">
      <view
        wx:for="{{favorites}}"
        wx:key="id"
        class="grid-cell"
        bindtap="onAlbumTap"
        data-id="{{item.id}}"
      >
        <view class="grid-disc">
          <view class="disc-label">
            <image wx:if="{{item.coverUrl}}" class="cover-img" src="{{item.coverUrl}}" mode="aspectFill" />
            <view wx:else class="disc-label-fallback" />
          </view>
          <view class="disc-spindle" />
        </view>
        <view class="grid-foot">
          <view class="grid-text">
            <text class="grid-title">{{item.title}}</text>
            <text class="grid-artist">{{item.artist}}</text>
          </view>
          <text class="grid-score-badge">{{item.score}}</text>
        </view>
      </view>
    </view>
    <view class="list-end">
      <text class="list-end-text">— {{favorites.length}} RECORDS —</text>
    </view>
  </scroll-view>

  <bottom-nav selected="{{3}}" />
</view>
