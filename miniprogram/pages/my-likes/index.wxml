<view class="page {{themeClass}}">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px">
    <text class="back" bindtap="onBack">←</text>
    <text class="topbar-title">MY LIKES</text>
    <text class="topbar-sub">{{reviews.length}} 条</text>
  </view>

  <view wx:if="{{loading}}" class="state"><text>LOADING...</text></view>

  <view wx:elif="{{reviews.length === 0}}" class="state">
    <text class="empty-mark">♡</text>
    <text class="empty-title">还没有点赞过评论</text>
    <text class="empty-sub">去专辑页给喜欢的乐评点个赞吧</text>
  </view>

  <scroll-view wx:else class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="side-row"><text class="side-text">SIDE A — 我的点赞 · {{reviews.length}}</text></view>
    <view
      wx:for="{{reviews}}"
      wx:key="_id"
      class="review-card"
      bindtap="onReviewTap"
      data-id="{{item.albumId}}"
    >
      <view class="review-head">
        <view class="disc"><view class="disc-label" /></view>
        <view class="review-meta">
          <text class="album-title">{{item.albumTitle}}</text>
          <text class="review-time">{{item.userName}} · {{item.timeAgo}}</text>
        </view>
        <text class="rating">{{item.ratingText}}</text>
      </view>
      <text class="review-content">{{item.content}}</text>
      <view class="review-foot">
        <text>♡ {{item.likes}}</text>
        <text class="album-link">查看专辑 →</text>
      </view>
    </view>
    <view class="list-end"><text>— END OF SIDE A —</text></view>
  </scroll-view>
</view>
