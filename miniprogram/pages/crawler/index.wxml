<view class="page">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px"><view class="topbar-back" bindtap="onBack"><text class="back-arrow">←</text></view><view class="topbar-titles"><text class="topbar-title">CRAWLER</text><text class="topbar-sub">MGMT</text></view></view>
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="card"><view class="section-title">定时触发器（每 5 分钟）</view><view class="status-row"><view class="status-dot {{heartbeatStale ? 'error' : 'running'}}"></view><text class="status-text">{{heartbeatStale ? '可能已停止' : '正常运行'}}</text></view><text class="time-text" style="display:block;margin-top:12rpx;">最近一次醒来: {{heartbeatText}}</text></view>
    <view class="card"><view class="section-title">运行状态</view><view class="status-row"><view class="status-dot {{crawlerTriggering ? 'running' : crawlerStatus.status}}"></view><text class="status-text">{{crawlerTriggering ? '启动中' : crawlerStatus.status === 'idle' ? '空闲' : crawlerStatus.status === 'pending' ? '等待中' : crawlerStatus.status === 'running' ? '运行中' : crawlerStatus.status === 'done' ? '已完成' : crawlerStatus.status === 'aborted' ? '已中止' : crawlerStatus.status === 'error' ? '出错' : '—'}}</text><view wx:if="{{crawlerStatus.mode && crawlerStatus.status !== 'idle'}}" class="mode-tag"><text>{{ crawlerStatus.mode === 'allApproved' ? '全部已批准' : crawlerStatus.mode === 'artist' ? '艺人 ' + crawlerStatus.param : crawlerStatus.mode === 'album' ? '专辑 ' + crawlerStatus.param : '裂变' }}</text></view><text wx:if="{{!crawlerTriggering && crawlerStatus.completedAt}}" class="time-text">上次完成: {{crawlerStatus.completedAt}}</text></view><block wx:if="{{crawlerTriggering || crawlerStatus.status === 'running' || crawlerStatus.status === 'pending'}}"><view class="progress-track"><view wx:if="{{!crawlerTriggering && crawlerStatus.status === 'running'}}" class="progress-fill" style="width: {{crawlerProgressPct}}%" /></view><view class="meta-row"><text class="meta">{{crawlerTriggering ? '正在启动，请稍候…' : '云端处理中…'}}</text></view></block><block wx:if="{{!crawlerTriggering && (crawlerStatus.status === 'done' || crawlerStatus.status === 'aborted') && crawlerStatus.lastRunSummary}}"><view class="summary-row"><view class="summary-chip"><text class="summary-num">+{{crawlerStatus.lastRunSummary.newAlbums}}</text><text class="summary-label">新专辑</text></view><view class="summary-chip"><text class="summary-num">+{{crawlerStatus.lastRunSummary.newCandidates}}</text><text class="summary-label">新候选</text></view></view></block></view>
    <view class="card"><view class="section-title">爬取模式</view><view class="mode-grid"><view wx:for="{{crawlerModes}}" wx:key="key" class="mode-chip {{crawlerMode === item.key ? 'active' : ''}}" bindtap="onCrawlerModeTap" data-key="{{item.key}}"><text class="mode-label">{{item.label}}</text></view></view><text class="mode-desc">{{crawlerDesc}}</text><input wx:if="{{crawlerNeedsId}}" class="id-input" type="number" value="{{crawlerParam}}" placeholder="{{crawlerPlaceholder}}" placeholder-style="color:#888" bindinput="onCrawlerParamInput" /></view>
    <view class="card"><view class="section-title">操作</view><view class="actions-row"><view wx:if="{{crawlerStatus.status === 'running' || crawlerStatus.status === 'pending'}}" class="btn-abort" bindtap="onCrawlerAbort"><text class="btn-text">中止</text></view><view wx:else class="btn-run {{crawlerTriggering ? 'btn-disabled' : ''}}" bindtap="onCrawlerTrigger"><text class="btn-text">立即运行</text></view><view class="btn-clear" bindtap="onCrawlerClearLog"><text class="btn-text">清除日志</text></view></view><view class="actions-row" style="margin-top:16rpx"><view class="btn-clear" style="flex:1" bindtap="onCleanupSingles"><text class="btn-text">清理专辑库</text></view></view></view>
    <view class="card card-log"><view class="section-title">运行日志</view><view wx:if="{{!crawlerStatus.log || crawlerStatus.log.length === 0}}" class="log-empty"><text class="meta">暂无日志</text></view><view wx:else class="log-list"><text wx:for="{{crawlerStatus.log}}" wx:key="*this" class="log-line">{{item}}</text></view></view>
  </scroll-view>
</view>