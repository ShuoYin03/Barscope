.page{min-height:100vh;background:#090609;color:#f3eadf}.topbar{height:88rpx;display:flex;align-items:center;padding-left:32rpx;padding-right:32rpx;border-bottom:1rpx solid #2a211d}.back{font-size:44rpx;color:#d65122;margin-right:24rpx}.title{font-size:34rpx;font-weight:700}.content{height:calc(100vh - 120rpx);box-sizing:border-box;padding:32rpx}.cover-row{display:flex;align-items:center;gap:28rpx;margin-bottom:32rpx}.cover{width:180rpx;height:180rpx;background:#1d1714}.cover.empty{display:flex;align-items:center;justify-content:center;color:#75675f;font-size:24rpx}.cover-btn,.action,.picker{border:1rpx solid #6b311f;padding:26rpx 28rpx;background:#17110f}.section{margin-bottom:28rpx}.label{display:block;color:#d65122;font-size:24rpx;letter-spacing:2rpx;margin-bottom:12rpx}.input{width:100%;box-sizing:border-box;height:96rpx;line-height:96rpx;padding:0 24rpx;background:#17110f;border:1rpx solid #3a2b25;color:#f3eadf;font-size:28rpx}.textarea{width:100%;box-sizing:border-box;height:320rpx;min-height:320rpx;padding:24rpx;background:#17110f;border:1rpx solid #3a2b25;color:#f3eadf;font-size:28rpx;line-height:1.5}.action,.picker{display:flex;justify-content:space-between;align-items:center;font-size:28rpx;min-height:96rpx;box-sizing:border-box}.save{margin:36rpx 0 80rpx;background:#d65122;color:#090609;text-align:center;padding:28rpx;font-size:30rpx;font-weight:700}.disabled{opacity:.5}