<view class="page {{themeClass}}">
  <view class="topbar" style="height: {{topbarHeight}}px; padding-top: {{statusBarHeight}}px"><text class="topbar-title">DISCOVER</text><text class="topbar-filter">⊞</text></view>
  <view class="search-wrap" style="position:relative;z-index:40">
    <view class="search-inner"><text class="search-icon">⌕</text><input class="search-input" placeholder="搜索专辑、歌手" placeholder-class="search-ph" bindfocus="onSearchFocus" bindblur="onSearchBlur" bindinput="onSearch" value="{{keyword}}" /></view>
    <view wx:if="{{suggestionVisible}}" class="suggestion-panel" style="position:absolute;left:32rpx;right:32rpx;top:calc(100% - 20rpx);z-index:60;max-height:620rpx;overflow-y:auto;background:#120d10;border:2rpx solid #30272c;box-shadow:0 18rpx 42rpx rgba(0,0,0,.58)">
      <view wx:if="{{suggestionLoading}}" class="suggestion-state" style="padding:30rpx 20rpx;text-align:center;font-size:23rpx;color:#766f68">正在搜索…</view>
      <block wx:elif="{{viewMode === 'albums'}}">
        <view wx:if="{{albumSuggestions.length === 0}}" class="suggestion-state" style="padding:30rpx 20rpx;text-align:center;font-size:23rpx;color:#766f68">没有匹配的专辑</view>
        <view wx:for="{{albumSuggestions}}" wx:key="id" class="suggestion-row" style="display:flex;align-items:center;gap:18rpx;min-height:96rpx;padding:14rpx 18rpx;border-bottom:2rpx solid #1b1519;box-sizing:border-box" catchtap="onSuggestionAlbumTap" data-id="{{item.id}}"><image wx:if="{{item.coverUrl}}" style="width:68rpx;height:68rpx;flex-shrink:0" src="{{item.coverUrl}}" mode="aspectFill" /><view wx:else style="width:68rpx;height:68rpx;background:#C94E25" /><view style="flex:1;min-width:0"><text class="suggestion-name">{{item.title}}</text><text class="suggestion-meta">{{item.artist}}</text><text class="suggestion-date">{{item.releaseDisplay}}</text></view><text class="suggestion-type">ALBUM</text></view>
      </block>
      <block wx:else>
        <view wx:if="{{artistSuggestions.length === 0}}" class="suggestion-state" style="padding:30rpx 20rpx;text-align:center;font-size:23rpx;color:#766f68">没有匹配的 rapper</view>
        <view wx:for="{{artistSuggestions}}" wx:key="artistId" class="suggestion-row" style="display:flex;align-items:center;gap:18rpx;min-height:96rpx;padding:14rpx 18rpx;border-bottom:2rpx solid #1b1519" catchtap="onSuggestionArtistTap" data-artist-id="{{item.artistId}}" data-artist="{{item.artistName}}"><view class="suggestion-avatar"><image wx:if="{{item.picUrl}}" class="suggestion-avatar-img" src="{{item.picUrl}}" mode="aspectFill" /><text wx:else>{{item.letter || item.artistName[0]}}</text></view><view style="flex:1;min-width:0"><text class="suggestion-name">{{item.artistName}}</text><text class="suggestion-meta">{{item.albumSize || 0}} 张专辑</text></view><text class="suggestion-type">RAPPER</text></view>
      </block>
    </view>
  </view>
  <view class="view-switch"><view class="switch-chip {{viewMode === 'albums' ? 'active' : ''}}" bindtap="onViewModeTap" data-mode="albums"><text>ALBUMS</text></view><view class="switch-chip {{viewMode === 'artists' ? 'active' : ''}}" bindtap="onViewModeTap" data-mode="artists"><text>ARTISTS</text></view></view>
  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}" scroll-into-view="{{artistScrollIntoView}}" scroll-with-animation="{{true}}" bindscroll="onContentScroll" bindscrolltolower="onAlbumScrollToLower" lower-threshold="160">
    <block wx:if="{{viewMode === 'albums'}}">
      <view class="side-row"><text class="side-text">SIDE A — SUBMIT</text><view class="side-rule" /></view>
      <view class="artist-submit-row" bindtap="onSubmitAlbumRequest"><text class="artist-submit-icon">＋</text><view class="artist-submit-copy"><text class="artist-submit-title">提交专辑</text><text class="artist-submit-desc">未收录？提交审核</text></view><text class="artist-all-arrow">›</text></view>
      <view class="side-row"><text class="side-text">SIDE B — 年份 YEAR</text><view class="side-rule" /></view>
      <scroll-view class="timeline-scroll" scroll-x enhanced show-scrollbar="{{false}}" scroll-into-view="{{yearScrollIntoView}}" scroll-with-animation="{{true}}">
        <view class="timeline-track"><view class="timeline-line" /><view wx:for="{{years}}" wx:key="name" id="year-{{item.name}}" class="timeline-item {{activeYear === item.name ? 'active' : ''}}" bindtap="onYearTap" data-year="{{item.name}}"><view class="timeline-dot" /><text class="timeline-label">{{item.name}}</text></view></view>
      </scroll-view>
      <view class="side-row"><text class="side-text">SIDE C — {{activeYear ? activeYear : '全部'}}{{activeMonth ? '.' + activeMonth : ''}} · {{loading ? '加载中' : total + ' 张'}}</text><view class="side-rule" /></view>
      <view wx:if="{{loading}}" class="empty-state"><text class="empty-text">加载中…</text></view>
      <view wx:elif="{{list.length === 0}}" class="empty-state"><text class="empty-text">没有找到相关专辑</text></view>
      <block wx:elif="{{activeYear === 'ALL'}}">
        <view wx:if="{{allRatedList.length > 0}}" class="album-list"><view class="artist-letter-row"><text class="artist-letter-title">SCORED</text><view class="artist-letter-rule" /></view><view wx:for="{{allRatedList}}" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{item.id}}"><view class="vinyl-cover-wrap"><view class="vinyl-disc-peek" /><image wx:if="{{item.coverUrl}}" class="cover-sq" src="{{item.coverUrl}}" mode="aspectFill" /></view><view class="album-info"><text class="album-title">{{item.title}}</text><text class="album-artist">{{item.artist}}</text><text class="album-date">{{item.releaseDisplay}}</text></view><text class="album-score">{{item.score}}</text></view></view>
        <view class="album-list with-alpha-index"><view class="artist-letter-row"><text class="artist-letter-title">UNRATED A-Z</text><view class="artist-letter-rule" /></view><view wx:for="{{allUnratedGroups}}" wx:key="letter" id="album-letter-{{item.letter === '#' ? 'num' : item.letter}}"><view class="artist-letter-row"><text class="artist-letter-title">{{item.letter}}</text><view class="artist-letter-rule" /></view><view wx:for="{{item.list}}" wx:for-item="album" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{album.id}}"><view class="vinyl-cover-wrap"><view class="vinyl-disc-peek" /><image wx:if="{{album.coverUrl}}" class="cover-sq" src="{{album.coverUrl}}" mode="aspectFill" /></view><view class="album-info"><text class="album-title">{{album.title}}</text><text class="album-artist">{{album.artist}}</text><text class="album-date">{{album.releaseDisplay}}</text></view><text class="album-score">{{album.score}}</text></view></view></view>
      </block>
      <block wx:else>
        <view wx:if="{{yearRatedList.length > 0}}" class="album-list"><view class="artist-letter-row"><text class="artist-letter-title">SCORED</text><view class="artist-letter-rule" /></view><view wx:for="{{yearRatedList}}" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{item.id}}"><view class="vinyl-cover-wrap"><view class="vinyl-disc-peek" /><image wx:if="{{item.coverUrl}}" class="cover-sq" src="{{item.coverUrl}}" mode="aspectFill" /></view><view class="album-info"><text class="album-title">{{item.title}}</text><text class="album-artist">{{item.artist}}</text><text class="album-date">{{item.releaseDisplay}}</text></view><text class="album-score">{{item.score}}</text></view></view>
        <view wx:if="{{yearUnratedList.length > 0}}" class="album-list with-month-index"><view class="artist-letter-row"><text class="artist-letter-title">UNRATED · RELEASE DATE</text><view class="artist-letter-rule" /></view><view wx:for="{{yearUnratedList}}" wx:key="id" class="album-row" bindtap="onAlbumTap" data-id="{{item.id}}"><view class="vinyl-cover-wrap"><view class="vinyl-disc-peek" /><image wx:if="{{item.coverUrl}}" class="cover-sq" src="{{item.coverUrl}}" mode="aspectFill" /></view><view class="album-info"><text class="album-title">{{item.title}}</text><text class="album-artist">{{item.artist}}</text><text class="album-date">{{item.releaseDisplay}}</text></view><text class="album-score">{{item.score}}</text></view></view>
      </block>
      <view wx:if="{{loadingMore}}" class="load-more">加载更多专辑…</view><view wx:elif="{{!albumHasMore}}" class="load-more">已显示全部 {{total}} 张专辑</view>
    </block>
    <block wx:else>
      <view class="side-row"><text class="side-text">SIDE A — LABEL 厂牌</text><view class="side-rule" /></view>
      <scroll-view scroll-x show-scrollbar="{{false}}" class="brand-scroll"><view class="brand-stamps brand-stamps-horizontal"><view wx:for="{{brandCards}}" wx:key="name" class="brand-stamp {{activeBrand === item.name ? 'active' : ''}}" bindtap="onBrandTap" data-brand="{{item.name}}"><text class="brand-name">{{item.name}}</text><text class="brand-count">{{item.count}}</text></view></view></scroll-view>
      <view class="side-row"><text class="side-text">SIDE B — SUBMIT</text><view class="side-rule" /></view>
      <view class="artist-submit-row" bindtap="onSubmitArtistRequest"><text class="artist-submit-icon">＋</text><view class="artist-submit-copy"><text class="artist-submit-title">提交 rapper</text><text class="artist-submit-desc">未收录？提交审核</text></view><text class="artist-all-arrow">›</text></view>
      <view class="side-row artist-result-title"><text class="side-text">SIDE C — {{activeBrand}} · {{artistLoading ? '加载中' : artistTotal + ' 位'}}</text><view class="side-rule" /></view>
      <view wx:if="{{artistLoading}}" class="empty-state"><text class="empty-text">加载中…</text></view><view wx:elif="{{artistVisibleList.length === 0}}" class="empty-state"><text class="empty-text">这个分类暂无艺人</text></view>
      <view wx:elif="{{activeBrand === '全部'}}" class="artist-all-list with-alpha-index"><view wx:for="{{artistLetterGroups}}" wx:key="letter" id="artist-letter-{{item.letter === '#' ? 'num' : item.letter}}"><view class="artist-letter-row"><text class="artist-letter-title">{{item.letter}}</text><view class="artist-letter-rule" /></view><view wx:for="{{item.list}}" wx:for-item="artist" wx:key="artistId" class="artist-all-row" bindtap="onArtistTap" data-artist-id="{{artist.artistId}}" data-artist="{{artist.artistName}}"><view class="artist-all-avatar"><image wx:if="{{artist.picUrl}}" class="artist-all-img" src="{{artist.picUrl}}" mode="aspectFill" /><text wx:else class="artist-all-initial">{{artist.letter}}</text></view><view class="artist-all-info"><text class="artist-all-name">{{artist.artistName}}</text><text class="artist-all-meta">{{artist.albumSize || 0}} 张专辑</text></view><text class="artist-all-arrow">›</text></view></view></view>
      <view wx:else class="artist-grid"><view wx:for="{{artistVisibleList}}" wx:key="artistId" class="artist-tile" bindtap="onArtistTap" data-artist-id="{{item.artistId}}" data-artist="{{item.artistName}}"><view class="artist-tile-avatar"><image wx:if="{{item.picUrl}}" class="artist-tile-img" src="{{item.picUrl}}" mode="aspectFill" /><text wx:else class="artist-tile-initial">{{item.letter}}</text></view><text class="artist-tile-name">{{item.artistName}}</text><text class="artist-tile-meta">{{item.albumSize || 0}} 张专辑</text></view></view>
    </block>
  </scroll-view>
  <view wx:if="{{viewMode === 'albums' && activeYear && activeYear !== 'ALL' && activeYear !== '2010s' && activeYear !== '2000s'}}" class="month-index transient {{monthIndexVisible ? 'visible' : ''}}"><view wx:for="{{months}}" wx:key="*this" class="month-index-item {{activeMonth === item ? 'active' : ''}}" bindtap="onMonthTap" data-month="{{item}}"><text>{{item}}</text></view></view>
  <view wx:if="{{viewMode === 'albums' && activeYear === 'ALL' && allAlbumLetters.length > 1}}" class="alphabet-index"><view wx:for="{{allAlbumLetters}}" wx:key="*this" class="alphabet-index-item {{activeAlbumLetter === item ? 'active' : ''}}" bindtap="onAlbumLetterTap" data-letter="{{item}}"><text>{{item}}</text></view></view>
  <view wx:if="{{viewMode === 'artists' && activeBrand === '全部' && artistLetters.length > 1}}" class="alphabet-index"><view wx:for="{{artistLetters}}" wx:key="*this" class="alphabet-index-item {{activeLetter === item ? 'active' : ''}}" bindtap="onLetterTap" data-letter="{{item}}"><text>{{item}}</text></view></view>
  <bottom-nav selected="{{2}}" />
</view>